@model IEnumerable<Recruitment.Web.ViewModels.Report.ReportListViewModel>
@using System.Text.Json

@{
    ViewData["Title"] = "Reports";
}

<div class="card-component">
    <div class="card-header">
        <div class="flex-between">
            <div>
                <h2 class="card-title">Reports</h2>
                <p class="card-description">Manage system reports</p>
            </div>
            <button type="button"
                    class="btn-component btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#createModal">
                <i class="bi bi-plus-circle me-2"></i>
                Add Report
            </button>
        </div>
    </div>

    <div class="card-content">
        <div class="table-component">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Stored Procedure</th>
                        <th>Status</th>
                        <th>Description</th>
                        <th class="text-end" style="width:220px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Name</td>
                                <td>
                                    <span class="badge-component badge-outline">
                                        @item.StoredProcedure
                                    </span>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge-component badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-component badge-muted">Inactive</span>
                                    }
                                </td>
                                <td>@item.Description</td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn-component btn-sm btn-info">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <button class="btn-component btn-sm btn-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editModal"
                                                data-id="@item.Id"
                                                data-name="@item.Name"
                                                data-sp="@item.StoredProcedure"
                                                data-desc="@item.Description"
                                                data-active="@item.IsActive"
                                                data-parameters='@System.Text.Json.JsonSerializer.Serialize(item.Parameters, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase })'>
                                            <i class="bi bi-pencil"></i>
                                        </button>

                                        <button class="btn-component btn-sm btn-destructive"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@item.Id"
                                                data-name="@item.Name">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">No reports found</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>

<!--Create Modal-->
<div class="modal fade" id="createModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i> Add Report</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="form-field">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-input" name="Name" required />
                    </div>

                    <div class="form-field">
                        <label class="form-label">Stored Procedure <span class="text-danger">*</span></label>
                        <input type="text" class="form-input" name="StoredProcedure" required />
                    </div>

                    <div class="form-field">
                        <label class="form-label">Description</label>
                        <textarea class="form-input" name="Description"></textarea>
                    </div>

                    <div class="form-field mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                            <input type="hidden" name="IsActive" value="false" />
                            <label class="form-check-label">Active</label>
                        </div>
                    </div>

                    <!-- Parameters Section -->
                    <div id="createParametersSection">
                        <h6>Parameters</h6>
                        <div id="createParametersList"></div>
                        <button type="button" class="btn-component btn-sm btn-outline-primary mt-2" id="addCreateParameter">
                            <i class="bi bi-plus-circle"></i> Add Parameter
                        </button>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-component btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- Edit Modal -->
<div class="modal fade" id="editModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="Edit"
                  method="post"
                  onsubmit="reindexParameters('editParametersList')">

                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editId" />

                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-pencil me-2"></i> Edit Report
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="form-field">
                        <label class="form-label">Name *</label>
                        <input type="text" class="form-input" id="editName" name="Name" required />
                    </div>

                    <div class="form-field">
                        <label class="form-label">Stored Procedure *</label>
                        <input type="text" class="form-input" id="editSP" name="StoredProcedure" required />
                    </div>

                    <div class="form-field">
                        <label class="form-label">Description</label>
                        <textarea class="form-input" id="editDesc" name="Description"></textarea>
                    </div>

                    <div class="form-field mb-3">
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="editActive"
                                   name="IsActive"
                                   value="true" />
                            <input type="hidden" name="IsActive" value="false" />
                            <label class="form-check-label">Active</label>
                        </div>
                    </div>

                    <hr />

                    <h6>Parameters</h6>
                    <div id="editParametersList"></div>

                    <button type="button"
                            class="btn-component btn-sm btn-outline-primary mt-2"
                            id="addEditParameter">
                        <i class="bi bi-plus-circle"></i> Add Parameter
                    </button>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-component btn-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>


<!--Delete Modal-->
<div class="modal fade" id="deleteModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="id" id="deleteId" />

                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-trash me-2"></i> Delete Report</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <p>Are you sure you want to delete <strong id="deleteName"></strong>?</p>
                    <p class="text-muted">This action cannot be undone.</p>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-component btn-destructive">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // Helpers
        // =========================
        function reindexParameters(containerId) {
            const items = document.querySelectorAll(`#${containerId} > .form-field`);
            items.forEach((item, index) => {

                const label = item.querySelector('strong');
                if (label) {
                    label.textContent = `Parameter ${index + 1}`;
                }

                item.querySelectorAll('input, select, textarea').forEach(el => {
                    if (el.name && el.name.includes('Parameters[')) {
                        el.name = el.name.replace(/Parameters\[\d+\]/, `Parameters[${index}]`);
                    }
                });
            });

            if (containerId === 'editParametersList') {
                editParamCount = items.length;
            } else if (containerId === 'createParametersList') {
                createParamCount = items.length;
            }
        }

        // =========================
        // Load enum types from server
        // =========================
        const paramTypes = @Html.Raw(ViewBag.ReportParameterTypes ?? "[]");

        function createParameterSelect(index, selectedValue) {
            let selectHtml = `<select class="form-input mt-1" name="Parameters[${index}].Type" required>`;
            paramTypes.forEach(p => {
                const selected = p.Name === selectedValue ? "selected" : "";
                selectHtml += `<option value="${p.Name}" ${selected}>${p.Name}</option>`;
            });
            selectHtml += `</select>`;
            return selectHtml;
        }

        // =========================
        // Create Modal - Add Parameter
        // =========================
        let createParamCount = 0;

        document.getElementById('addCreateParameter')?.addEventListener('click', function () {
            const container = document.getElementById('createParametersList');
            const index = createParamCount++;

            const html = `
            <div class="form-field border rounded p-2 mb-2">
                <input type="hidden" name="Parameters[${index}].Id" value="0" />

                <div class="d-flex justify-content-between">
                    <strong>Parameter ${index + 1}</strong>
                    <button type="button" class="btn-component btn-sm btn-destructive removeParam">X</button>
                </div>

                <input type="text" class="form-input mt-1" name="Parameters[${index}].Name" placeholder="Name" required />
                <input type="text" class="form-input mt-1" name="Parameters[${index}].DisplayName" placeholder="Display Name" required />

                ${createParameterSelect(index, "")}

                <div class="form-check mt-1">
                    <input type="checkbox" class="form-check-input" name="Parameters[${index}].IsRequired" value="true" />
                    <input type="hidden" name="Parameters[${index}].IsRequired" value="false" />
                    <label class="form-check-label">Required</label>
                </div>
            </div>`;
            container.insertAdjacentHTML('beforeend', html);
        });

        // =========================
        // Fill Edit Modal
        // =========================
        let editParamCount = 0;

        document.getElementById('editModal')?.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;

            // Basic fields
            document.getElementById('editId').value = btn.dataset.id;
            document.getElementById('editName').value = btn.dataset.name;
            document.getElementById('editSP').value = btn.dataset.sp;
            document.getElementById('editDesc').value = btn.dataset.desc || '';
            document.getElementById('editActive').checked =
                btn.dataset.active?.toLowerCase() === "true";

            const container = document.getElementById('editParametersList');
            container.innerHTML = '';
            editParamCount = 0;

            const params = JSON.parse(btn.dataset.parameters || '[]');

            params.forEach(p => {
                const index = editParamCount++;

                const html = `
                <div class="form-field border rounded p-2 mb-2">
                    <input type="hidden" name="Parameters[${index}].Id" value="${p.id ?? p.Id ?? 0}" />

                    <div class="d-flex justify-content-between">
                        <strong>Parameter ${index + 1}</strong>
                        <button type="button" class="btn-component btn-sm btn-destructive removeParam">X</button>
                    </div>

                    <input type="text" class="form-input mt-1" name="Parameters[${index}].Name" value="${p.name ?? p.Name ?? ''}" required />
                    <input type="text" class="form-input mt-1" name="Parameters[${index}].DisplayName" value="${p.displayName ?? p.DisplayName ?? ''}" required />

                    ${createParameterSelect(index, p.type ?? p.Type)}

                    <div class="form-check mt-1">
                        <input type="checkbox" class="form-check-input" name="Parameters[${index}].IsRequired" value="true" ${(p.isRequired ?? p.IsRequired) ? 'checked' : ''} />
                        <input type="hidden" name="Parameters[${index}].IsRequired" value="false" />
                        <label class="form-check-label">Required</label>
                    </div>
                </div>`;
                container.insertAdjacentHTML('beforeend', html);
            });
        });

        // =========================
        // Add new parameter to Edit Modal
        // =========================
        document.getElementById('addEditParameter')?.addEventListener('click', function () {
            const container = document.getElementById('editParametersList');
            const index = editParamCount++;

            const html = `
            <div class="form-field border rounded p-2 mb-2">
                <input type="hidden" name="Parameters[${index}].Id" value="0" />

                <div class="d-flex justify-content-between">
                    <strong>Parameter ${index + 1}</strong>
                    <button type="button" class="btn-component btn-sm btn-destructive removeParam">X</button>
                </div>

                <input type="text" class="form-input mt-1" name="Parameters[${index}].Name" placeholder="Name" required />
                <input type="text" class="form-input mt-1" name="Parameters[${index}].DisplayName" placeholder="Display Name" required />

                ${createParameterSelect(index, "")}

                <div class="form-check mt-1">
                    <input type="checkbox" class="form-check-input" name="Parameters[${index}].IsRequired" value="true" />
                    <input type="hidden" name="Parameters[${index}].IsRequired" value="false" />
                    <label class="form-check-label">Required</label>
                </div>
            </div>`;
            container.insertAdjacentHTML('beforeend', html);
        });

        // =========================
        // Remove parameter (Create / Edit)
        // =========================
        document.addEventListener('click', function (e) {
            if (e.target.classList.contains('removeParam')) {
                const container = e.target.closest('.form-field').parentElement;
                const containerId = container.id;

                e.target.closest('.form-field').remove();

                reindexParameters(containerId);
            }
        });

        // =========================
        // Fill Delete Modal
        // =========================
        document.getElementById('deleteModal')?.addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('deleteId').value = btn.dataset.id;
            document.getElementById('deleteName').textContent = btn.dataset.name;
        });
    </script>
}
