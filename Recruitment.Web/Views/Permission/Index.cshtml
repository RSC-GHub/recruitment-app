@model IEnumerable<Recruitment.Application.DTOs.UserManagement.Permission.PermissionDto>
@{
    ViewData["Title"] = "Permissions";
}

<style>

    :root {
        --ink: #0d0d0d;
        --paper: #f7f6f3;
        --muted: #888;
        --line: #e0deda;
        --accent: #1a1a1a;
        --tag-bg: #efefed;
        --danger: #c0392b;
        --danger-bg: #fdf0ef;
        --radius: 6px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--paper);
        color: var(--ink);
        /* font-family: 'Syne', sans-serif; */
    }

    /* ── PAGE HEADER ─────────────────────────────────── */
    .perm-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid var(--ink);
        margin-bottom: 2rem;
    }

    .perm-header-left h1 {
        font-size: clamp(1.8rem, 3vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1;
    }

    .perm-header-left p {
        font-size: 0.8rem;
        color: var(--muted);
        margin-top: 0.4rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 500;
    }

    /* ── BTN NEW ─────────────────────────────────────── */
    .btn-new {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--ink);
        color: #fff;
        border: none;
        padding: 0.65rem 1.25rem;
        /* font-family: 'Syne', sans-serif; */
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: var(--radius);
        cursor: pointer;
        transition: opacity .2s;
    }

        .btn-new:hover {
            opacity: .75;
            color: #fff;
        }

        .btn-new i {
            font-size: 0.9rem;
        }

    /* ── SEARCH ──────────────────────────────────────── */
    .search-wrap {
        position: relative;
        margin-bottom: 2rem;
    }

        .search-wrap svg {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
        }

    .search-input {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.75rem;
        border: 1.5px solid var(--line);
        border-radius: var(--radius);
        background: #fff;
        /* font-family: 'DM Mono', monospace; */
        font-size: 0.85rem;
        color: var(--ink);
        outline: none;
        transition: border-color .2s;
    }

        .search-input:focus {
            border-color: var(--ink);
        }

        .search-input::placeholder {
            color: var(--muted);
        }

    /* ── RESOURCE GROUP ──────────────────────────────── */
    .resource-group {
        border: 1.5px solid var(--line);
        border-radius: var(--radius);
        background: #fff;
        margin-bottom: 1rem;
        overflow: hidden;
    }

    .group-toggle {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        background: none;
        border: none;
        cursor: pointer;
        text-align: left;
        /* font-family: 'Syne', sans-serif; */
        transition: background .15s;
    }

        .group-toggle:hover {
            background: var(--paper);
        }

    .group-toggle-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .group-label {
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--ink);
    }

    .group-count {
        /* font-family: 'DM Mono', monospace; */
        font-size: 0.7rem;
        color: var(--muted);
        background: var(--tag-bg);
        padding: 0.15rem 0.55rem;
        border-radius: 20px;
    }

    .toggle-chevron {
        width: 20px;
        height: 20px;
        color: var(--muted);
        transition: transform .25s ease;
        flex-shrink: 0;
    }

    .group-toggle.open .toggle-chevron {
        transform: rotate(180deg);
    }

    /* ── COLLAPSE BODY ───────────────────────────────── */
    .group-body {
        display: none;
        padding: 0 1.25rem 1.25rem;
        border-top: 1.5px solid var(--line);
    }

        .group-body.open {
            display: block;
        }

    /* ── PERMISSION TABLE ────────────────────────────── */
    .perm-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 0.75rem;
        font-size: 0.85rem;
    }

        .perm-table thead th {
            /* font-family: 'DM Mono', monospace; */
            font-size: 0.7rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--muted);
            padding: 0.5rem 0.75rem;
            text-align: left;
            border-bottom: 1px solid var(--line);
        }

        .perm-table tbody tr {
            border-bottom: 1px solid var(--line);
            transition: background .15s;
        }

            .perm-table tbody tr:last-child {
                border-bottom: none;
            }

            .perm-table tbody tr:hover {
                background: var(--paper);
            }

        .perm-table td {
            padding: 0.75rem 0.75rem;
            vertical-align: middle;
        }

    .perm-name {
        font-weight: 600;
        color: var(--ink);
    }

    .perm-desc {
        color: var(--muted);
        font-size: 0.78rem;
        max-width: 320px;
    }

    /* ── ACTION BADGE ────────────────────────────────── */
    .action-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        /* font-family: 'DM Mono', monospace; */
        font-size: 0.72rem;
        font-weight: 500;
        padding: 0.25rem 0.6rem;
        border-radius: 4px;
        letter-spacing: 0.04em;
    }

        .action-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

        .action-badge.create {
            background: #edfaf1;
            color: #1a6b35;
        }

            .action-badge.create::before {
                background: #2ecc71;
            }

        .action-badge.edit {
            background: #fef9ec;
            color: #7a5200;
        }

            .action-badge.edit::before {
                background: #f39c12;
            }

        .action-badge.delete {
            background: #fdf0ef;
            color: #8b1a1a;
        }

            .action-badge.delete::before {
                background: #e74c3c;
            }

        .action-badge.view {
            background: #eef4fd;
            color: #1a3f7a;
        }

            .action-badge.view::before {
                background: #3498db;
            }

    /* ── DELETE BTN ──────────────────────────────────── */
    .btn-del {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background: none;
        border: 1.5px solid var(--line);
        color: var(--muted);
        /*font-family: 'DM Mono', monospace;*/
        font-size: 0.72rem;
        padding: 0.3rem 0.7rem;
        border-radius: var(--radius);
        cursor: pointer;
        transition: all .2s;
    }

        .btn-del:hover {
            border-color: var(--danger);
            color: var(--danger);
            background: var(--danger-bg);
        }

    /* ── EMPTY STATE ─────────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--muted);
        display: none;
    }

        .empty-state h3 {
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: 0.05em;
        }

    /* ── MODAL ───────────────────────────────────────── */
    .modal-content {
        border: 1.5px solid var(--line);
        border-radius: var(--radius);
        box-shadow: 0 8px 30px rgba(0,0,0,0.1);
    }

    .modal-header {
        background: var(--ink) !important;
        border-bottom: none;
        padding: 1.25rem 1.5rem;
        border-radius: calc(var(--radius) - 1px) calc(var(--radius) - 1px) 0 0;
    }

    .modal-title {
        /* font-family: 'Syne', sans-serif; */
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .modal-body {
        padding: 1.5rem;
        font-size: 0.9rem;
        color: var(--ink);
    }

    .modal-footer {
        border-top: 1px solid var(--line);
        padding: 1rem 1.5rem;
    }

    .btn-modal-cancel {
        background: var(--tag-bg);
        border: none;
        color: var(--ink);
        /* font-family: 'Syne', sans-serif; */
        font-weight: 600;
        font-size: 0.8rem;
        padding: 0.55rem 1rem;
        border-radius: var(--radius);
        cursor: pointer;
        transition: opacity .2s;
    }

        .btn-modal-cancel:hover {
            opacity: .7;
        }

    .btn-modal-confirm {
        background: var(--danger);
        border: none;
        color: #fff;
        /* font-family: 'Syne', sans-serif; */
        font-weight: 700;
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        padding: 0.55rem 1rem;
        border-radius: var(--radius);
        cursor: pointer;
        transition: opacity .2s;
    }

        .btn-modal-confirm:hover {
            opacity: .8;
        }
</style>

<!-- ── PAGE HEADER ───────────────────────── -->
<div class="perm-header">
    <div class="perm-header-left">
        <h1>Permissions</h1>
        <p>Configure &amp; manage system permissions</p>
    </div>
    <a asp-action="Create" class="btn-component btn-primary">
        <i class="bi bi-plus-lg"></i> New Permission
    </a>
</div>

<!-- ── SEARCH ───────────────────────────── -->
<div class="search-wrap">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"
         viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
    </svg>
    <input id="searchInput" class="search-input"
           placeholder="Search by name, resource, or action…" autocomplete="off">
</div>

<!-- ── GROUPS ───────────────────────────── -->
<div id="groupsContainer">
    @foreach (var group in Model.GroupBy(p => p.Resource).OrderBy(g => g.Key))
    {
        var collapseId = $"grp_{group.Key.Replace(" ", "_")}";
        var count = group.Count();

        <div class="resource-group">
            <button class="group-toggle"
                    onclick="toggleGroup(this, '@collapseId')"
                    aria-expanded="false">
                <div class="group-toggle-left">
                    <span class="group-label">@group.Key</span>
                    <span class="group-count">@count</span>
                </div>
                <svg class="toggle-chevron" fill="none" stroke="currentColor" stroke-width="2.5"
                     viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <polyline points="6 9 12 15 18 9" />
                </svg>
            </button>

            <div id="@collapseId" class="group-body">
                <table class="perm-table">
                    <thead>
                        <tr>
                            <th>Permission</th>
                            <th>Description</th>
                            <th>Action</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in group)
                        {
                            <tr class="perm-row"
                                data-search="@p.PermissionName?.ToLower() @p.Resource?.ToLower() @p.Action?.ToLower()">
                                <td class="perm-name">@p.PermissionName</td>
                                <td class="perm-desc">@p.Description</td>
                                <td>
                                    <span class="action-badge @p.Action?.ToLower()">
                                        @p.Action
                                    </span>
                                </td>
                                <td>
                                    <button class="btn-del"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-id="@p.Id"
                                            data-name="@p.PermissionName">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<div class="empty-state" id="emptyState">
    <h3>No permissions found</h3>
</div>

<!-- ── DELETE MODAL ─────────────────────── -->
@Html.AntiForgeryToken()
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title text-white">Confirm Delete</h5>
                <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete <strong id="itemName"></strong>?
                This action cannot be undone.
            </div>
            <div class="modal-footer">
                <button class="btn-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                <button id="confirmDeleteBtn" class="btn-modal-confirm">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── TOGGLE ────────────────────────────────────────
        function toggleGroup(btn, id) {
            const body = document.getElementById(id);
            const isOpen = body.classList.contains('open');
            body.classList.toggle('open', !isOpen);
            btn.classList.toggle('open', !isOpen);
            btn.setAttribute('aria-expanded', String(!isOpen));
        }

        // ── SEARCH ────────────────────────────────────────
        const searchInput  = document.getElementById('searchInput');
        const groups       = document.querySelectorAll('.resource-group');
        const emptyState   = document.getElementById('emptyState');

        searchInput.addEventListener('input', () => {
            const term = searchInput.value.toLowerCase().trim();
            let totalMatches = 0;

            groups.forEach(group => {
                const rows = group.querySelectorAll('.perm-row');
                let groupMatches = 0;

                rows.forEach(row => {
                    const hit = !term || row.dataset.search.includes(term);
                    row.style.display = hit ? '' : 'none';
                    if (hit) groupMatches++;
                });

                group.style.display = groupMatches ? '' : 'none';

                // Auto-open group if searching
                const body   = group.querySelector('.group-body');
                const toggle = group.querySelector('.group-toggle');
                if (term && groupMatches) {
                    body.classList.add('open');
                    toggle.classList.add('open');
                }

                totalMatches += groupMatches;
            });

            emptyState.style.display = totalMatches === 0 ? 'block' : 'none';
        });

        // ── DELETE ────────────────────────────────────────
        let deleteId   = null;
        let deleteRow  = null;

        document.getElementById('deleteModal').addEventListener('show.bs.modal', e => {
            const btn = e.relatedTarget;
            deleteId  = btn.dataset.id;
            deleteRow = btn.closest('.perm-row');
            document.getElementById('itemName').textContent = btn.dataset.name;
        });

        document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
            fetch(`/Permission/Delete/${deleteId}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken':
                        document.querySelector("input[name='__RequestVerificationToken']").value
                }
            })
            .then(() => {
                deleteRow?.remove();
                bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
                showToast('Permission deleted successfully', 'success');
            })
            .catch(() => showToast('Error deleting permission', 'error'));
        });

        // ── TOASTS ───────────────────────────────────────
        @if (TempData["SuccessMessage"] != null)
        {
                <text>showToast('@TempData["SuccessMessage"]', 'success');</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
                <text>showToast('@TempData["ErrorMessage"]', 'error');</text>
        }
    </script>
}
