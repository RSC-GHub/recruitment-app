@model Recruitment.Application.DTOs.UserManagement.Permission.CreatePermissionDto

@{
    ViewData["Title"] = "Create Permission";
}

<h2>Create Permission</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="PermissionName"></label>
        <input asp-for="PermissionName" class="form-control" />
        <span asp-validation-for="PermissionName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Resource"></label>
        <input asp-for="Resource" class="form-control" />
        <span asp-validation-for="Resource" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Action"></label>
        <input asp-for="Action" class="form-control" />
        <span asp-validation-for="Action" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success mt-3">Save</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>
</form>
