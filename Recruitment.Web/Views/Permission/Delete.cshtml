@model Recruitment.Application.DTOs.UserManagement.Permission.PermissionDto

@{
    ViewData["Title"] = "Delete Permission";
}

<h2>Delete Permission</h2>

<h4>Are you sure you want to delete this permission?</h4>

<div>
    <p><strong>Name:</strong> @Model.PermissionName</p>
    <p><strong>Resource:</strong> @Model.Resource</p>
    <p><strong>Action:</strong> @Model.Action</p>
    <p><strong>Description:</strong> @Model.Description</p>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
