@model IEnumerable<Recruitment.Web.ViewModels.UserManagement.RoleListViewModel>

@{
    ViewData["Title"] = "Roles";
}

<h2>Roles</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Role</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Role Name</th>
            <th>Description</th>
            <th>Active</th>
            <th>Permissions</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model)
        {
            <tr>
                <td>@role.RoleName</td>
                <td>@role.Description</td>
                <td>@(role.IsActive ? "Yes" : "No")</td>
                <td>
                    @if (role.Permissions != null && role.Permissions.Any())
                    {
                        <ul>
                            @foreach (var p in role.Permissions)
                            {
                                <li>@p.Resource - @p.Action</li>
                            }
                        </ul>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@role.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@role.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
