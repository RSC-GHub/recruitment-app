@model Recruitment.Web.ViewModels.UserManagement.RoleEditViewModel

@{
    ViewData["Title"] = "Edit Role";
}

<div class="card-component">
    <div class="card-header">
        <h2 class="card-title"><i class="bi bi-pencil-square me-2"></i>Edit Role</h2>
    </div>
    <div class="card-content">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="RoleName" class="form-field-label"></label><span class="text-danger"> *</span>
                <input asp-for="RoleName" class="form-field-input" />
                <span asp-validation-for="RoleName" class="form-field-error"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-field-label"></label>
                <input asp-for="Description" class="form-field-input" />
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <h5 class="mt-4 mb-3"><i class="bi bi-key me-2"></i>Permissions</h5>

            @foreach (var group in Model.AllPermissions
                .OrderBy(p => p.Resource)
                .GroupBy(p => p.Resource))
            {
                var resourceId = group.Key.Replace(" ", "_"); // ID-safe key
                <div class="card-component mb-3">
                    <div class="card-header flex-between">
                        <strong>@group.Key</strong>
                        <div>
                            <input type="checkbox" id="selectAll_@resourceId" class="form-check-input me-1"
                                   onclick="toggleGroup('@resourceId', this)" />
                            <label for="selectAll_@resourceId" class="form-check-label">Select All</label>
                        </div>
                    </div>
                    <div class="card-content" id="group_@resourceId">
                        <div class="row">
                            @foreach (var p in group.OrderBy(p => p.Action))
                            {
                                <div class="col-md-3 mb-2">
                                    <input type="checkbox" name="SelectedPermissionIds" value="@p.Id"
                                           id="perm_@p.Id" class="perm_@resourceId form-check-input"
                                           @(p.IsSelected ? "checked" : "") />
                                    <label for="perm_@p.Id" class="form-check-label">@p.Action</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <button type="submit" class="button-primary mt-3"><i class="bi bi-check-circle me-1"></i>Update</button>
            <a asp-action="Index" class="button-secondary mt-3 ms-2"><i class="bi bi-x-circle me-1"></i>Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function toggleGroup(resourceId, masterCheckbox) {
            const checkboxes = document.querySelectorAll(`.perm_${resourceId}`);
            checkboxes.forEach(cb => cb.checked = masterCheckbox.checked);
        }
    </script>
    <script>
        $(document).ready(function () {

            var $roleName = $('input[name="RoleName"]');
            var $validationMsg = $('span[data-valmsg-for="RoleName"]');

            function validateRoleName() {
                if (!$roleName.val().trim()) {
                    $validationMsg.text('Role Name is required').show();
                    $roleName.addClass('is-invalid').removeClass('is-valid');
                    return false;
                } else {
                    $validationMsg.text('').hide();
                    $roleName.addClass('is-valid').removeClass('is-invalid');
                    return true;
                }
            }

            $roleName.on('input blur', function () {
                validateRoleName();
            });

            $('form').on('submit', function (e) {
                if (!validateRoleName()) {
                    e.preventDefault();
                    e.stopPropagation();
                }
            });

        });

        function toggleGroup(resourceId, masterCheckbox) {
            const checkboxes = document.querySelectorAll(`.perm_${resourceId}`);
            checkboxes.forEach(cb => cb.checked = masterCheckbox.checked);
        }
    </script>
}
