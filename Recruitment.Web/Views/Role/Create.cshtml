@model Recruitment.Web.ViewModels.UserManagement.RoleCreateViewModel

@{
    ViewData["Title"] = "Create Role";
}

<h2>Create Role</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="RoleName"></label>
        <input asp-for="RoleName" class="form-control" />
        <span asp-validation-for="RoleName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
        <input asp-for="Description" class="form-control" />
    </div>

    <div class="form-group form-check">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>

    <h5>Permissions</h5>

    @foreach (var group in Model.AllPermissions
        .OrderBy(p => p.Resource)
        .GroupBy(p => p.Resource))
    {
        var resourceId = group.Key.Replace(" ", "_"); // ID-safe key
                                                      <div class="card mb-3">
                                                          <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                                              <strong>@group.Key</strong>
                                                              <div>
                                                                  <input type="checkbox" id="selectAll_@resourceId" class="form-check-input me-1"
                                                                         onclick="toggleGroup('@resourceId', this)" />
                                                                  <label for="selectAll_@resourceId" class="form-check-label">Select All</label>
                                                              </div>
                                                          </div>
                                                          <div class="card-body" id="group_@resourceId">
                                                              <div class="row">
                    @foreach (var p in group.OrderBy(p => p.Action))
                    {
                        <div class="col-md-3 mb-2">
                            <input type="checkbox" name="SelectedPermissionIds" value="@p.Id" id="perm_@p.Id" class="perm_@resourceId" />
                            <label for="perm_@p.Id">@p.Action</label>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary mt-3">Save</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Cancel</a>
</form>

@section Scripts {
    <script>
        function toggleGroup(resourceId, masterCheckbox) {
            const checkboxes = document.querySelectorAll(`.perm_${resourceId}`);
            checkboxes.forEach(cb => cb.checked = masterCheckbox.checked);
        }
    </script>
}
