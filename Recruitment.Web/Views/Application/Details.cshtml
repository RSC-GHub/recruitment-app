@using Recruitment.Domain.Enums
@model Recruitment.Web.ViewModels.RecruitmentProcess.Application.ApplicationDetailVM
@using Recruitment.Domain.Workflows

@{
    ViewData["Title"] = "Application Details";
}

<div class="card-component">
    <div class="card-header flex-between">
        <h2 class="card-title"><i class="bi bi-file-earmark-person me-2"></i>Application Details</h2>
        <div class="d-flex gap-2">
            <!-- Action Button -->
            <button class="btn-component btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#reviewModal"
                    data-application-id="@Model.Id"
                    data-note='@Json.Serialize(Model.Note ?? "")'>
                <i class="bi bi-check-circle me-2"></i>
                Review Application
            </button>

            @* Show Schedule Interview only if allowed *@
            @if (ViewBag.CanAddInterview)
            {
                <button class="btn-component btn-outline" data-bs-toggle="modal" data-bs-target="#addInterviewModal">
                    <i class="bi bi-calendar-plus me-2"></i>Schedule Interview
                </button>
            }
        </div>
    </div>
    <div class="card-content">

        <div class="row g-3">
            <!-- Applicant Info -->
            <div class="col-md-6">
                <div class="card-component mb-3">
                    <div class="card-header">
                        <h4 class="card-title mb-0">
                            <i class="bi bi-person-circle me-2"></i>Applicant Information
                        </h4>
                    </div>
                    <div class="card-content">
                        <div class="space-y-3">
                            <div>
                                <span class="text-muted small">Name</span>
                                <p class="mb-0 fw-semibold">@Model.ApplicantName</p>
                            </div>
                            <div>
                                <span class="text-muted small">Email</span>
                                <p class="mb-0 fw-semibold">@Model.ApplicantEmail</p>
                            </div>
                            <div>
                                <span class="text-muted small">Phone</span>
                                <p class="mb-0 fw-semibold">@Model.PhoneNumber</p>
                            </div>
                            <div>
                                <span class="text-muted small">Current Job</span>
                                <p class="mb-0 fw-semibold">@(Model.CurrentJob ?? "-")</p>
                            </div>
                            <div>
                                <span class="text-muted small">Current Employer</span>
                                <p class="mb-0 fw-semibold">@(Model.CurrentEmployer ?? "-")</p>
                            </div>
                            <div>
                                <span class="text-muted small">CV</span><br />
                                @if (!string.IsNullOrWhiteSpace(Model.CVFilePath))
                                {
                                    <a class="mb-0 btn-component btn-primary w-50" asp-controller="Applicant" asp-action="DownloadCV" asp-route-filePath="@Model.CVFilePath">
                                        <i class="bi bi-download me-2"></i>Download CV
                                    </a>
                                }
                                else
                                {
                                    <div class="alert-component alert-destructive">
                                        <i class="bi bi-exclamation-triangle-fill alert-icon"></i>
                                        <div>
                                            <div class="alert-description">No CV uploaded.</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Vacancy Info -->
            <div class="col-md-6">
                <div class="card-component mb-3">
                    <div class="card-header">
                        <h4 class="card-title mb-0">
                            <i class="bi bi-briefcase-fill me-2"></i>Vacancy Information
                        </h4>
                    </div>
                    <div class="card-content">
                        <div class="space-y-3">
                            <div>
                                <span class="text-muted small">Title</span>
                                <p class="mb-0 fw-semibold">@Model.VacancyTitle</p>
                            </div>
                            <div>
                                <span class="text-muted small">Description</span>
                                <p class="mb-0 fw-semibold">@Html.Raw((Model.VacancyDescription ?? "-"))</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Application Info -->
        <div class="card-component mb-3">
            <div class="card-header">
                <h4 class="card-title mb-0">
                    <i class="bi bi-clipboard-check me-2"></i>Application Details
                </h4>
            </div>
            <div class="card-content">
                <div class="row">
                    <div class="col-md-6">
                        <div class="space-y-3">
                            <div>
                                <span class="text-muted small">Status</span>
                                <p class="mb-0">
                                    @{
                                        var statusStr = Model.ApplicationStatus.ToString();
                                        var statusClass = statusStr == "Accepted" ? "badge-success" :
                                        statusStr == "Rejected" ? "badge-destructive" :
                                        statusStr == "Under Review" ? "badge-warning" :
                                        "badge-default";
                                    }
                                    <span class="badge-component @statusClass">@Model.ApplicationStatus</span>
                                </p>
                            </div>
                            <div>
                                <span class="text-muted small">Applied On</span>
                                <p class="mb-0 fw-semibold">@Model.ApplicationDate.ToString("MMM dd, yyyy HH:mm")</p>
                            </div>

                            @* Expected First Date *@
                            @if (Model.ExpectedFirstDate.HasValue)
                            {
                                <div>
                                    <span class="text-muted small">Expected Start Date</span>
                                    <p class="mb-0 fw-semibold">@Model.ExpectedFirstDate.Value.ToString("MMM dd, yyyy")</p>
                                </div>
                            }

                            @* Actual First Date *@
                            @if (Model.ActualFirstDate.HasValue)
                            {
                                <div class="d-flex align-items-center">
                                    <div class="me-2">
                                        <span class="text-muted small">Actual Start Date</span>
                                        <p class="mb-0 fw-semibold">@Model.ActualFirstDate.Value.ToString("MMM dd, yyyy")</p>
                                    </div>
                                    @if (Model.ApplicationStatus != ApplicationStatus.Rejected && Model.ApplicationStatus != ApplicationStatus.Hired)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary p-1" title="Edit Actual Start Date"
                                                data-bs-toggle="modal" data-bs-target="#editActualDateModal">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                    }
                                </div>
                            }

                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="space-y-3">
                            <div>
                                <span class="text-muted small">Reviewed By</span>
                                <p class="mb-0 fw-semibold">@(Model.ReviewedByUserName ?? "-")</p>
                            </div>
                            <div>
                                <span class="text-muted small">Review Date</span>
                                <p class="mb-0 fw-semibold">@(Model.ReviewDate?.ToString("MMM dd, yyyy HH:mm") ?? "-")</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* Note *@
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="mt-3">
                        <span class="text-muted small">Note</span>
                        <p class="mb-0 fw-semibold">@Model.Note</p>
                    </div>
                }

                @* Rejection Reasons if Rejected *@
                @if (Model.ApplicationStatus == ApplicationStatus.Rejected
                                && Model.SelectedRejectionReasons != null
                                && Model.SelectedRejectionReasons.Any())
                {
                    <div class="mt-3">
                        <span class="text-muted small">Rejection Reasons</span>

                        <div class="d-flex gap-2 flex-wrap mt-1">
                            @foreach (var reason in Model.SelectedRejectionReasons)
                            {
                                <span class="badge-component badge-secondary">
                                    @reason
                                </span>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>

</div>

        <!-- Review Modal -->
        <div class="modal fade" id="reviewModal" tabindex="-1"
             aria-labelledby="reviewModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">

                    <form id="reviewForm">
                        @Html.AntiForgeryToken()

                        <div class="modal-header">
                            <h5 class="modal-title" id="reviewModalLabel">
                                <i class="bi bi-check-circle me-2"></i>
                                Review Application
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body">

                            <!-- IMPORTANT -->
                            <input type="hidden" id="reviewApplicationId" name="ApplicationId" />

                            <!-- Decision -->
                            <div class="form-field">
                                <label class="form-label">
                                    Decision <span class="text-danger">*</span>
                                </label>

                                <select id="reviewApplicationStatus"
                                        name="ApplicationStatus"
                                        class="form-select"
                                        required>
                                    <option value="">-- Select Decision --</option>
                                    @foreach (var status in ApplicationWorkflow.GetAllowedTransitions(Model.ApplicationStatus))
                                    {
                                        <option value="@((int)status)">@status</option>
                                    }
                                </select>
                            </div>

                            <!-- Rejection Reasons -->
                            <div class="form-field d-none" id="rejectionReasonsField">
                                <label class="form-label">Rejection Reasons <span class="text-danger">*</span></label>
                                <select id="RejectionReasonIds" name="RejectionReasonIds" class="form-select" multiple>
                                    @foreach (var reason in Model.AllRejectionReasons)
                                    {
                                        <option value="@reason.Id">@reason.Reason</option>
                                    }
                                </select>
                            </div>

                            <!-- Note -->
                            <div class="form-field">
                                <label class="form-label">Note</label>
                                <textarea id="reviewNote"
                                          name="Note"
                                          class="form-input"
                                          rows="3"
                                          maxlength="1000"></textarea>
                            </div>

                            <!-- Expected Start Date -->
                            <div class="form-field d-none" id="expectedDateField">
                                <label class="form-label">Expected Start Date <span class="text-danger">*</span></label>
                                <input type="date"
                                       id="ExpectedFirstDate"
                                       name="ExpectedFirstDate"
                                       class="form-input"
                                       min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            </div>

                            <!-- Actual Start Date -->
                            <div class="form-field d-none" id="actualDateField">
                                <label class="form-label">Actual Start Date <span class="text-danger">*</span></label>
                                <input type="date"
                                       id="ActualFirstDate"
                                       name="ActualFirstDate"
                                       class="form-input"
                                       min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            </div>

                            <!-- Messages -->
                            <div id="reviewError" class="text-danger mt-2"></div>
                            <div id="reviewSuccess" class="text-success mt-2"></div>
                        </div>

                        <div class="modal-footer">
                            <button type="button"
                                    class="btn-component btn-secondary"
                                    data-bs-dismiss="modal">
                                Cancel
                            </button>

                            <button type="submit"
                                    class="btn-component btn-primary">
                                <i class="bi bi-check-circle me-2"></i>
                                Submit Review
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>

        <!-- Add Interview Modal -->
        <div class="modal fade" id="addInterviewModal" tabindex="-1" aria-labelledby="addInterviewModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form id="addInterviewForm">
                        @Html.AntiForgeryToken()

                        <div class="modal-header">
                            <h5 class="modal-title" id="addInterviewModalLabel">
                                <i class="bi bi-calendar-plus me-2"></i>
                                Schedule Interview
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        <div class="modal-body">
                            <input type="hidden" id="ApplicationId" name="ApplicationId" value="@Model.Id" />

                            <div class="form-field">
                                <label for="InterviewerId" class="form-label">
                                    Interviewer <span class="text-danger">*</span>
                                </label>
                                <select id="InterviewerId" name="InterviewerId" class="form-select select2" required>
                                    <option value="">-- Select Interviewer --</option>
                                    @foreach (var interviewer in Model.Interviewers)
                                    {
                                        <option value="@interviewer.Value">@interviewer.Text</option>
                                    }
                                </select>
                            </div>

                            <div class="form-field">
                                <label for="ScheduledDate" class="form-label">
                                    Scheduled Date <span class="text-danger">*</span>
                                </label>
                                <input type="datetime-local" id="ScheduledDate" name="ScheduledDate"
                                       class="form-input" required min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                            </div>

                            <div class="form-field">
                                <label for="InterviewType" class="form-label">Interview Type</label>
                                <select id="InterviewType" name="InterviewType" class="form-select">
                                    <option value="FaceToFace">Face To Face</option>
                                    <option value="OnlineZoom">Online Zoom</option>
                                    <option value="Teams">Teams</option>
                                </select>
                            </div>
                            <div class="form-field">
                                <label for="InterviewCategory" class="form-label">Interview Category</label>
                                <select id="InterviewCategory" name="InterviewCategory" class="form-select">
                                    <option value="Technical">Technical</option>
                                    <option value="HR">HR</option>
                                    <option value="Managerial">Managerial</option>
                                </select>
                            </div>

                            <div class="form-field">
                                <label for="DurationMinutes" class="form-label">Duration (minutes)</label>
                                <input type="number" id="DurationMinutes" name="DurationMinutes" class="form-input" value="60" min="1" />
                            </div>

                            <div class="form-field">
                                <label for="Note" class="form-label">Note</label>
                                <input type="text"
                                       id="InterViewNote"
                                       name="InterViewNote"
                                       class="form-input"
                                       placeholder="Optional notes" />
                            </div>

                            <div id="addInterviewError" class="text-danger"></div>
                            <div id="addInterviewSuccess" class="text-success"></div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">
                                Cancel
                            </button>
                            <button type="submit" class="btn-component btn-primary">
                                <i class="bi bi-check-circle me-2"></i>
                                Add Interview
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>

    <!-- Edit Actual Start Date Modal -->
    <div class="modal fade" id="editActualDateModal" tabindex="-1" aria-labelledby="editActualDateModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="editActualDateForm">
                    @Html.AntiForgeryToken()

                    <div class="modal-header">
                        <h5 class="modal-title" id="editActualDateModalLabel">
                            <i class="bi bi-pencil-fill me-2"></i>Edit Actual Start Date
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" id="editApplicationId" name="ApplicationId" value="@Model.Id" />

                        <div class="form-field">
                            <label for="editActualStartDate" class="form-label">Actual Start Date <span class="text-danger">*</span></label>
                            <input type="date"
                                   id="editActualStartDate"
                                   name="ActualFirstDate"
                                   class="form-control"
                                   required
                                   value="@(Model.ActualFirstDate?.ToString("yyyy-MM-dd"))"
                                   min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>


                        <div id="editActualDateError" class="text-danger mt-2"></div>
                        <div id="editActualDateSuccess" class="text-success mt-2"></div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Save
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>



@section Scripts {
        <script>

                    /* =========================
           Review Modal Logic
        ========================= */
        var reviewModal = document.getElementById('reviewModal');

        if (reviewModal) {
            reviewModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;

                var applicationId = button.getAttribute('data-application-id');
                var noteJson = button.getAttribute('data-note');

                var note = noteJson ? JSON.parse(noteJson) : '';

                document.getElementById('reviewApplicationId').value = applicationId;
                document.getElementById('reviewNote').value = note || '';
                document.getElementById('reviewApplicationStatus').value = '';

                document.getElementById('reviewError').innerText = '';
                document.getElementById('reviewSuccess').innerText = '';

                // Hide all dynamic fields initially
                document.getElementById('expectedDateField').classList.add('d-none');
                document.getElementById('ActualFirstDate').value = '';
                document.getElementById('ExpectedFirstDate').value = '';
                document.getElementById('actualDateField').classList.add('d-none');

                // Rejection reasons
                var rejectionField = document.getElementById('rejectionReasonsField');
                rejectionField.classList.add('d-none');
                var rejectionSelect = $('#RejectionReasonIds');

                rejectionSelect.val(null).trigger('change');
                rejectionSelect.prop('required', false);

                // Initialize Select2 for rejection reasons
                if (rejectionSelect.hasClass("select2-hidden-accessible")) {
                    rejectionSelect.select2('destroy');
                }
                rejectionSelect.select2({
                    placeholder: "Select rejection reasons",
                    dropdownParent: $('#reviewModal'),
                    width: '100%',
                    allowClear: true
                });
            });
        }

        // Show/hide dynamic fields based on selected status
        var reviewStatusSelect = document.getElementById('reviewApplicationStatus');
        if (reviewStatusSelect) {
            reviewStatusSelect.addEventListener('change', function () {
                var selectedValue = parseInt(this.value);

                var expectedField = document.getElementById('expectedDateField');
                var actualField = document.getElementById('actualDateField');
                var expectedInput = document.getElementById('ExpectedFirstDate');
                var actualInput = document.getElementById('ActualFirstDate');
                var rejectionField = document.getElementById('rejectionReasonsField');
                var rejectionSelect = $('#RejectionReasonIds');

                // Hide all by default
                expectedField.classList.add('d-none');
                expectedInput.required = false;
                actualField.classList.add('d-none');
                actualInput.required = false;
                rejectionField.classList.add('d-none');
                rejectionSelect.prop('required', false);

                if (selectedValue === @((int)ApplicationStatus.AcceptedOffer)) {
                    expectedField.classList.remove('d-none');
                    expectedInput.required = true;
                } else if (selectedValue === @((int)ApplicationStatus.SignedContract)) {
                    actualField.classList.remove('d-none');
                    actualInput.required = true;
                } else if (selectedValue === @((int)ApplicationStatus.Rejected)) {
                    rejectionField.classList.remove('d-none');
                    rejectionSelect.prop('required', true);
                }
            });
        }


            // Submit Review Form
            var reviewForm = document.getElementById('reviewForm');
            if (reviewForm) {
                reviewForm.addEventListener('submit', function (e) {
                    e.preventDefault();

                    var data = {
                        ApplicationId: parseInt(document.getElementById('reviewApplicationId').value),
                        ApplicationStatus: parseInt(document.getElementById('reviewApplicationStatus').value),
                        Note: document.getElementById('reviewNote').value,
                        ExpectedFirstDate: document.getElementById('ExpectedFirstDate').value || null,
                        ActualFirstDate: document.getElementById('ActualFirstDate').value || null,
                        RejectionReasonIds: Array.from(document.getElementById('RejectionReasonIds').selectedOptions)
                                                  .map(o => parseInt(o.value))
                    };

                    fetch('@Url.Action("Review", "Application")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken':
                                document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(data)
                    })
                    .then(r => r.json())
                    .then(result => {
                        if (result.success) {
                            document.getElementById('reviewSuccess').innerText = result.message;
                            document.getElementById('reviewError').innerText = '';
                            setTimeout(() => location.reload(), 800);
                        } else {
                            document.getElementById('reviewError').innerText = result.message;
                            document.getElementById('reviewSuccess').innerText = '';
                        }
                    })
                    .catch(() => {
                        document.getElementById('reviewError').innerText = 'An error occurred';
                    });
                });
            }

            /* =========================
               Add Interview Logic
            ========================= */
            var addInterviewForm = document.getElementById('addInterviewForm');
            if (addInterviewForm) {
                addInterviewForm.addEventListener('submit', function(e) {
                    e.preventDefault();

                    const formData = new FormData(addInterviewForm);

                    fetch('@Url.Action("CreateInterview", "Interview")', {
                        method: 'POST',
                        body: formData
                    })
                    .then(r => r.json())
                    .then(result => {
                        if (result.success) {
                            document.getElementById('addInterviewSuccess').innerText = result.message;
                            document.getElementById('addInterviewError').innerText = '';
                            setTimeout(() => location.reload(), 800);
                        } else {
                            document.getElementById('addInterviewError').innerText = result.message;
                            document.getElementById('addInterviewSuccess').innerText = '';
                        }
                    })
                    .catch(() => {
                        document.getElementById('addInterviewError').innerText = 'An error occurred';
                    });
                });
            }

            // Initialize Select2 for modal
            $('#addInterviewModal').on('shown.bs.modal', function () {
                var $interviewer = $('#InterviewerId');

                if ($interviewer.hasClass('select2-hidden-accessible')) {
                    $interviewer.select2('destroy');
                }

                $interviewer.select2({
                    placeholder: "Select an interviewer",
                    dropdownParent: $('#addInterviewModal'),
                    width: '100%'
                });
            });

            /* =========================
               Edit Actual Start Date Logic
            ========================= */
            var editActualDateForm = document.getElementById('editActualDateForm');
            if(editActualDateForm){
                editActualDateForm.addEventListener('submit', function(e){
                    e.preventDefault();

                    var data = {
                        ApplicationId: parseInt(document.getElementById('editApplicationId').value),
                        ActualFirstDate: document.getElementById('editActualStartDate').value
                    };

                    fetch('@Url.Action("UpdateActualStartDate", "Application")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(data)
                    })
                    .then(r => r.json())
                    .then(result => {
                        if(result.success){
                            document.getElementById('editActualDateSuccess').innerText = result.message;
                            document.getElementById('editActualDateError').innerText = '';
                            setTimeout(() => location.reload(), 800);
                        } else {
                            document.getElementById('editActualDateError').innerText = result.message;
                            document.getElementById('editActualDateSuccess').innerText = '';
                        }
                    })
                    .catch(() => {
                        document.getElementById('editActualDateError').innerText = 'An error occurred';
                    });
                });
            }

        </script>
}
