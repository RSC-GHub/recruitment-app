@using Recruitment.Domain.Enums
@model Recruitment.Web.ViewModels.RecruitmentProcess.Application.ApplicationDetailVM
@using Recruitment.Domain.Workflows

@{
    ViewData["Title"] = "Application Details";
}

<div class="container py-4">
    <h2 class="mb-4">Application Details</h2>

    <!-- Action Button -->
    <a href="#" class="btn btn-warning mb-4" data-bs-toggle="modal" data-bs-target="#reviewModal">
        Action
    </a>

    @* Show Schedule Interview only if allowed *@
    @if (ViewBag.CanAddInterview)
    {
        <a href="#" class="btn btn-primary mb-4 ms-2" data-bs-toggle="modal" data-bs-target="#addInterviewModal">
            Schedule Interview
        </a>
    }

    <div class="row g-3">
        <!-- Applicant Info -->
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-primary text-white">Applicant Information</div>
                <div class="card-body">
                    <p><strong>Name:</strong> @Model.ApplicantName</p>
                    <p><strong>Email:</strong> @Model.ApplicantEmail</p>
                    <p><strong>Phone:</strong> @Model.PhoneNumber</p>
                    <p><strong>Current Job:</strong> @(Model.CurrentJob ?? "-")</p>
                    <p><strong>Current Employer:</strong> @(Model.CurrentEmployer ?? "-")</p>
                </div>
            </div>
        </div>

        <!-- Vacancy Info -->
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-success text-white">Vacancy Information</div>
                <div class="card-body">
                    <p><strong>Title:</strong> @Model.VacancyTitle</p>
                    <p><strong>Description:</strong> @(Model.VacancyDescription ?? "-")</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Application Info -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-info text-white">Application Details</div>
        <div class="card-body">
            <p><strong>Status:</strong> @Model.ApplicationStatus</p>
            <p><strong>Applied On:</strong> @Model.ApplicationDate.ToString("yyyy-MM-dd HH:mm")</p>
            <p><strong>Reviewed By:</strong> @(Model.ReviewedByUserName ?? "-")</p>
            <p><strong>Review Date:</strong> @(Model.ReviewDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</p>
            <p><strong>Note:</strong> @(Model.Note ?? "-")</p>
        </div>
    </div>
</div>

<!-- Review Modal -->
<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="reviewForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="reviewModalLabel">Review Application</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" name="ApplicationId" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label">Decision</label>
                        <select name="ApplicationStatus" class="form-select" required>
                            <option value="">-- Select Decision --</option>

                            @* Generate options dynamically based on workflow *@
                            @{
                                @foreach (var status in ApplicationWorkflow.GetAllowedTransitions(Model.ApplicationStatus))
                                {
                                    <option value="@((int)status)">@status</option>
                                }

                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Note</label>
                        <textarea name="Note" class="form-control" rows="3" maxlength="1000"></textarea>
                    </div>

                    <div id="reviewError" class="text-danger"></div>
                    <div id="reviewSuccess" class="text-success"></div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Submit Review</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Interview Modal -->
<div class="modal fade" id="addInterviewModal" tabindex="-1" aria-labelledby="addInterviewModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="addInterviewForm">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title" id="addInterviewModalLabel">Schedule Interview</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="ApplicationId" name="ApplicationId" value="@Model.Id" />

                    <div class="mb-3">
                        <label for="Interviewer" class="form-label">Interviewer</label><span class="text-danger">*</span>
                        <input type="text" id="Interviewer" name="Interviewer" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="ScheduledDate" class="form-label">Scheduled Date</label><span class="text-danger">*</span>
                        <input type="datetime-local" id="ScheduledDate" name="ScheduledDate" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="InterviewType" class="form-label">Interview Type</label>
                        <select id="InterviewType" name="InterviewType" class="form-select">
                            <option value="FaceToFace">Face To Face</option>
                            <option value="OnlineZoom">Online Zoom</option>
                            <option value="Teams">Teams</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="InterviewCategory" class="form-label">Interview Type</label>
                        <select id="InterviewCategory" name="InterviewCategory" class="form-select">
                            <option value="Technical">Technical</option>
                            <option value="HR">HR</option>
                            <option value="Managerial">Managerial</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="DurationMinutes" class="form-label">Duration (minutes)</label>
                        <input type="number" id="DurationMinutes" name="DurationMinutes" class="form-control" value="60" min="1" />
                    </div>

                    <div class="mb-3">
                        <label for="Note" class="form-label">Note</label>
                        <input type="text" id="Note" name="Note" class="form-control" />
                    </div>

                    <div id="addInterviewError" class="text-danger"></div>
                    <div id="addInterviewSuccess" class="text-success"></div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Add Interview</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Review Form
        document.getElementById('reviewForm').addEventListener('submit', function (e) {
            e.preventDefault();
            var form = e.target;

            var data = {
                ApplicationId: parseInt(form.ApplicationId.value),
                ApplicationStatus: parseInt(form.ApplicationStatus.value),
                Note: form.Note.value
            };

            fetch('@Url.Action("Review", "Application")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(data)
            })
            .then(r => r.json())
            .then(result => {
                if (result.success) {
                    document.getElementById('reviewSuccess').innerText = result.message;
                    document.getElementById('reviewError').innerText = '';
                    setTimeout(() => location.reload(), 1000);
                } else {
                    document.getElementById('reviewError').innerText = result.message;
                    document.getElementById('reviewSuccess').innerText = '';
                }
            })
            .catch(err => {
                document.getElementById('reviewError').innerText = 'An error occurred';
            });
        });

        // Add Interview Form
        document.getElementById('addInterviewForm').addEventListener('submit', function(e) {
            e.preventDefault();
            var form = e.target;

            if (!form.Interviewer.value) {
                document.getElementById('addInterviewError').innerText = 'Please enter interviewer';
                return;
            }

            if (!form.ScheduledDate.value) {
                document.getElementById('addInterviewError').innerText = 'Please select scheduled date';
                return;
            }

            if (parseInt(form.DurationMinutes.value) < 1) {
                form.DurationMinutes.value = 60;
            }

            var formData = new FormData(form);

            fetch('@Url.Action("CreateInterview", "Interview")', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    return response.text().then(text => { throw new Error(`Server returned ${response.status}: ${text}`); });
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    document.getElementById('addInterviewSuccess').innerText = data.message;
                    document.getElementById('addInterviewError').innerText = '';
                    setTimeout(() => location.reload(), 1000);
                } else {
                    document.getElementById('addInterviewError').innerText = data.message;
                    document.getElementById('addInterviewSuccess').innerText = '';
                }
            })
            .catch(err => {
                console.error(err);
                document.getElementById('addInterviewError').innerText = err.message;
            });
        });
    </script>
}
