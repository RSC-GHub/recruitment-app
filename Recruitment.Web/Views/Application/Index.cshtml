@model Recruitment.Web.ViewModels.RecruitmentProcess.Application.ApplicationIndexVM

@{
    ViewData["Title"] = "Applications";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .table-scroll-wrapper {
        position: relative;
        overflow-x: auto;
        margin-bottom: 1rem;
    }

    .table-fixed-columns {
        border-collapse: collapse;
        min-width: 1200px;
        table-layout: auto;
    }

        .table-fixed-columns th,
        .table-fixed-columns td {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .table-fixed-columns thead th {
            position: sticky;
            top: 0;
            background-color: #212529;
            color: #fff;
            z-index: 10;
        }

        .table-fixed-columns th:nth-child(1),
        .table-fixed-columns td:nth-child(1) {
            position: sticky;
            left: 0;
            width: 50px;
            background-color: #212529;
            z-index: 20;
        }

        .table-fixed-columns th:nth-child(2),
        .table-fixed-columns td:nth-child(2) {
            position: sticky;
            left: 50px; 
            width: 316px;
            background-color: #212529;
            z-index: 20;
        }

        .table-fixed-columns th:nth-child(3),
        .table-fixed-columns td:nth-child(3) {
            position: sticky;
            left: 366px; 
            width: 200px;
            background-color: #212529;
            z-index: 20;
        }

        .table-fixed-columns tbody tr:nth-of-type(odd) td {
            background-color: #f8f9fa;
        }

        .table-fixed-columns tbody tr:nth-of-type(even) td {
            background-color: #fff;
        }

        .table-fixed-columns tbody tr:hover td {
            background-color: rgba(0,0,0,.075);
        }
</style>

<div class="container-fluid mt-4">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-clipboard2-check-fill me-2"></i>Applications
        </h2>
    </div>

    <!-- SEARCH FORM -->
    <form method="get" class="row mb-4">

        <div class="col-md-4">
            <input type="text" name="search" value="@Model.Search"
                   class="form-control"
                   placeholder="Search by name, email, phone..." />
        </div>

        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">-- All Statuses --</option>
                @foreach (var item in Model.StatusList)
                {
                    <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">
                        @item.Text
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-search"></i> Filter
            </button>
        </div>

    </form>


    <!-- APPLICATIONS TABLE -->
    <div class="table-scroll-wrapper">
        <table class="table table-striped table-hover align-middle table-fixed-columns">
            <thead class="table-dark">
                <tr>
                    <th style="min-width: 50px;">#</th>
                    <th style="min-width: 316px;">Applicant</th>
                    <th style="min-width: 200px;">Email</th>
                    <th style="min-width: 120px;">Phone</th>
                    <th style="min-width: 180px;">Vacancy</th>
                    <th style="min-width: 100px;">Status</th>
                    <th style="min-width: 110px;">Applied On</th>
                    <th style="min-width: 130px;">Reviewer</th>
                    <th style="min-width: 110px;">Review Date</th>
                    <th style="min-width: 150px;">Note</th>
                    <th style="min-width: 80px;" class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Applications.Any())
                {
                    foreach (var app in Model.Applications)
                    {
                        <tr style="cursor:pointer;"
                            onclick="window.location='@Url.Action("Details", new { id = app.Id })'">

                            <td>@app.Id</td>
                            <td>@app.ApplicantName</td>
                            <td>@app.ApplicantEmail</td>
                            <td>@app.PhoneNumber</td>
                            <td>@app.VacancyTitle</td>
                            <td>
                                <span class="badge bg-info text-dark">
                                    @app.ApplicationStatus
                                </span>
                            </td>
                            <td>@app.ApplicationDate.ToString("yyyy-MM-dd")</td>
                            <td>@(app.ReviewedByUserName ?? "—")</td>
                            <td>@(app.ReviewDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                            <td>@(string.IsNullOrWhiteSpace(app.Note) ? "—" : app.Note)</td>

                            <td class="text-center" onclick="event.stopPropagation();">
                                <button class="btn btn-sm btn-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal-@app.Id">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>

                        <!-- DELETE MODAL -->
                        <div class="modal fade" id="deleteModal-@app.Id" tabindex="-1"
                             aria-labelledby="deleteModalLabel-@app.Id" aria-hidden="true">

                            <div class="modal-dialog">
                                <div class="modal-content">

                                    <form asp-action="DeleteConfirmed" method="post">
                                        <input type="hidden" name="id" value="@app.Id" />

                                        <div class="modal-header bg-danger text-white">
                                            <h5 class="modal-title" id="deleteModalLabel-@app.Id">
                                                <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete
                                            </h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>

                                        <div class="modal-body">
                                            Are you sure you want to delete the application for
                                            <strong>@app.ApplicantName</strong>?
                                            <br />
                                            <span class="text-muted">This action cannot be undone.</span>
                                        </div>

                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                Cancel
                                            </button>

                                            <button type="submit" class="btn btn-danger">
                                                Delete
                                            </button>
                                        </div>

                                    </form>

                                </div>
                            </div>

                        </div>
                        <!-- END DELETE MODAL -->
                    }
                }
                else
                {
                    <tr>
                        <td colspan="11" class="text-center text-muted py-4">
                            No applications found.
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>




    <!-- PAGINATION -->
    @{
        int totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
    }

    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">

                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-search="@Model.Search">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(Model.Page == i ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-search="@Model.Search">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.Page == totalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-search="@Model.Search">
                        Next
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>