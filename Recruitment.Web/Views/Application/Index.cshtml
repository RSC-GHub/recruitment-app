@model Recruitment.Web.ViewModels.RecruitmentProcess.Application.ApplicationIndexVM

@{
    ViewData["Title"] = "Applications";
}

<!-- Page Header -->
<div class="flex-between mb-4">
    <div>
        <h2 class="card-title d-flex align-items-center gap-2">
            <i class="bi bi-clipboard2-check-fill"></i>
            Applications
        </h2>
        <p class="card-description">Review and manage job applications</p>
    </div>
</div>

<!-- Search and Filter Card -->
<div class="card-component mb-4">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-funnel me-2"></i>
            Search & Filter
        </h3>
    </div>
    <div class="card-content">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <div class="form-field">
                    <label class="form-label" for="search">Search</label>
                    <input type="text" 
                           id="search"
                           name="search" 
                           value="@Model.Search"
                           class="form-input"
                           placeholder="Search by name, email, phone..." />
                </div>
            </div>

            <div class="col-md-4">
                <div class="form-field">
                    <label class="form-label" for="status">Status</label>
                    <select id="status" name="status" class="form-select">
                        <option value="">All Statuses</option>
                        @foreach (var item in Model.StatusList)
                        {
                            <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <div class="form-field w-100">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn-component btn-primary w-100">
                        <i class="bi bi-search me-2"></i>
                        Filter
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Applications Table Card -->
<div class="card-component">
    <div class="card-content p-0">
        <div style="overflow-x: auto;">
            <div class="table-component" style="min-width: 1200px;">
                <table>
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th style="min-width: 200px;">Applicant</th>
                            <th style="min-width: 200px;">Email</th>
                            <th style="min-width: 130px;">Phone</th>
                            <th style="min-width: 180px;">Vacancy</th>
                            <th style="width: 120px;">Status</th>
                            <th style="width: 110px;">Applied On</th>
                            <th style="min-width: 130px;">Reviewer</th>
                            <th style="width: 110px;">Review Date</th>
                            <th style="min-width: 150px;">Note</th>
                            <th style="width: 100px;" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Applications.Any())
                        {
                            @foreach (var app in Model.Applications)
                            {
                                <tr>
                                    <td>@app.Id</td>
                                    <td>
                                        <a asp-action="Profile" asp-controller="Applicant" asp-route-id="@app.ApplicantId" 
                                           class="d-flex align-items-center gap-2 text-decoration-none">
                                            <i class="bi bi-person-circle fs-5"></i>
                                            <span class="fw-semibold">@app.ApplicantName</span>
                                        </a>
                                    </td>
                                    <td>@app.ApplicantEmail</td>
                                    <td>@app.PhoneNumber</td>
                                    <td>@app.VacancyTitle</td>
                                    <td>
                                        @{
                                            var statusClass = app.ApplicationStatus.ToString() == "Accepted" ? "badge-success" :
                                            app.ApplicationStatus.ToString() == "Rejected" ? "badge-destructive" :
                                            app.ApplicationStatus.ToString() == "Under Review" ? "badge-warning" :
                                                             "badge-default";
                                        }
                                        <span class="badge-component @statusClass">
                                            @app.ApplicationStatus
                                        </span>
                                    </td>
                                    <td>@app.ApplicationDate.ToString("MMM dd, yyyy")</td>
                                    <td>@(app.ReviewedByUserName ?? "—")</td>
                                    <td>@(app.ReviewDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(app.Note))
                                        {
                                            <span title="@app.Note">@(app.Note.Length > 30 ? app.Note.Substring(0, 30) + "..." : app.Note)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-2 justify-content-center">
                                            <a href="@Url.Action("Details", new { id = app.Id })" 
                                               class="btn-component btn-sm btn-outline"
                                               title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <button type="button"
                                                    class="btn-component btn-sm btn-destructive"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteModal-@app.Id"
                                                    title="Delete Application">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>

                                <!-- DELETE MODAL -->
                                <div class="modal fade" id="deleteModal-@app.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <form asp-action="DeleteConfirmed" method="post">
                                                <input type="hidden" name="id" value="@app.Id" />
                                                
                                                <div class="modal-header" style="background-color: hsl(0, 84%, 60%); color: white;">
                                                    <h5 class="modal-title">
                                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                                        Confirm Delete
                                                    </h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                </div>

                                                <div class="modal-body">
                                                    <div class="alert-component alert-destructive mb-0">
                                                        <i class="bi bi-exclamation-triangle-fill alert-icon"></i>
                                                        <div>
                                                            <div class="alert-title">Are you sure?</div>
                                                            <div class="alert-description">
                                                                You are about to delete the application for <strong>@app.ApplicantName</strong>.
                                                                This action cannot be undone.
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="modal-footer">
                                                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">
                                                        Cancel
                                                    </button>
                                                    <button type="submit" class="btn-component btn-destructive">
                                                        <i class="bi bi-trash me-2"></i>
                                                        Delete Application
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="11" class="text-center py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
                                    <div class="text-muted">No applications found</div>
                                    @if (!string.IsNullOrEmpty(Model.Search))
                                    {
                                        <a href="/Application/Index" class="btn-component btn-outline mt-3">Clear Search</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @{
        int totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
    }

    @if (totalPages > 1)
    {
        <div class="card-footer">
            <nav class="pagination-component" aria-label="Pagination">
                <a class="pagination-button @(Model.Page == 1 ? "disabled" : "")"
                   asp-action="Index"
                   asp-route-page="@(Model.Page - 1)"
                   asp-route-search="@Model.Search">
                    <i class="bi bi-chevron-left"></i>
                </a>

                @{
                    int startPage = Math.Max(1, Model.Page - 2);
                    int endPage = Math.Min(totalPages, Model.Page + 2);
                }

                @if (startPage > 1)
                {
                    <a class="pagination-button"
                       asp-action="Index"
                       asp-route-page="1"
                       asp-route-search="@Model.Search">
                        1
                    </a>
                    @if (startPage > 2)
                    {
                        <span class="pagination-button disabled">...</span>
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a class="pagination-button @(Model.Page == i ? "active" : "")"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@Model.Search">
                        @i
                    </a>
                }

                @if (endPage < totalPages)
                {
                    @if (endPage < totalPages - 1)
                    {
                        <span class="pagination-button disabled">...</span>
                    }
                    <a class="pagination-button"
                       asp-action="Index"
                       asp-route-page="@totalPages"
                       asp-route-search="@Model.Search">
                        @totalPages
                    </a>
                }

                <a class="pagination-button @(Model.Page == totalPages ? "disabled" : "")"
                   asp-action="Index"
                   asp-route-page="@(Model.Page + 1)"
                   asp-route-search="@Model.Search">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </nav>

            <div class="text-center mt-3 text-muted small">
                Showing @((Model.Page - 1) * Model.PageSize + 1) to @Math.Min(Model.Page * Model.PageSize, Model.TotalCount) of @Model.TotalCount results
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Show success toast if application was deleted
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            showToast('@TempData["SuccessMessage"]', 'success');
            </text>
        }

        // Show error toast if deletion failed
        @if (TempData["ErrorMessage"] != null)
        {
            <text>
            showToast('@TempData["ErrorMessage"]', 'error');
            </text>
        }
    </script>
}