@model List<Recruitment.Web.ViewModels.CoreBusiness.Currency.CurrencyListVM>

@{
    ViewData["Title"] = "Currencies";
}

<div class="flex-between mb-4">
    <div>
        <h2 class="card-title">Currencies</h2>
        <p class="card-description">Manage currencies and exchange rates</p>
    </div>
    <button class="btn-component btn-primary" data-bs-toggle="modal" data-bs-target="#addCurrencyModal">
        <i class="bi bi-plus-circle me-2"></i>
        Add Currency
    </button>
</div>

<div class="row g-3">
    @if (Model != null && Model.Any())
    {
        @foreach (var currency in Model)
        {
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card-component">
                    <div class="card-content">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-cash-coin text-primary fs-4"></i>
                                <h5 class="card-title mb-0">@currency.Name</h5>
                            </div>

                            <div class="dropdown">
                                <button class="btn-component btn-sm btn-outline dropdown-toggle"
                                        type="button"
                                        id="optionsMenuButton-@currency.Id"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false">
                                    <i class="bi bi-three-dots"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="optionsMenuButton-@currency.Id">
                                    <li>
                                        <a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#editModal-@currency.Id">
                                            <i class="bi bi-pencil me-2"></i>Edit
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-danger" href="#" data-bs-toggle="modal" data-bs-target="#deleteModal-@currency.Id">
                                            <i class="bi bi-trash me-2"></i>Delete
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Edit Modal -->
            <div class="modal fade" id="editModal-@currency.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-action="Edit" method="post">
                            @Html.AntiForgeryToken()
                            <div class="modal-header">
                                <h5 class="modal-title">
                                    <i class="bi bi-pencil me-2"></i>
                                    Edit Currency
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" name="id" value="@currency.Id" />
                                <div class="form-field">
                                    <label for="Name-@currency.Id" class="form-label">
                                        Currency Name <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" class="form-input" id="Name-@currency.Id" name="Name" value="@currency.Name" required />
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn-component btn-primary">
                                    <i class="bi bi-check-circle me-2"></i>
                                    Save Changes
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Delete Modal -->
            <div class="modal fade" id="deleteModal-@currency.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <form asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@currency.Id" />
                            <div class="modal-header" style="background-color: hsl(0, 84%, 60%); color: white;">
                                <h5 class="modal-title">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    Delete Currency
                                </h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="alert-component alert-destructive mb-0">
                                    <i class="bi bi-exclamation-triangle-fill alert-icon"></i>
                                    <div>
                                        <div class="alert-title">Are you sure?</div>
                                        <div class="alert-description">
                                            You are about to delete currency <strong>@currency.Name</strong>.
                                            This action cannot be undone.
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn-component btn-destructive">
                                    <i class="bi bi-trash me-2"></i>
                                    Delete Currency
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="card-component">
                <div class="card-content text-center py-5">
                    <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
                    <span class="text-muted">No currencies found</span>
                </div>
            </div>
        </div>
    }
</div>

<!-- Add Currency Modal -->
<div class="modal fade" id="addCurrencyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-plus-circle me-2"></i>
                        Add Currency
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-field">
                        <label for="AddCurrencyName" class="form-label">
                            Currency Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" 
                               class="form-input" 
                               id="AddCurrencyName" 
                               name="Name" 
                               placeholder="e.g., US Dollar, Euro"
                               required />
                        <p class="form-description">Enter the full name of the currency</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-component btn-primary">
                        <i class="bi bi-check-circle me-2"></i>
                        Add Currency
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Show toast notifications
        @if (TempData["Success"] != null)
        {
            <text>
            showToast('@TempData["Success"]', 'success');
            </text>
        }

        @if (TempData["Error"] != null)
        {
            <text>
            showToast('@TempData["Error"]', 'error');
            </text>
        }
    </script>
}