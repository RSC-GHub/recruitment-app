@model Recruitment.Web.ViewModels.CoreBusiness.Title.TitleDeleteViewModel

@{
    ViewData["Title"] = "Delete Title";
}

<div class="card-component" style="max-width: 600px; margin: 2rem auto;">
    <div class="card-header" style="background-color: hsl(0, 84%, 60%); color: white;">
        <h2 class="card-title mb-0">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Delete Title
        </h2>
    </div>

    <div class="card-content">
        <div class="alert-component alert-destructive mb-4">
            <i class="bi bi-exclamation-triangle-fill alert-icon"></i>
            <div>
                <div class="alert-title">Are you sure you want to delete this?</div>
                <div class="alert-description">
                    This action cannot be undone. This will permanently delete the title.
                </div>
            </div>
        </div>

        <div class="mb-4 p-4" style="background-color: hsl(0, 0%, 97%); border-radius: 8px;">
            <strong class="d-block mb-2">Title:</strong>
            <div class="fw-semibold fs-5">@Model.Name</div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn-component btn-destructive">
                    <i class="bi bi-trash me-2"></i>
                    Yes, Delete Title
                </button>
                <a asp-action="Index" class="btn-component btn-secondary">
                    <i class="bi bi-x-circle me-2"></i>
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Show toast notifications
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            showToast('@TempData["SuccessMessage"]', 'success');
            </text>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <text>
            showToast('@TempData["ErrorMessage"]', 'error');
            </text>
        }
    </script>
}
