@model Recruitment.Web.ViewModels.CoreBusiness.Title.TitleDetailsViewModel

@{
    ViewData["Title"] = "Title Details";
}

<div class="card-component" style="max-width: 700px; margin: 2rem auto;">
    <div class="card-header">
        <h2 class="card-title">
            <i class="bi bi-card-heading me-2"></i>
            Title Details
        </h2>
        <p class="card-description">View job title information</p>
    </div>

    <div class="card-content">
        <div class="mb-4">
            <label class="form-label text-muted">Title Name</label>
            <h4 class="mb-0">@Model.Name</h4>
        </div>
    </div>

    <div class="card-footer">
        <div class="d-flex gap-2">
            <a asp-action="Edit" 
               asp-route-id="@Model.Id" 
               class="btn-component btn-primary">
                <i class="bi bi-pencil me-2"></i>
                Edit
            </a>
            <a asp-action="Index" 
               class="btn-component btn-secondary">
                <i class="bi bi-arrow-left me-2"></i>
                Back to List
            </a>
        </div>
    </div>
</div>
