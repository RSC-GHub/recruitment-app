@model Recruitment.Web.ViewModels.RecruitmentProcess.RejectionReason.ReasonsPagedVM

@{
    ViewData["Title"] = "Rejection Reasons";
}

<!-- Page Header -->
<div class="flex-between mb-4">
    <div>
        <h2 class="card-title d-flex align-items-center gap-2">
            <i class="bi bi-x-octagon"></i>
            Rejection Reasons
        </h2>
        <p class="card-description">Manage application rejection reasons</p>
    </div>
    <button type="button"
            class="btn-component btn-primary"
            data-bs-toggle="modal"
            data-bs-target="#createModal">
        <i class="bi bi-plus-circle me-2"></i>
        Add Reason
    </button>
</div>

<!-- Search Card -->
<div class="card-component mb-4">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-search me-2"></i>
            Search Rejection Reasons
        </h3>
    </div>
    <div class="card-content">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-8">
                <div class="form-field">
                    <label class="form-label">Search</label>
                    <input type="text"
                           name="search"
                           value="@Model.Search"
                           class="form-input"
                           placeholder="Search by reason..." />
                </div>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <div class="form-field w-100">
                    <div class="d-flex gap-2">
                        <button class="btn-component btn-primary flex-grow-1">
                            <i class="bi bi-search me-2"></i>Search
                        </button>
                        @if (!string.IsNullOrEmpty(Model.Search))
                        {
                            <a asp-action="Index" class="btn-component btn-outline">
                                <i class="bi bi-x-circle"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card-component">
    <div class="card-content p-0">
        <div class="table-scroll-wrapper">
            <div class="table-component">
                <table>
                    <thead>
                        <tr>
                            <th style="width:60px;">#</th>
                            <th>Reason</th>
                            <th>Type</th>
                            <th style="width:150px" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td class="fw-semibold">@item.Reason</td>
                                    <td>
                                        <span class="badge bg-secondary">
                                            @item.ReasonType
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn-component btn-sm btn-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editModal"
                                                data-id="@item.Id"
                                                data-reason="@item.Reason"
                                                data-reasontype="@((int)item.ReasonType)">
                                            <i class="bi bi-pencil"></i>
                                        </button>

                                        <button class="btn-component btn-sm btn-destructive"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@item.Id"
                                                data-reason="@item.Reason">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    No rejection reasons found
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ===================== Modals ===================== -->
<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Add Rejection Reason</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="form-field mb-3">
                        <label class="form-label">Reason <span class="text-danger">*</span></label>
                        <input name="Reason" class="form-input" required />
                    </div>

                    <div class="form-field">
                        <label class="form-label">Reason Type <span class="text-danger">*</span></label>
                        <select name="ReasonType" class="form-input" required>
                            <option value="">Select type</option>
                            @foreach (var type in Model.ReasonTypes)
                            {
                                <option value="@type.Value">@type.Text</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-component btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id" />

                <div class="modal-header">
                    <h5 class="modal-title">Edit Rejection Reason</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="form-field mb-3">
                        <label class="form-label">Reason <span class="text-danger">*</span></label>
                        <input id="editReason" name="Reason" class="form-input" required />
                    </div>

                    <div class="form-field">
                        <label class="form-label">Reason Type <span class="text-danger">*</span></label>
                        <select id="editReasonType" name="ReasonType" class="form-input" required>
                            @foreach (var type in Model.ReasonTypes)
                            {
                                <option value="@type.Value">@type.Text</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-component btn-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteId" name="Id" />

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    You are about to delete <strong id="deleteReasonName"></strong>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-component btn-destructive">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Edit modal
        document.getElementById('editModal')
            ?.addEventListener('show.bs.modal', function (e) {
                const btn = e.relatedTarget;
                document.getElementById('editId').value = btn.dataset.id;
                document.getElementById('editReason').value = btn.dataset.reason;
                document.getElementById('editReasonType').value = btn.dataset.reasontype;
            });

        // Delete modal
        document.getElementById('deleteModal')
            ?.addEventListener('show.bs.modal', function (e) {
                const btn = e.relatedTarget;
                document.getElementById('deleteId').value = btn.dataset.id;
                document.getElementById('deleteReasonName').textContent = btn.dataset.reason;
            });

        @if (TempData["Success"] != null)
        {
                <text>showToast('@TempData["Success"]','success');</text>
        }
        @if (TempData["Error"] != null)
        {
                <text>showToast('@TempData["Error"]','error');</text>
        }
    </script>
}
