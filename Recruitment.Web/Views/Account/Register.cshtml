@model Recruitment.Web.ViewModels.UserManagement.Account.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center py-5" style="background: linear-gradient(135deg, hsl(222, 47%, 11%) 0%, hsl(197, 78.9%, 14.9%) 100%);">
    <div class="card-component" style="max-width: 600px; width: 100%; margin: 2rem;">
        <div class="card-header text-center">
            <h2 class="card-title mb-2">
                <i class="bi bi-person-plus-fill me-2"></i>
                Create Account
            </h2>
            <p class="card-description">Join our recruitment system</p>
        </div>

        <div class="card-content">
            <form asp-action="Register" method="post">
                <div class="row g-3">
                    <div class="col-12">
                        <div class="form-field">
                            <label asp-for="FullName" class="form-label">
                                Full Name <span class="text-danger">*</span>
                            </label>
                            <div class="position-relative">
                                <i class="bi bi-person position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: hsl(0, 0%, 60%);"></i>
                                <input asp-for="FullName" 
                                       class="form-input" 
                                       style="padding-left: 40px;"
                                       placeholder="Enter your full name"
                                       autofocus />
                            </div>
                            <span asp-validation-for="FullName" class="form-error"></span>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-field">
                            <label asp-for="Email" class="form-label">
                                Email Address <span class="text-danger">*</span>
                            </label>
                            <div class="position-relative">
                                <i class="bi bi-envelope position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: hsl(0, 0%, 60%);"></i>
                                <input asp-for="Email" 
                                       class="form-input" 
                                       style="padding-left: 40px;"
                                       placeholder="your.email@example.com" />
                            </div>
                            <span asp-validation-for="Email" class="form-error"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-field">
                            <label asp-for="Password" class="form-label">
                                Password <span class="text-danger">*</span>
                            </label>
                            <div class="position-relative">
                                <i class="bi bi-lock position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: hsl(0, 0%, 60%);"></i>
                                <input asp-for="Password" 
                                       type="password" 
                                       class="form-input" 
                                       style="padding-left: 40px;"
                                       placeholder="Create a password" />
                            </div>
                            <span asp-validation-for="Password" class="form-error"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-field">
                            <label asp-for="ConfirmPassword" class="form-label">
                                Confirm Password <span class="text-danger">*</span>
                            </label>
                            <div class="position-relative">
                                <i class="bi bi-lock-fill position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: hsl(0, 0%, 60%);"></i>
                                <input asp-for="ConfirmPassword" 
                                       type="password" 
                                       class="form-input" 
                                       style="padding-left: 40px;"
                                       placeholder="Confirm your password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="form-error"></span>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-field">
                            <label asp-for="DepartmentId" class="form-label">
                                Department <span class="text-danger">*</span>
                            </label>
                            <select asp-for="DepartmentId" 
                                    asp-items="Model.Departments" 
                                    class="form-select">
                                <option value="">-- Select Department --</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="form-error"></span>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-component btn-primary w-100 mt-4 mb-3">
                    <i class="bi bi-check-circle me-2"></i>
                    Create Account
                </button>

                <div class="text-center">
                    <p class="text-muted small mb-0">
                        Already have an account? 
                        <a asp-action="Login" class="text-primary fw-semibold">Sign in here</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        // Show any registration messages as toast
        @if (TempData["ErrorMessage"] != null)
        {
            <text>
            showToast('@TempData["ErrorMessage"]', 'error');
            </text>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            showToast('@TempData["SuccessMessage"]', 'success');
            </text>
        }
    </script>
}
