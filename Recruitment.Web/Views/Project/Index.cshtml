@model IEnumerable<Recruitment.Web.ViewModels.CoreBusiness.Project.ProjectViewModel>

@{
    ViewData["Title"] = "Projects";
}

<div class="card-component">
    <div class="card-header">
        <div class="flex-between">
            <div>
                <h2 class="card-title">Projects</h2>
                <p class="card-description">Manage projects and assignments</p>
            </div>
            <button type="button" 
                    class="btn-component btn-primary"
                    data-bs-toggle="modal" 
                    data-bs-target="#createModal">
                <i class="bi bi-plus-circle me-2"></i>
                Add Project
            </button>
        </div>
    </div>

    <div class="card-content">
        <div class="table-component">
            <table>
                <thead>
                    <tr>
                        <th>Project Name</th>
                        <th>Status</th>
                        <th>Location</th>
                        <th style="width: 150px;" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var project in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-folder-fill text-primary"></i>
                                        <span class="fw-semibold">@project.ProjectName</span>
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var statusClass = project.Status.ToString() == "Active" ? "badge-success" :
                                        project.Status.ToString() == "Completed" ? "badge-secondary" :
                                        "badge-warning";
                                    }
                                    <span class="badge-component @statusClass">@project.Status</span>
                                </td>
                                <td>
                                    <span class="badge-component badge-outline">@project.LocationName</span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button type="button" 
                                                class="btn-component btn-sm btn-primary edit-btn"
                                                data-bs-toggle="modal" 
                                                data-bs-target="#editModal"
                                                data-id="@project.Id"
                                                data-name="@project.ProjectName"
                                                data-status="@project.Status"
                                                data-location-id="@project.LocationId"
                                                title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button type="button" 
                                                class="btn-component btn-sm btn-destructive delete-btn"
                                                data-bs-toggle="modal" 
                                                data-bs-target="#deleteModal"
                                                data-id="@project.Id"
                                                data-name="@project.ProjectName"
                                                title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
                                <span class="text-muted">No projects found</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-plus-circle me-2"></i>
                        Add New Project
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-field">
                        <label for="createName" class="form-label">
                            Project Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" 
                               class="form-input" 
                               id="createName" 
                               name="ProjectName" 
                               placeholder="Enter project name"
                               required />
                    </div>
                    <div class="form-field">
                        <label for="createStatus" class="form-label">
                            Status <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" id="createStatus" name="Status" required>
                            @foreach (var status in Enum.GetValues(typeof(Recruitment.Domain.Enums.ProjectStatus)))
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </div>
                    <div class="form-field">
                        <label for="createLocation" class="form-label">
                            Location <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" id="createLocation" name="LocationId" required>
                            <option value="">-- Select Location --</option>
                            @foreach (var loc in ViewBag.Locations as IEnumerable<SelectListItem>)
                            {
                                <option value="@loc.Value">@loc.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn-component btn-primary">
                        <i class="bi bi-check-circle me-2"></i>
                        Save Project
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Edit" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-pencil me-2"></i>
                        Edit Project
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editId" name="Id" />
                    <div class="form-field">
                        <label for="editName" class="form-label">
                            Project Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" 
                               class="form-input" 
                               id="editName" 
                               name="ProjectName" 
                               required />
                    </div>
                    <div class="form-field">
                        <label for="editStatus" class="form-label">
                            Status <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" id="editStatus" name="Status" required>
                            @foreach (var status in Enum.GetValues(typeof(Recruitment.Domain.Enums.ProjectStatus)))
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </div>
                    <div class="form-field">
                        <label for="editLocation" class="form-label">
                            Location <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" id="editLocation" name="LocationId" required>
                            <option value="">-- Select Location --</option>
                            @foreach (var loc in ViewBag.Locations as IEnumerable<SelectListItem>)
                            {
                                <option value="@loc.Value">@loc.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn-component btn-primary">
                        <i class="bi bi-check-circle me-2"></i>
                        Update Project
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Delete" method="post">
                <div class="modal-header" style="background-color: hsl(0, 84%, 60%); color: white;">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Confirm Delete
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert-component alert-destructive mb-0">
                        <i class="bi bi-exclamation-triangle-fill alert-icon"></i>
                        <div>
                            <div class="alert-title">Are you sure?</div>
                            <div class="alert-description">
                                You are about to delete project <strong id="deleteProjectName"></strong>.
                                This action cannot be undone.
                            </div>
                        </div>
                    </div>
                    <input type="hidden" id="deleteProjectId" name="Id" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn-component btn-destructive">
                        <i class="bi bi-trash me-2"></i>
                        Delete Project
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Fill Edit Modal
        var editModal = document.getElementById('editModal');
        editModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            var name = button.getAttribute('data-name');
            var status = button.getAttribute('data-status');
            var locationId = button.getAttribute('data-location-id');

            document.getElementById('editId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editStatus').value = status;
            document.getElementById('editLocation').value = locationId;
        });

        // Fill Delete Modal
        var deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            var name = button.getAttribute('data-name');

            document.getElementById('deleteProjectId').value = id;
            document.getElementById('deleteProjectName').textContent = name;
        });

        // Show toast notifications
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            showToast('@TempData["SuccessMessage"]', 'success');
            </text>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <text>
            showToast('@TempData["ErrorMessage"]', 'error');
            </text>
        }
    </script>
}
