@model Recruitment.Web.ViewModels.CoreBusiness.Project.ProjectViewModel

@{
    ViewData["Title"] = "Delete Project";
}

<h2>Delete Project</h2>

<h4>Are you sure you want to delete this project?</h4>

<div>
    <dl class="row">
        <dt class="col-sm-2">Project Name</dt>
        <dd class="col-sm-10">@Model.ProjectName</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>

        <dt class="col-sm-2">Location</dt>
        <dd class="col-sm-10">@Model.LocationName</dd>
    </dl>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
