@model Recruitment.Web.ViewModels.UserManagement.User.UserProfileViewModel

@{
    ViewData["Title"] = "User Profile";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<!-- Page Header -->
<div class="mb-4">
    <div class="d-flex align-items-center gap-3 mb-2">
        <div class="d-flex align-items-center justify-content-center" style="width: 64px; height: 64px; background: linear-gradient(135deg, hsl(222, 47%, 45%) 0%, hsl(197, 78.9%, 14.9%) 100%); border-radius: 50%; color: white;">
            <i class="bi bi-person-circle" style="font-size: 2.5rem;"></i>
        </div>
        <div>
            <h2 class="mb-1" style="font-size: 1.75rem; font-weight: 600; color: hsl(222, 47%, 20%);">@Model.FullName</h2>
            <p class="mb-0 text-muted">@Model.Email</p>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- ================== USER INFO CARD ================== -->
    <div class="col-lg-12">
        <div class="card-component">
            <div class="card-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-person-badge" style="font-size: 1.25rem; color: hsl(222, 47%, 45%);"></i>
                    <h3 class="card-title mb-0">User Information</h3>
                </div>
            </div>
            <div class="card-content">
                <form asp-action="EditUser" method="post" id="userForm">
                    <input type="hidden" asp-for="Id" />

                    <div class="field-group">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="field">
                                    <label class="field-label" for="FullName">
                                        <i class="bi bi-person me-1"></i>Full Name
                                        <span class="text-danger">*</span>
                                        <span class="tooltip-trigger">
                                            <i>i</i>
                                            <span class="tooltip-content multiline">Enter user's complete first and last name</span>
                                        </span>
                                    </label>
                                    <input asp-for="FullName" id="FullName" class="form-field-input" required />
                                    <span class="field-description">This will be displayed across the system</span>
                                    <span class="field-error" style="display:none;">Full Name is required.</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="field">
                                    <label class="field-label" for="Email">
                                        <i class="bi bi-envelope me-1"></i>Email
                                        <span class="text-danger">*</span>
                                        <span class="tooltip-trigger">
                                            <i>i</i>
                                            <span class="tooltip-content multiline">User's primary email for login and notifications</span>
                                        </span>
                                    </label>
                                    <input asp-for="Email" id="Email" class="form-field-input" type="email" required />
                                    <span class="field-description">Used for login and system notifications</span>
                                    <span class="field-error" style="display:none;">Valid email is required.</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="field">
                                    <label class="field-label" for="DepartmentId">
                                        <i class="bi bi-building me-1"></i>Department
                                        <span class="text-danger">*</span>
                                        <span class="tooltip-trigger">
                                            <i>i</i>
                                            <span class="tooltip-content multiline">Select the department this user belongs to</span>
                                        </span>
                                    </label>
                                    <select asp-for="DepartmentId" id="DepartmentId" class="form-field-select" asp-items="Model.Departments" required>
                                        <option value="">-- Select Department --</option>
                                    </select>
                                    <span class="field-description">Determines user access and permissions</span>
                                    <span class="field-error" style="display:none;">Please select a department.</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="field orientation-horizontal">
                                    <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveCheck" style="width: 20px; height: 20px; cursor: pointer;" />
                                    <div class="field-content">
                                        <label class="field-label mb-0" for="isActiveCheck" style="cursor: pointer;">
                                            <i class="bi bi-toggle-on me-1"></i>Active Account
                                            <span class="tooltip-trigger">
                                                <i>i</i>
                                                <span class="tooltip-content multiline">Enable or disable user's system access</span>
                                            </span>
                                        </label>
                                        <span class="field-description">Toggle to enable or disable user access</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="field-separator"></div>

                    <button type="submit" class="btn-component btn-primary">
                        <i class="bi bi-check-circle me-2"></i>Save Changes
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- ================== USER ROLES CARD ================== -->
    <div class="col-lg-12">
        <div class="card-component">
            <div class="card-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-shield-check" style="font-size: 1.25rem; color: hsl(142, 76%, 36%);"></i>
                    <h3 class="card-title mb-0">User Roles</h3>
                </div>
            </div>
            <div class="card-content">
                @if (Model.Roles != null && Model.Roles.Any())
                {
                    <div class="d-flex flex-column gap-2 mb-3">
                        @foreach (var role in Model.Roles)
                        {
                            <div class="d-flex justify-content-between align-items-center p-3" style="background: hsl(0, 0%, 98%); border-radius: 8px; border: 1px solid hsl(0, 0%, 90%);">
                                <span class="badge-component badge-primary" style="font-size: 0.875rem;">
                                    <i class="bi bi-shield-fill-check me-1"></i>@role
                                </span>
                                <form asp-action="RemoveRole" method="post" class="m-0">
                                    <input type="hidden" name="userId" value="@Model.Id" />
                                    <input type="hidden" name="roleName" value="@role" />
                                    <button type="submit" class="btn-component btn-secondary" title="Remove role">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-shield-x fs-1 d-block mb-2" style="color: hsl(0, 0%, 70%);"></i>
                        <p class="text-muted mb-0">No roles assigned yet</p>
                    </div>
                }

                <button type="button" class="btn-component btn-primary" data-bs-toggle="modal" data-bs-target="#rolesModal">
                    <i class="bi bi-pencil-square me-2"></i>Manage Roles
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ================== User project CARD ================== -->

<div class="col-lg-12">
    <div class="card-component">
        <div class="card-header">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-diagram-3" style="font-size: 1.25rem; color: hsl(210, 70%, 45%);"></i>
                <h3 class="card-title mb-0">User Projects</h3>
            </div>
        </div>

        <div class="card-content">

            @if (Model.Projects != null && Model.Projects.Any())
            {
                <div class="d-flex flex-column gap-2 mb-3">
                    @foreach (var project in Model.Projects)
                    {
                        <div class="d-flex justify-content-between align-items-center p-3"
                             style="background: hsl(0,0%,98%); border-radius:8px; border:1px solid hsl(0,0%,90%);">

                            <span class="badge-component badge-primary">
                                <i class="bi bi-folder me-1"></i>@project.ProjectName
                            </span>

                            <form asp-action="RemoveProject" method="post" class="m-0">
                                <input type="hidden" name="userId" value="@Model.Id" />
                                <input type="hidden" name="projectId" value="@project.Id" />

                                <button type="submit" class="btn-component btn-secondary">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-folder-x fs-1 d-block mb-2" style="color:hsl(0,0%,70%)"></i>
                    <p class="text-muted mb-0">No projects assigned</p>
                </div>
            }

            <button type="button"
                    class="btn-component btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#projectsModal">

                <i class="bi bi-pencil-square me-2"></i>Manage Projects
            </button>

        </div>
    </div>
</div>

<!-- ================== Role MODAL ================== -->
<div class="modal fade" id="rolesModal" tabindex="-1" aria-labelledby="rolesModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateRoles" method="post" id="rolesForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="rolesModalLabel">Edit Roles</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label class="form-field-label">Select Roles<span class="text-danger"> *</span></label>
                        <select asp-for="SelectedRoleIds"
                                class="form-field-select select2"
                                multiple="multiple"
                                asp-items="Model.AvailableRoles"
                                required>
                        </select>
                        <div class="invalid-feedback">Please select at least one role.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn-component btn-primary"><i class="bi bi-check-circle me-1"></i>Save Roles</button>
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ================== User project MODAL ================== -->

<div class="modal fade" id="projectsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form asp-action="UpdateProjects" method="post" id="projectsForm">

                <div class="modal-header">
                    <h5 class="modal-title">Edit Projects</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label class="form-field-label">
                            Select Projects
                        </label>

                        <select asp-for="SelectedProjectIds"
                                class="form-field-select select2"
                                multiple
                                asp-items="Model.AvailableProjects">
                        </select>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn-component btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Save Projects
                    </button>

                    <button type="button"
                            class="btn-component btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <!-- REMOVE THIS LINE -->
    <!-- <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script> -->

    <script>
        $(document).ready(function () {

            // ================== SELECT2 MODAL ==================
            function initModalSelect2() {
                $('#rolesModal .select2').select2({
                    placeholder: "Select roles",
                    allowClear: true,
                    width: '100%',
                    dropdownParent: $('#rolesModal')
                });
            }
            initModalSelect2();

            $('#rolesModal').on('shown.bs.modal', function () {
                initModalSelect2();
            });

            $('#rolesModal').on('hidden.bs.modal', function () {
                $('#rolesModal .select2').select2('destroy');
            });

            // ================== REAL-TIME VALIDATION ==================
            function validateField($field) {
                var isRequired = $field.prop('required');
                var value = $field.val();
                var $fieldContainer = $field.closest('.field');
                var $fieldError = $fieldContainer.find('.field-error');

                if (isRequired) {
                    if (!value || value.length === 0 || (Array.isArray(value) && value.length === 0)) {
                        $field.addClass('is-invalid').removeClass('is-valid');
                        $fieldContainer.attr('data-invalid', 'true');
                        if ($fieldError.length) $fieldError.show();
                        return false;
                    } else {
                        $field.addClass('is-valid').removeClass('is-invalid');
                        $fieldContainer.removeAttr('data-invalid');
                        if ($fieldError.length) $fieldError.hide();
                        return true;
                    }
                }
                return true;
            }

            function attachValidation(formSelector) {
                var $form = $(formSelector);
                var $fields = $form.find('input, select, textarea');

                $fields.each(function () {
                    var $field = $(this);
                    $field.on('input change blur', function () {
                        validateField($field);
                    });
                });

                $form.on('submit', function (e) {
                    var isValid = true;
                    $fields.each(function () {
                        if (!validateField($(this))) {
                            isValid = false;
                        }
                    });

                    if (!isValid) {
                        e.preventDefault();
                        e.stopPropagation();
                    }
                });
            }

            // Attach validation to user info form
            attachValidation('#userForm');

            // Attach validation to roles modal form
            attachValidation('#rolesForm');

        });


                function initProjectsSelect2() {
            $('#projectsModal .select2').select2({
                placeholder: "Select projects",
                allowClear: true,
                width: '100%',
                dropdownParent: $('#projectsModal')
            });
        }

        initProjectsSelect2();

        $('#projectsModal').on('shown.bs.modal', function () {
            initProjectsSelect2();
        });

        $('#projectsModal').on('hidden.bs.modal', function () {
            $('#projectsModal .select2').select2('destroy');
        });

    </script>
}

