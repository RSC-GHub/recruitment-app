@model Recruitment.Web.ViewModels.UserManagement.User.UserProfileViewModel

@{
    ViewData["Title"] = "User Profile";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<h2>@Model.FullName</h2>
<hr />

<div class="row">
    <!-- ================== USER INFO ================== -->
    <div class="col-md-12 mb-4">
        <h4>User Information</h4>
        <form asp-action="EditUser" method="post" class="card p-4 shadow-sm border-0">
            <input type="hidden" asp-for="Id" />

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Department</label>
                    <select asp-for="DepartmentId" class="form-control" asp-items="Model.Departments">
                        <option value="">-- Select Department --</option>
                    </select>
                </div>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveCheck" />
                <label class="form-check-label" for="isActiveCheck">Active</label>
            </div>

            <button type="submit" class="btn btn-primary px-4">Save Changes</button>
        </form>
    </div>

    <!-- ================== USER ROLES ================== -->
    <div class="col-md-12">
        <h4>User Roles</h4>
        <div class="card p-4 shadow-sm border-0">
            @if (Model.Roles != null && Model.Roles.Any())
            {
                <ul class="list-group mb-3">
                    @foreach (var role in Model.Roles)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@role</span>
                            <form asp-action="RemoveRole" method="post" class="m-0">
                                <input type="hidden" name="userId" value="@Model.Id" />
                                <input type="hidden" name="roleName" value="@role" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
                            </form>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No roles assigned yet.</p>
            }

            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#rolesModal">
                Edit Roles
            </button>
        </div>
    </div>
</div>

<!-- ================== MODAL ================== -->
<div class="modal fade" id="rolesModal" tabindex="-1" aria-labelledby="rolesModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateRoles" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="rolesModalLabel">Edit Roles</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label>Select Roles</label>
                        <select asp-for="SelectedRoleIds"
                                class="form-control select2"
                                multiple="multiple"
                                asp-items="Model.AvailableRoles">
                        </select>
                        
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save Roles</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            function initSelect2() {
                $('.select2').select2({
                    placeholder: "Select roles",
                    allowClear: true,
                    width: '100%',
                    dropdownParent: $('#rolesModal')
                });
            }

            initSelect2();

            // Re-initialize Select2 when modal opens
            $('#rolesModal').on('shown.bs.modal', function () {
                initSelect2();
            });

            // Destroy Select2 when modal closes
            $('#rolesModal').on('hidden.bs.modal', function () {
                $('.select2').select2('destroy');
            });
        });
    </script>
}
