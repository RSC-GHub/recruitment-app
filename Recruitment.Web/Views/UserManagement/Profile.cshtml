@model Recruitment.Web.ViewModels.UserManagement.User.UserProfileViewModel

@{
    ViewData["Title"] = "User Profile";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<div class="card-component">
    <div class="card-header">
        <h2 class="card-title"><i class="bi bi-person-circle me-2"></i>@Model.FullName</h2>
    </div>
    <div class="card-content">

        <div class="row">
            <!-- ================== USER INFO ================== -->
            <div class="col-md-12 mb-4">
                <h4 class="mb-3"><i class="bi bi-person-badge me-2"></i>User Information</h4>
                <div class="card-component">
                    <div class="card-content">
                        <form asp-action="EditUser" method="post" id="userForm">
                            <input type="hidden" asp-for="Id" />

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-field-label">Full Name<span class="text-danger"> *</span></label>
                                    <input asp-for="FullName" class="form-field-input" required />
                                    <div class="invalid-feedback">Full Name is required.</div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-field-label">Email<span class="text-danger"> *</span></label>
                                    <input asp-for="Email" class="form-field-input" type="email" required />
                                    <div class="invalid-feedback">Valid email is required.</div>
                                </div>

                                <div class="col-md-6 mt-3">
                                    <label class="form-field-label">Department<span class="text-danger"> *</span></label>
                                    <select asp-for="DepartmentId" class="form-field-select" asp-items="Model.Departments" required>
                                        <option value="">-- Select Department --</option>
                                    </select>
                                    <div class="invalid-feedback">Please select a department.</div>
                                </div>
                            </div>

                            <div class="form-check mb-3">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveCheck" />
                                <label class="form-check-label" for="isActiveCheck">Active</label>
                            </div>

                            <button type="submit" class="button-primary px-4"><i class="bi bi-check-circle me-1"></i>Save Changes</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- ================== USER ROLES ================== -->
            <div class="col-md-12">
                <h4 class="mb-3"><i class="bi bi-shield-check me-2"></i>User Roles</h4>
                <div class="card-component">
                    <div class="card-content">
                        @if (Model.Roles != null && Model.Roles.Any())
                        {
                            <ul class="list-group mb-3">
                                @foreach (var role in Model.Roles)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span><span class="badge-component badge-secondary">@role</span></span>
                                        <form asp-action="RemoveRole" method="post" class="m-0">
                                            <input type="hidden" name="userId" value="@Model.Id" />
                                            <input type="hidden" name="roleName" value="@role" />
                                            <button type="submit" class="button-destructive button-sm"><i class="bi bi-trash me-1"></i>Remove</button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted">No roles assigned yet.</p>
                        }

                        <button type="button" class="button-primary" data-bs-toggle="modal" data-bs-target="#rolesModal">
                            <i class="bi bi-pencil me-1"></i>Edit Roles
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- ================== MODAL ================== -->
<div class="modal fade" id="rolesModal" tabindex="-1" aria-labelledby="rolesModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateRoles" method="post" id="rolesForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="rolesModalLabel">Edit Roles</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label class="form-field-label">Select Roles<span class="text-danger"> *</span></label>
                        <select asp-for="SelectedRoleIds"
                                class="form-field-select select2"
                                multiple="multiple"
                                asp-items="Model.AvailableRoles"
                                required>
                        </select>
                        <div class="invalid-feedback">Please select at least one role.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="button-primary"><i class="bi bi-check-circle me-1"></i>Save Roles</button>
                    <button type="button" class="button-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- REMOVE THIS LINE -->
    <!-- <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script> -->

    <script>
        $(document).ready(function () {

            // ================== SELECT2 MODAL ==================
            function initModalSelect2() {
                $('#rolesModal .select2').select2({
                    placeholder: "Select roles",
                    allowClear: true,
                    width: '100%',
                    dropdownParent: $('#rolesModal')
                });
            }
            initModalSelect2();

            $('#rolesModal').on('shown.bs.modal', function () {
                initModalSelect2();
            });

            $('#rolesModal').on('hidden.bs.modal', function () {
                $('#rolesModal .select2').select2('destroy');
            });

            // ================== REAL-TIME VALIDATION ==================
            function validateField($field) {
                var isRequired = $field.prop('required');
                var value = $field.val();

                if (isRequired) {
                    if (!value || value.length === 0 || (Array.isArray(value) && value.length === 0)) {
                        $field.addClass('is-invalid').removeClass('is-valid');
                        return false;
                    } else {
                        $field.addClass('is-valid').removeClass('is-invalid');
                        return true;
                    }
                }
                return true;
            }

            function attachValidation(formSelector) {
                var $form = $(formSelector);
                var $fields = $form.find('input, select, textarea');

                $fields.each(function () {
                    var $field = $(this);
                    $field.on('input change blur', function () {
                        validateField($field);
                    });
                });

                $form.on('submit', function (e) {
                    var isValid = true;
                    $fields.each(function () {
                        if (!validateField($(this))) {
                            isValid = false;
                        }
                    });

                    if (!isValid) {
                        e.preventDefault();
                        e.stopPropagation();
                    }
                });
            }

            // Attach validation to user info form
            attachValidation('#userForm');

            // Attach validation to roles modal form
            attachValidation('#rolesForm');

        });
    </script>
}

