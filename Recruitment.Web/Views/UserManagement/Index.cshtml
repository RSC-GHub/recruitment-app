@model IEnumerable<Recruitment.Web.ViewModels.UserManagement.User.UserWithRoleViewModel>

<h2>User Management</h2>

<table class="table table-hover table-striped">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr onclick="window.location='@Url.Action("Profile", "UserManagement", new { id = user.Id })'" style="cursor:pointer">
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.DepartmentName</td>
                <td>
                    @if (user.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
