<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Recruitment.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/tailwind.css" />
    <link rel="stylesheet" href="~/css/shadcn-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Recruitment.Web.styles.css" asp-append-version="true" />

    <link href="~/lib/select2/css/select2.css" rel="stylesheet" />
    <link href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
    <link href="~/lib/select2-bootstrap-5-theme/select2-bootstrap-5-theme.css" rel="stylesheet" />
    <link href="~/lib/select2-bootstrap-5-theme/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet" />
</head>

<body>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <!-- Sidebar for authenticated users -->
        <aside class="sidebar" id="sidebar">
            <!-- Sidebar Header -->
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="sidebar-logo">
                    <img src="~/logo/LOGO.png" alt="Recruitment Logo" />
                </a>

                <button type="button"
                        class="sidebar-collapse-btn"
                        id="sidebarCollapseBtn"
                        onclick="toggleSidebar()">
                    <i class="bi bi-chevron-left"></i>
                </button>
            </div>

            <!-- Sidebar Content -->
            <div class="sidebar-content">
                <ul class="sidebar-menu">
                    <!-- Home -->
                    <li class="sidebar-menu-item">
                        <a asp-controller="Home" asp-action="Index" class="sidebar-menu-button">
                            <i class="bi bi-house-fill"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>
                </ul>

                <!-- Recruitment Section -->
                <div class="sidebar-group-label">Recruitment</div>
                <ul class="sidebar-menu">
                    <li class="sidebar-menu-item">
                        <a asp-controller="Vacancy" asp-action="Index" class="sidebar-menu-button">
                            <i class="bi bi-briefcase-fill"></i>
                            <span>Vacancies</span>
                        </a>
                    </li>
                    <li class="sidebar-menu-item">
                        <a asp-controller="Applicant" asp-action="Index" class="sidebar-menu-button">
                            <i class="bi bi-person-badge-fill"></i>
                            <span>Applicants</span>
                        </a>
                    </li>
                    <li class="sidebar-menu-item">
                        <a asp-controller="Application" asp-action="Index" class="sidebar-menu-button">
                            <i class="bi bi-file-earmark-text-fill"></i>
                            <span>Applications</span>
                        </a>
                    </li>
                    <li class="sidebar-menu-item">
                        <a asp-controller="Interview" asp-action="Index" class="sidebar-menu-button">
                            <i class="bi bi-calendar-event-fill"></i>
                            <span>Interviews</span>
                        </a>
                    </li>
                </ul>

                <!-- Setup Section -->
                <div class="sidebar-group-label">Configuration</div>
                <ul class="sidebar-menu">
                    <li class="sidebar-menu-item">
                        <a asp-controller="AppSetup" asp-action="Index" class="sidebar-menu-button">
                            <i class="bi bi-gear-fill"></i>
                            <span>Setup</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Reports Section (Dynamic Active Reports) -->
            <div class="sidebar-group-label">Reports</div>
            <div class="sidebar-section">
                @await Component.InvokeAsync("ActiveReportsSidebar")
            </div>


            <!-- User Management Section (Admin Only) -->
            @if (User.IsInRole("Admin"))
            {
                <div class="sidebar-group-label">User Management</div>
                <ul class="sidebar-menu">
                    <li class="sidebar-menu-item">
                        <a asp-controller="UserManagement" asp-action="Index" class="sidebar-menu-button">
                            <i class="bi bi-people-fill"></i>
                            <span>Users</span>
                        </a>
                    </li>
                    <li class="sidebar-menu-item">
                        <a asp-controller="Permission" asp-action="Index" class="sidebar-menu-button">
                            <i class="bi bi-shield-lock-fill"></i>
                            <span>Permissions</span>
                        </a>
                    </li>
                    <li class="sidebar-menu-item">
                        <a asp-controller="Role" asp-action="Index" class="sidebar-menu-button">
                            <i class="bi bi-award-fill"></i>
                            <span>Roles</span>
                        </a>
                    </li>
                </ul>


                <!-- Developer Reports Section -->
                <div class="sidebar-group-label">Developer</div>
                <ul class="sidebar-menu">
                    <li class="sidebar-menu-item">
                        <a asp-controller="ReportDev" asp-action="Index" class="sidebar-menu-button">
                            <i class="bi bi-bar-chart-fill"></i>
                            <span>Reports dev</span>
                        </a>
                    </li>
                </ul>
            }

            

            <!-- Sidebar Footer -->
            <div class="sidebar-footer">
                <div class="d-flex flex-column gap-2">
                    <div class="text-sm" style="color: var(--sidebar-foreground); opacity: 0.9;">
                        <i class="bi bi-person-circle"></i>
                        <span class="ms-2">@User.Identity.Name</span>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="btn-component btn-destructive w-100">
                            <i class="bi bi-box-arrow-right me-2"></i>
                            Logout
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- Main Content with Sidebar -->
        <div class="main-content-with-sidebar">
            <!-- Breadcrumb -->
            @{
                var controller = ViewContext.RouteData.Values["controller"]?.ToString();
                var action = ViewContext.RouteData.Values["action"]?.ToString();
                var parentController = ViewData["ParentController"]?.ToString();
                var parentTitle = ViewData["ParentTitle"]?.ToString();
            }

            <div class="breadcrumb-container">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb align-items-center">
                        <li class="breadcrumb-item">
                            <a href="@Url.Action("Index", "Home")" class="breadcrumb-link">
                                <i class="bi bi-house-fill"></i>
                            </a>
                        </li>

                        @* Parent breadcrumb dynamic *@
                        @if (!string.IsNullOrWhiteSpace(parentController))
                        {
                            <li class="breadcrumb-separator">/</li>
                            <li class="breadcrumb-item">
                                <a href="@Url.Action("Index", parentController)" class="breadcrumb-link">
                                    @parentTitle
                                </a>
                            </li>
                        }

                        @* Current controller breadcrumb *@
                        @if (!string.IsNullOrWhiteSpace(controller) && controller != "Home")
                        {
                            <li class="breadcrumb-separator">/</li>
                            <li class="breadcrumb-item">
                                <a href="@Url.Action("Index", controller)" class="breadcrumb-link">
                                    @(ViewData["BreadcrumbTitle"]?.ToString() ?? controller)
                                </a>
                            </li>
                        }

                        @* Specific: Reports action breadcrumb *@
                        @if (controller == "Reports" && action == "Index")
                        {
                            <li class="breadcrumb-separator">/</li>
                            <li class="breadcrumb-item">
                                <span class="breadcrumb-page">Reports</span>
                            </li>
                        }

                        @* Action-specific breadcrumb if not Index *@
                        @if (!string.IsNullOrWhiteSpace(action) && action != "Index")
                        {
                            <li class="breadcrumb-separator">/</li>
                            <li class="breadcrumb-item">
                                <span class="breadcrumb-page">
                                    @action
                                </span>
                            </li>
                        }
                    </ol>
                </nav>
            </div>

            <!-- Main Content -->
            <div class="container-fluid p-4">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>

    }
    else
    {
        <!-- Layout for unauthenticated users (no sidebar) -->
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light"
                 style="background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
                                    box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                        <img src="~/logo/logo.png" style="height:40px" alt="Recruitment Logo" />
                    </a>
                    <div class="ms-auto d-flex gap-2">
                        <a class="btn-component btn-outline" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            Login
                        </a>
                        <a class="btn-component btn-primary" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus me-2"></i>
                            Register
                        </a>
                    </div>
                </div>
            </nav>
        </header>

        <div class="container">
            <main role="main" class="pb-3 pt-4">
                @RenderBody()
            </main>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/select2/js/select2.full.min.js"></script>
    <script src="~/lib/select2/js/select2.js"></script>
    <script src="~/lib/select2/js/select2.min.js"></script>
    <script src="~/lib/sonner/sonner.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Helper functions for toast notifications
        window.showToast = function(message, type = 'default') {
            if (!window.sonner || !window.sonner.toast) {
                console.error('Toast library not loaded');
                return;
            }

            const toast = window.sonner.toast;

            switch(type) {
                case 'success':
                    toast.success(message);
                    break;
                case 'error':
                    toast.error(message);
                    break;
                case 'warning':
                    toast.warning(message);
                    break;
                case 'info':
                    toast.info(message);
                    break;
                default:
                    toast(message);
            }
        };

        // Sidebar collapse functionality
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.querySelector('.main-content-with-sidebar');
            const collapseBtn = document.getElementById('sidebarCollapseBtn');

            sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('sidebar-collapsed');

            const isCollapsed = sidebar.classList.contains('collapsed');
            localStorage.setItem('sidebarCollapsed', isCollapsed);

            const icon = collapseBtn.querySelector('i');
            if (isCollapsed) {
                icon.classList.remove('bi-chevron-left');
                icon.classList.add('bi-chevron-right');
            } else {
                icon.classList.remove('bi-chevron-right');
                icon.classList.add('bi-chevron-left');
            }

            if (window.updateCalendarAfterSidebar) {
                window.updateCalendarAfterSidebar();
            }
        }

        // Highlight active sidebar menu item
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname;
            const menuButtons = document.querySelectorAll('.sidebar-menu-button');

            menuButtons.forEach(button => {
                if (button.getAttribute('href') === currentPath) {
                    button.classList.add('active');
                }
            });

            const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            if (isCollapsed) {
                const sidebar = document.getElementById('sidebar');
                const mainContent = document.querySelector('.main-content-with-sidebar');
                const collapseBtn = document.getElementById('sidebarCollapseBtn');

                if (sidebar && mainContent && collapseBtn) {
                    sidebar.classList.add('collapsed');
                    mainContent.classList.add('sidebar-collapsed');

                    const icon = collapseBtn.querySelector('i');
                    icon.classList.remove('bi-chevron-left');
                    icon.classList.add('bi-chevron-right');
                }
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    @{
        var errorModel = Context.Items["ErrorViewModel"] as Recruitment.Web.Models.ErrorViewModel;
    }

    @if (errorModel != null)
    {
        @await Html.PartialAsync("_ErrorModal", errorModel)
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var errorModal = document.getElementById("globalErrorModal");
            if (errorModal) {
                var modal = new bootstrap.Modal(errorModal);
                modal.show();
            }
        });
    </script>

</body>
</html>
