<ul class="sidebar-menu">

    <!-- Parent button -->
    <li class="sidebar-menu-item">
        <a class="sidebar-menu-button d-flex justify-content-between align-items-center"
           data-bs-toggle="collapse"
           href="#reportsCollapse"
           role="button"
           aria-expanded="false"
           aria-controls="reportsCollapse">

            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-bar-chart-fill"></i>
                <span>Reports</span>
            </div>

            <i class="bi bi-chevron-down small"></i>
        </a>
    </li>

    <!-- Collapsed reports -->
    <div class="collapse" id="reportsCollapse">
        <ul class="sidebar-menu ps-4">
            @foreach (var report in Model)
            {
                <li class="sidebar-menu-item">
                    <a asp-controller="Reports"
                       asp-action="Run"
                       asp-route-id="@report.Id"
                       class="sidebar-menu-button">
                        <i class="bi bi-dot"></i>
                        <span>@report.Name</span>
                    </a>
                </li>
            }
        </ul>
    </div>

</ul>
