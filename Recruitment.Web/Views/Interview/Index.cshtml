@using Recruitment.Domain.Enums
@model Recruitment.Web.ViewModels.RecruitmentProcess.Interview.InterviewIndexVM

@{
    ViewData["Title"] = "Interviews";
}

<!-- Page Header -->
<div class="flex-between mb-4">
    <div>
        <h2 class="card-title d-flex align-items-center gap-2">
            <i class="bi bi-calendar-event-fill"></i>
            Interviews
        </h2>
        <p class="card-description">Manage and track interview schedules</p>
    </div>
</div>

<!-- Search and Filters Card -->
<div class="card-component mb-4">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-funnel me-2"></i>
            Search & Filter
        </h3>
    </div>
    <div class="card-content">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <div class="form-field">
                    <label class="form-label" for="search">Search</label>
                    <input type="text" 
                           id="search"
                           name="search" 
                           value="@Model.Search"
                           class="form-input" 
                           placeholder="Applicant, Vacancy, Interviewer..." />
                </div>
            </div>

            <div class="col-md-2">
                <div class="form-field">
                    <label class="form-label" for="type">Type</label>
                    <select id="type" name="type" class="form-select">
                        <option value="">All Types</option>
                        @foreach (var t in Enum.GetValues(typeof(InterviewType)))
                        {
                            var isSelected = Model.Type == (InterviewType)t;
                            <option value="@t" selected="@isSelected">@t</option>
                        }
                    </select>
                </div>
            </div>

            <div class="col-md-2">
                <div class="form-field">
                    <label class="form-label" for="category">Category</label>
                    <select id="category" name="category" class="form-select">
                        <option value="">All Categories</option>
                        @foreach (var t in Enum.GetValues(typeof(InterviewCategory)))
                        {
                            var isSelected = Model.InterviewCategory == (InterviewCategory)t;
                            <option value="@t" selected="@isSelected">@t</option>
                        }
                    </select>
                </div>
            </div>

            <div class="col-md-2">
                <div class="form-field">
                    <label class="form-label" for="result">Result</label>
                    <select id="result" name="result" class="form-select">
                        <option value="">All Results</option>
                        @foreach (var r in Enum.GetValues(typeof(InterviewResult)))
                        {
                            var isSelected = Model.Result == (InterviewResult)r;
                            <option value="@r" selected="@isSelected">@r</option>
                        }
                    </select>
                </div>
            </div>

            <div class="col-md-2">
                <div class="form-field">
                    <label class="form-label" for="status">Status</label>
                    <select id="status" name="status" class="form-select">
                        <option value="">All Status</option>
                        @foreach (var r in Enum.GetValues(typeof(InterviewStatus)))
                        {
                            var isSelected = Model.Status == (InterviewStatus)r;
                            <option value="@r" selected="@isSelected">@r</option>
                        }
                    </select>
                </div>
            </div>

            <div class="col-md-2">
                <div class="form-field">
                    <label class="form-label" for="fromDate">From Date</label>
                    <input type="date" 
                           id="fromDate"
                           name="fromDate" 
                           value="@Model.FromDate?.ToString("yyyy-MM-dd")" 
                           class="form-input" />
                </div>
            </div>

            <div class="col-md-2">
                <div class="form-field">
                    <label class="form-label" for="toDate">To Date</label>
                    <input type="date" 
                           id="toDate"
                           name="toDate" 
                           value="@Model.ToDate?.ToString("yyyy-MM-dd")" 
                           class="form-input" />
                </div>
            </div>

            <div class="col-md-12">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-component btn-primary">
                        <i class="bi bi-search me-2"></i>
                        Apply Filters
                    </button>
                    <a href="/Interview/Index" class="btn-component btn-outline">
                        <i class="bi bi-x-circle me-2"></i>
                        Clear Filters
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Interviews Table -->
<div class="card-component">
    <div class="card-content p-0">
        <div style="overflow-x: auto;">
            <div class="table-component" style="min-width: 1200px;">
                <table>
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th style="min-width: 180px;">Applicant</th>
                            <th style="min-width: 180px;">Vacancy</th>
                            <th style="min-width: 150px;">Interviewer</th>
                            <th style="width: 150px;">Scheduled Date</th>
                            <th style="width: 120px;">Type</th>
                            <th style="width: 120px;">Category</th>
                            <th style="width: 100px;">Status</th>
                            <th style="width: 100px;">Result</th>
                            <th style="min-width: 200px;">Note</th>
                            <th style="width: 100px;" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Interviews.Any())
                        {
                            int index = (Model.Page - 1) * Model.PageSize;
                            foreach (var interview in Model.Interviews)
                            {
                                index++;
                                <tr>
                                    <td>@index</td>
                                    <td>
                                        <div class="fw-semibold">@interview.ApplicantName</div>
                                    </td>
                                    <td>@interview.VacancyTitle</td>
                                    <td>@interview.InterViewer</td>
                                    <td>@interview.ScheduledDate.ToString("MMM dd, yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge-component badge-default">@interview.InterviewType</span>
                                    </td>
                                    <td>
                                        <span class="badge-component badge-secondary">@interview.InterviewCategory</span>
                                    </td>
                                    <td>
                                        @{
                                            var statusClass = interview.InterviewStatus == "Completed" ? "badge-success" : 
                                                             interview.InterviewStatus == "Scheduled" ? "badge-warning" :
                                                             interview.InterviewStatus == "Cancelled" ? "badge-destructive" :
                                                             "badge-default";
                                        }
                                        <span class="badge-component @statusClass">@interview.InterviewStatus</span>
                                    </td>
                                    <td>
                                        @if (interview.InterviewResult != null)
                                        {
                                            var resultClass = interview.InterviewResult.ToString() == "Passed" ? "badge-success" : 
                                                             interview.InterviewResult.ToString() == "Failed" ? "badge-destructive" :
                                                             "badge-warning";
                                            <span class="badge-component @resultClass">@interview.InterviewResult</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(interview.InterViewNote))
                                        {
                                            <span title="@interview.InterViewNote">@(interview.InterViewNote.Length > 50 ? interview.InterViewNote.Substring(0, 50) + "..." : interview.InterViewNote)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a href="@Url.Action("Details", "Interview", new { id = interview.Id })" 
                                           class="btn-component btn-sm btn-outline"
                                           title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="11" class="text-center py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
                                    <div class="text-muted">No interviews found</div>
                                    <a href="/Interview/Index" class="btn-component btn-outline mt-3">Clear Filters</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalCount > Model.PageSize)
    {
        int totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);
        <div class="card-footer">
            <nav class="pagination-component" aria-label="Pagination">
                <a class="pagination-button @(Model.Page == 1 ? "disabled" : "")"
                   href="?search=@Model.Search&page=@(Model.Page - 1)&pageSize=@Model.PageSize">
                    <i class="bi bi-chevron-left"></i>
                </a>

                @{
                    int startPage = Math.Max(1, Model.Page - 2);
                    int endPage = Math.Min(totalPages, Model.Page + 2);
                }

                @if (startPage > 1)
                {
                    <a class="pagination-button" href="?search=@Model.Search&page=1&pageSize=@Model.PageSize">1</a>
                    @if (startPage > 2)
                    {
                        <span class="pagination-button disabled">...</span>
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a class="pagination-button @(Model.Page == i ? "active" : "")"
                       href="?search=@Model.Search&page=@i&pageSize=@Model.PageSize">
                        @i
                    </a>
                }

                @if (endPage < totalPages)
                {
                    @if (endPage < totalPages - 1)
                    {
                        <span class="pagination-button disabled">...</span>
                    }
                    <a class="pagination-button" href="?search=@Model.Search&page=@totalPages&pageSize=@Model.PageSize">@totalPages</a>
                }

                <a class="pagination-button @(Model.Page == totalPages ? "disabled" : "")"
                   href="?search=@Model.Search&page=@(Model.Page + 1)&pageSize=@Model.PageSize">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </nav>

            <div class="text-center mt-3 text-muted small">
                Showing @((Model.Page - 1) * Model.PageSize + 1) to @Math.Min(Model.Page * Model.PageSize, Model.TotalCount) of @Model.TotalCount results
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Show toast notifications
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            showToast('@TempData["SuccessMessage"]', 'success');
            </text>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <text>
            showToast('@TempData["ErrorMessage"]', 'error');
            </text>
        }
    </script>
}
