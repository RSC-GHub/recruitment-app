@using Recruitment.Domain.Enums
@model Recruitment.Web.ViewModels.RecruitmentProcess.Interview.InterviewIndexVM

@{
    ViewData["Title"] = "Interviews";
}

<div class="container py-4">
    <h2 class="mb-4">Interviews</h2>

    <!-- Search -->
    <form method="get" class="row g-3 mb-4 align-items-end">

        <div class="col-md-3">
            <label class="form-label">Search</label>
            <input type="text" name="search" value="@Model.Search"
                   class="form-control" placeholder="Applicant, Vacancy, Interviewer..." />
        </div>

        <div class="col-md-2">
            <label class="form-label">Type</label>
            <select name="type" class="form-select">
                <option value="">-- All Types --</option>
                @foreach (var t in Enum.GetValues(typeof(InterviewType)))
                {
                    var isSelected = Model.Type == (InterviewType)t;
                    <option value="@t" selected="@isSelected">@t</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Result</label>
            <select name="result" class="form-select">
                <option value="">-- All Results --</option>
                @foreach (var r in Enum.GetValues(typeof(InterviewResult)))
                {
                    var isSelected = Model.Result == (InterviewResult)r;
                    <option value="@r" selected="@isSelected">@r</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">From Date</label>
            <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>

        <div class="col-md-2">
            <label class="form-label">To Date</label>
            <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>

        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>

    </form>



    <!-- Interviews Table -->
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Applicant</th>
                    <th>Vacancy</th>
                    <th>Interviewer</th>
                    <th>Scheduled Date</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Result</th>
                    <th>Note</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Interviews.Any())
                {
                    int index = (Model.Page - 1) * Model.PageSize;
                    foreach (var interview in Model.Interviews)
                    {
                        index++;
                        <tr style="cursor:pointer;" onclick="window.location.href='@Url.Action("Details", "Interview", new { id = interview.Id })'">
                            <td>@index</td>
                            <td>@interview.ApplicantName</td>
                            <td>@interview.VacancyTitle</td>
                            <td>@interview.InterViewer</td>
                            <td>@interview.ScheduledDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@interview.InterviewType</td>
                            <td>@interview.InterviewStatus</td>
                            <td>@(interview.InterviewResult.ToString() ?? "-")</td>
                            <td>@interview.InterViewNote</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center">No interviews found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalCount > Model.PageSize)
    {
        int totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);
        <nav>
            <ul class="pagination">
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link" href="?search=@Model.Search&page=@(Model.Page - 1)&pageSize=@Model.PageSize">Previous</a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(Model.Page == i ? "active" : "")">
                        <a class="page-link" href="?search=@Model.Search&page=@i&pageSize=@Model.PageSize">@i</a>
                    </li>
                }

                <li class="page-item @(Model.Page == totalPages ? "disabled" : "")">
                    <a class="page-link" href="?search=@Model.Search&page=@(Model.Page + 1)&pageSize=@Model.PageSize">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>
