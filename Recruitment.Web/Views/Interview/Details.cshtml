@using Recruitment.Domain.Enums
@model Recruitment.Web.ViewModels.RecruitmentProcess.Interview.InterviewDetailVM

@{
    ViewData["Title"] = "Interview Details";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container py-4">
    <h2 class="mb-4">Interview Details</h2>
    <div class="d-flex justify-content-end">
        <div class="btn-group">

            @if (Model.InterviewResult != InterviewResult.Accepted && Model.InterviewStatus != InterviewStatus.Cancelled)
            {
                <button type="button" class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#editInterviewModal">
                    <i class="bi bi-pencil"></i> Edit Interview
                </button>
                <button type="button" class="btn btn-success mb-3" data-bs-toggle="modal" data-bs-target="#CompeleteInterviewModal">
                    <i class="bi bi-check-lg"></i> Mark As Complete
                </button>
            }

        </div>
    </div>


    <div class="row g-3">
        <!-- Applicant & Vacancy Info -->
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-primary text-white">Applicant Information</div>
                <div class="card-body">
                    <p><strong>Name: </strong><a asp-action="Profile" asp-controller="Applicant" asp-route-id="@Model.ApplicantId"> @Model.ApplicantName</a></p>
                    <p><strong>Email:</strong> @Model.ApplicantEmail</p>
                    <p><strong>Phone:</strong> @Model.PhoneNumber</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-success text-white">Vacancy Information</div>
                <div class="card-body">
                    <p><strong>Title:</strong> @Model.VacancyTitle</p>
                    <p><strong>Employment Type:</strong> @Model.EmploymentType</p>

                    <p><strong>Projects:</strong></p>
                    @if (Model.VacancyProjects != null && Model.VacancyProjects.Any())
                    {
                        <ul class="mb-0">
                            @foreach (var project in Model.VacancyProjects)
                            {
                                <li>@project</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p>-</p>
                    }
                </div>
            </div>
        </div>

    </div>

    <!-- Interview Info -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-info text-white">Interview Information</div>
        <div class="card-body">
            <p><strong>Interviewer:</strong> @(Model.InterViewer ?? "-")</p>
            <p><strong>Scheduled Date:</strong> @Model.ScheduledDate.ToString("yyyy-MM-dd HH:mm")</p>
            <p><strong>Type:</strong> @Model.InterviewType</p>
            <p><strong>Status:</strong> @Model.InterviewStatus</p>
            <p><strong>Result:</strong> @Model.InterviewResult</p>
            <p><strong>Duration (minutes):</strong> @Model.DurationMinutes</p>
            <p><strong>Note:</strong> @(Model.InterViewNote ?? "-")</p>
            <p><strong>Feedback:</strong> @(Model.Feedback ?? "-")</p>
        </div>
    </div>

    <!-- Audit Info -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-secondary text-white">Audit Information</div>
        <div class="card-body">
            <p><strong>Created By:</strong> @(Model.CreatedBy ?? "-")</p>
            <p><strong>Created On:</strong> @Model.CreatedOn.ToString("yyyy-MM-dd HH:mm")</p>
            <p><strong>Modified By:</strong> @(Model.ModifiedBy ?? "-")</p>
            <p><strong>Modified On:</strong> @(Model.ModifiedOn?.ToString("yyyy-MM-dd HH:mm") ?? "-")</p>
        </div>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Index", "Interview")" class="btn btn-secondary">Back to List</a>
    </div>
</div>

<!-- Edit Interview Modal -->
<div class="modal fade" id="editInterviewModal" tabindex="-1" aria-labelledby="editInterviewModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="editInterviewForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="editInterviewModalLabel">Edit Interview</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="InterviewId" name="Id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label">Interviewer</label>
                        <input type="text" class="form-control" id="InterViewer" name="InterViewer" value="@Model.InterViewer" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Scheduled Date</label>
                        <input type="datetime-local" class="form-control" id="ScheduledDate" name="ScheduledDate" value="@Model.ScheduledDate.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Type</label>
                        <select class="form-select" id="InterviewType" name="InterviewType">
                            <option value="Technical" selected=@(Model.InterviewType == InterviewType.Technical ? "selected" : "")>Technical</option>
                            <option value="HR" selected=@(Model.InterviewType == InterviewType.HR ? "selected" : "")>HR</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select class="form-select" id="InterviewStatus" name="InterviewStatus">
                            <option value="Postponed" selected=@(Model.InterviewStatus == InterviewStatus.Postponed ? "selected" : "")>Postponed</option>
                            <option value="Cancelled" selected=@(Model.InterviewStatus == InterviewStatus.Cancelled ? "selected" : "")>Cancelled</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Duration (minutes)</label>
                        <input type="number" class="form-control" id="DurationMinutes" name="DurationMinutes" value="@Model.DurationMinutes" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Note</label>
                        <textarea class="form-control" id="InterviewNote" name="InterviewNote">@Model.InterViewNote</textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Feedback</label>
                        <textarea class="form-control" id="Feedback" name="Feedback">@Model.Feedback</textarea>
                    </div>

                    <div id="editInterviewError" class="text-danger"></div>
                    <div id="editInterviewSuccess" class="text-success"></div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Mark Interview as Complete Modal -->
<div class="modal fade" id="CompeleteInterviewModal" tabindex="-1" aria-labelledby="completeInterviewLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="completeInterviewForm">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title">Mark Interview as Complete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" name="Id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label">Result</label>
                        <select class="form-select" name="InterviewResult" required>
                            <option value="">-- Select Result --</option>
                            <option value="Accepted">Accepted</option>
                            <option value="Rejected">Rejected</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Feedback</label>
                        <textarea class="form-control" name="Feedback"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Note</label>
                        <textarea class="form-control" name="Note"></textarea>
                    </div>

                    <div id="completeInterviewError" class="text-danger"></div>
                    <div id="completeInterviewSuccess" class="text-success"></div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-success">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('editInterviewForm').addEventListener('submit', function(e) {
            e.preventDefault();

            var form = e.target;
            var formData = new FormData(form);

            fetch('@Url.Action("UpdateInterview", "Interview")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('editInterviewSuccess').innerText = data.message;
                    document.getElementById('editInterviewError').innerText = '';
                    setTimeout(() => location.reload(), 1000);
                } else {
                    document.getElementById('editInterviewError').innerText = data.message;
                    document.getElementById('editInterviewSuccess').innerText = '';
                }
            })
            .catch(err => {
                console.error(err);
                document.getElementById('editInterviewError').innerText = 'An error occurred';
            });
        });

        // Mark As Complete Modal
                document.getElementById('completeInterviewForm').addEventListener('submit', function (e) {
            e.preventDefault();

            var form = e.target;
            var formData = new FormData(form);

            fetch('@Url.Action("UpdateInterviewResult", "Interview")', {
                method: 'POST',
                body: formData
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('completeInterviewSuccess').innerText = data.message;
                        document.getElementById('completeInterviewError').innerText = '';

                        setTimeout(() => location.reload(), 1000);
                    } else {
                        document.getElementById('completeInterviewError').innerText = data.message;
                        document.getElementById('completeInterviewSuccess').innerText = '';
                    }
                })
                .catch(err => {
                    console.error(err);
                    document.getElementById('completeInterviewError').innerText = 'An error occurred.';
                });
        });


    </script>
}