@{
    ViewData["Title"] = "Setup";
}

<div>
    <div class="mb-4">
        <h2 class="card-title d-flex align-items-center gap-2">
            <i class="bi bi-gear-fill"></i>
            System Setup
        </h2>
        <p class="card-description">Configure system settings and data</p>
    </div>

    <div class="row g-4">

        <!-- Country -->
        <div class="col-md-4">
            <a asp-controller="Country" asp-action="Index" class="text-decoration-none">
                <div class="card-component setup-card">
                    <div class="card-content text-center">
                        <i class="bi bi-globe2 setup-color fs-1 text-primary mb-3 d-block"></i>
                        <h5 class="card-title setup-color">Country</h5>
                        <p class="card-description">Manage countries and regions</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Location -->
        <div class="col-md-4">
            <a asp-controller="Location" asp-action="Index" class="text-decoration-none">
                <div class="card-component setup-card">
                    <div class="card-content text-center">
                        <i class="bi bi-geo-alt-fill fs-1 setup-color text-primary mb-3 d-block"></i>
                        <h5 class="card-title setup-color">Location</h5>
                        <p class="card-description">Manage office locations</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Department -->
        <div class="col-md-4">
            <a asp-controller="Department" asp-action="Index" class="text-decoration-none">
                <div class="card-component setup-card">
                    <div class="card-content text-center">
                        <i class="bi bi-building fs-1 setup-color text-primary mb-3 d-block"></i>
                        <h5 class="card-title setup-color">Department</h5>
                        <p class="card-description">Manage departments</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Title -->
        <div class="col-md-4">
            <a asp-controller="Title" asp-action="Index" class="text-decoration-none">
                <div class="card-component setup-card">
                    <div class="card-content text-center">
                        <i class="bi bi-card-heading fs-1 setup-color text-primary mb-3 d-block"></i>
                        <h5 class="card-title setup-color">Job Titles</h5>
                        <p class="card-description">Manage job titles and positions</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Project -->
        <div class="col-md-4">
            <a asp-controller="Project" asp-action="Index" class="text-decoration-none">
                <div class="card-component setup-card">
                    <div class="card-content text-center">
                        <i class="bi bi-folder-fill fs-1 setup-color text-primary mb-3 d-block"></i>
                        <h5 class="card-title setup-color">Projects</h5>
                        <p class="card-description">Manage projects and assignments</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Currency -->
        <div class="col-md-4">
            <a asp-controller="Currency" asp-action="Index" class="text-decoration-none">
                <div class="card-component setup-card">
                    <div class="card-content text-center">
                        <i class="bi bi-cash-coin fs-1 setup-color text-primary mb-3 d-block"></i>
                        <h5 class="card-title setup-color">Currency</h5>
                        <p class="card-description">Manage currencies and exchange rates</p>
                    </div>
                </div>
            </a>
        </div>

    </div>
</div>

<style>
    .setup-card {
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .setup-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.12);
    }

    .setup-card:hover .bi {
        transform: scale(1.1);
        transition: transform 0.3s ease;
    }

    .setup-color {
        color: hsl(202 80.3% 23.9%) !important;
    }

</style>
