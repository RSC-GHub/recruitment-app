@model ErrorViewModel
@inject IWebHostEnvironment Env

@{
    ViewData["Title"] = "Error";
}

<div class="min-h-screen flex items-center justify-center bg-background px-4">
    <div class="w-full max-w-lg">
        <div class="rounded-2xl border border-border bg-card shadow-lg">

            <!-- Header -->
            <div class="flex items-center gap-3 border-b border-border px-6 py-4">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-destructive/10">
                    <svg class="h-5 w-5 text-destructive" fill="none" stroke="currentColor" stroke-width="2"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                    </svg>
                </div>

                <div>
                    <h1 class="text-lg font-semibold text-foreground">
                        Something went wrong
                    </h1>
                    <p class="text-sm text-muted-foreground">
                        An unexpected error has occurred
                    </p>
                </div>
            </div>

            <!-- Content -->
            <div class="px-6 py-5 space-y-4">
                <p class="text-sm text-foreground">
                    @Model.Message
                </p>

                @if (Env.IsDevelopment())
                {
                    <div class="rounded-lg bg-destructive/5 border border-destructive/20 p-4">
                        <p class="text-xs font-medium text-destructive mb-2">
                            Error details (Development only)
                        </p>
                        <pre class="text-xs text-destructive whitespace-pre-wrap">
                            @Model.Details
                            </pre>
                    </div>
                }

                <p class="text-xs text-muted-foreground">
                    Trace ID: <span class="font-mono">@Model.TraceId</span>
                </p>
            </div>

            <!-- Footer -->
            <div class="flex justify-end gap-2 border-t border-border px-6 py-4">
                <a asp-controller="Home"
                   asp-action="Index"
                   class="inline-flex items-center justify-center rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition">
                    Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
