@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h1 class="page-title">Dashboard</h1>
    <p class="page-breadcrumb">Welcome to the Recruitment Management System</p>
</div>

<div class="row" style="margin: 0;">
    <div class="col-md-3" style="margin-bottom: 1.5rem;">
        <div class="card" style="border-left: 4px solid var(--rsc-teal);">
            <div class="card-body">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <p style="color: var(--font-color-1); font-size: 0.85rem; margin: 0; margin-bottom: 0.5rem;">Total Users</p>
                        <h3 style="margin: 0; font-size: 1.75rem; color: var(--rsc-teal);">--</h3>
                    </div>
                    <div style="width: 50px; height: 50px; background: rgba(52, 101, 109, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                        👥
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3" style="margin-bottom: 1.5rem;">
        <div class="card" style="border-left: 4px solid var(--rsc-sand);">
            <div class="card-body">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <p style="color: var(--font-color-1); font-size: 0.85rem; margin: 0; margin-bottom: 0.5rem;">Departments</p>
                        <h3 style="margin: 0; font-size: 1.75rem; color: var(--rsc-sand);">--</h3>
                    </div>
                    <div style="width: 50px; height: 50px; background: rgba(220, 190, 83, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                        🏢
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3" style="margin-bottom: 1.5rem;">
        <div class="card" style="border-left: 4px solid #28a745;">
            <div class="card-body">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <p style="color: var(--font-color-1); font-size: 0.85rem; margin: 0; margin-bottom: 0.5rem;">Projects</p>
                        <h3 style="margin: 0; font-size: 1.75rem; color: #28a745;">--</h3>
                    </div>
                    <div style="width: 50px; height: 50px; background: rgba(40, 167, 69, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                        📁
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3" style="margin-bottom: 1.5rem;">
        <div class="card" style="border-left: 4px solid #17a2b8;">
            <div class="card-body">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <p style="color: var(--font-color-1); font-size: 0.85rem; margin: 0; margin-bottom: 0.5rem;">Vacancies</p>
                        <h3 style="margin: 0; font-size: 1.75rem; color: #17a2b8;">--</h3>
                    </div>
                    <div style="width: 50px; height: 50px; background: rgba(23, 162, 184, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                        📊
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row" style="margin: 0;">
    <div class="col-md-8" style="margin-bottom: 1.5rem;">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Welcome to Recruitment Management System</h5>
            </div>
            <div class="card-body">
                <p style="color: var(--body-text-color); line-height: 1.6;">
                    This system helps you manage your recruitment process efficiently. Use the sidebar to navigate through different modules:
                </p>
                <ul style="color: var(--body-text-color); line-height: 1.8;">
                    <li><strong>User Management:</strong> Manage users, permissions, and roles</li>
                    <li><strong>Setup:</strong> Configure countries, locations, departments, titles, and projects</li>
                    <li><strong>System Tracking:</strong> Track vacancies and recruitment progress</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-4" style="margin-bottom: 1.5rem;">
        <div class="card" style="background: linear-gradient(135deg, var(--rsc-teal) 0%, var(--rsc-dark-green) 100%); color: white; border: none;">
            <div class="card-body">
                <h5 style="color: white; margin-bottom: 1rem;">Quick Actions</h5>
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <a href="@Url.Action("Index", "UserManagement")" class="btn" style="background: rgba(255,255,255,0.2); color: white; justify-content: flex-start;">
                        <span>👥</span>
                        <span>Manage Users</span>
                    </a>
                    <a href="@Url.Action("Index", "Department")" class="btn" style="background: rgba(255,255,255,0.2); color: white; justify-content: flex-start;">
                        <span>🏢</span>
                        <span>Manage Departments</span>
                    </a>
                    <a href="@Url.Action("Index", "Vacancy")" class="btn" style="background: rgba(255,255,255,0.2); color: white; justify-content: flex-start;">
                        <span>📊</span>
                        <span>View Vacancies</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
