@using Recruitment.Web.ViewModels.Report
@using System.Data
@model ReportResultViewModel
@{
    ViewData["Title"] = "Report Result";
}
<!-- Page Header -->
<div class="flex-between mb-4">
    <div>
        <h2 class="card-title d-flex align-items-center gap-2">
            <i class="bi bi-bar-chart-fill"></i>
            @Model.Report.Name
        </h2>
        <p class="card-description">Report data generated from database</p>
    </div>
    <div>
        <a href="@Url.Action("ExportReport", "Reports", new { reportId = Model.Report.Id })"
           class="btn-component btn-outline">
            <i class="bi bi-file-earmark-excel-fill me-2"></i>
            Export Excel
        </a>
    </div>
</div>

<!-- Scroll Indicator -->
<div class="mb-2 text-muted small">
    <i class="bi bi-arrow-left-right"></i> Scroll horizontally to view all columns
</div>

<!-- Report Table Card -->
<div class="card-component">
    <div class="card-content p-0">
        <div class="table-wrapper">
            <div class="table-responsive" id="tableScroll">
                <table class="table table-striped table-bordered table-hover mb-0" style="min-width: 100%;">
                    <thead class="table-light">
                        <tr>
                            @foreach (DataColumn col in Model.Data.Columns)
                            {
                                <th class="text-nowrap px-3">@col.ColumnName</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Data.Rows.Count > 0)
                        {
                            @foreach (DataRow row in Model.Data.Rows)
                            {
                                <tr>
                                    @foreach (var item in row.ItemArray)
                                    {
                                        <td class="text-nowrap px-3">@Html.Raw(item)</td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@Model.Data.Columns.Count" class="text-center py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
                                    <div class="text-muted">No data available for this report</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table-wrapper {
        position: relative;
    }

    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        position: relative;
        box-shadow: inset -15px 0 15px -15px rgba(0,0,0,0.15);
        transition: box-shadow 0.3s ease;
    }

        .table-responsive.scrolled-right {
            box-shadow: inset 15px 0 15px -15px rgba(0,0,0,0.15);
        }

        .table-responsive.scrolled-middle {
            box-shadow: inset 15px 0 15px -15px rgba(0,0,0,0.15), inset -15px 0 15px -15px rgba(0,0,0,0.15);
        }

        /* تحسين شكل الـ scrollbar */
        .table-responsive::-webkit-scrollbar {
            height: 12px;
        }

        .table-responsive::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .table-responsive::-webkit-scrollbar-thumb {
            background: #c1c1c1; 
            border-radius: 10px;
        }

            .table-responsive::-webkit-scrollbar-thumb:hover {
                background: #a8a8a8; 
            }

    .table th.text-nowrap,
    .table td.text-nowrap {
        white-space: nowrap;
    }

    .table th,
    .table td {
        vertical-align: middle;
    }
</style>

<script>

    document.addEventListener('DOMContentLoaded', function() {
        const tableScroll = document.getElementById('tableScroll');

        if (tableScroll) {
            tableScroll.addEventListener('scroll', function() {
                const scrollLeft = this.scrollLeft;
                const maxScroll = this.scrollWidth - this.clientWidth;

                this.classList.remove('scrolled-right', 'scrolled-middle');

                if (scrollLeft === 0) {
                    // default state
                } else if (scrollLeft >= maxScroll - 1) {

                    this.classList.add('scrolled-right');
                } else {

                    this.classList.add('scrolled-middle');
                }
            });
        }
    });
</script>