@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyViewModel

<h2>Vacancy Details</h2>

<div>
    <h4>@Model.TitleName</h4>
    <p><strong>Job Description:</strong> @Model.JobDescription</p>
    <p><strong>Requirements:</strong> @Model.Requirements</p>
    <p><strong>Responsibilities:</strong> @Model.Responsibilities</p>
    <p><strong>Benefits:</strong> @Model.Benefits</p>
    <p><strong>Position Count:</strong> @Model.PositionCount</p>
    <p><strong>Employment Type:</strong> @Model.EmploymentType</p>
    <p><strong>Salary Range:</strong> @Model.SalaryRangeMin - @Model.SalaryRangeMax</p>
    <p><strong>Status:</strong> @Model.Status</p>
    <p><strong>Deadline:</strong> @Model.Deadline?.ToShortDateString()</p>
    <p><strong>Projects:</strong> @string.Join(", ", Model.ProjectNames ?? new List<string>())</p>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
