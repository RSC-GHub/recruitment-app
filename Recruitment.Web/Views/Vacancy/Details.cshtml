@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyDetailsVM

@{
    ViewData["Title"] = "Vacancy Details";
}

<h2>Vacancy Details</h2>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Vacancy</a>

    <!-- Delete Button -->
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this vacancy?');">
        <button type="submit" class="btn btn-danger">Delete Vacancy</button>
    </form>
</div>

<div class="card">
    <div class="card-body">
        <h4 class="card-title">@Model.TitleName</h4>
        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Positions:</strong> @Model.PositionCount</p>
        <p><strong>Employment Type:</strong> @Model.EmploymentType</p>
        <p>
            <strong>Salary Range:</strong>
            @if (Model.SalaryRangeMin.HasValue && Model.SalaryRangeMax.HasValue)
            {
                @($"{Model.SalaryRangeMin:C} - {Model.SalaryRangeMax:C}")
            }
            else
            {
                <span>-</span>
            }
        </p>
        <p><strong>Deadline:</strong> @(Model.Deadline?.ToString("yyyy-MM-dd") ?? "-")</p>

        <hr />
        <h5>Job Description</h5>
        <p>@Model.JobDescription</p>

        <h5>Requirements</h5>
        <p>@Model.Requirements</p>

        <h5>Responsibilities</h5>
        <p>@Model.Responsibilities</p>

        <h5>Benefits</h5>
        <p>@Model.Benefits</p>

        <h5>Projects</h5>
        @if (Model.ProjectNames != null && Model.ProjectNames.Any())
        {
            <div>
                @foreach (var project in Model.ProjectNames)
                {
                    <span class="badge bg-info text-dark me-1">@project</span>
                }
            </div>
        }
        else
        {
            <p>-</p>
        }
    </div>
</div>
