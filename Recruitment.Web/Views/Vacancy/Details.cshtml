@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyDetailsVM

@{
    ViewData["Title"] = "Vacancy Details";
}

<div class="card-component">
    <div class="card-header flex-between">
        <h2 class="card-title"><i class="bi bi-briefcase-fill me-2"></i>Vacancy Details</h2>
        <div class="btn-group">
            <a asp-action="Index" class="button-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>

            <a asp-action="Edit" asp-route-id="@Model.Id" class="button-primary">
                <i class="bi bi-pencil"></i> Edit
            </a>

            <a asp-action="GetSubmissions" asp-route-vacancyId="@Model.Id" class="button-outline">
                <i class="bi bi-file-earmark-text"></i> View Submissions
            </a>


            @if (Model.Status == "Open")
            {
                <a asp-action="AssignApplicant" asp-route-id="@Model.Id"
                   class="button-outline" data-bs-toggle="modal" data-bs-target="#assignApplicantModal">
                    <i class="bi bi-person-plus"></i> Assign Applicant
                </a>
            }

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Are you sure you want to delete this vacancy?');">
                <button type="submit" class="button-destructive">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>

    <!-- MAIN CARD -->
    <div class="card shadow-lg border-0">
        <div class="card-body p-4">

            <!-- TITLE -->
            <h3 class="fw-bold mb-4 text-dark">
                @Model.TitleName
            </h3>

            <!-- QUICK INFO -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <strong class="text-muted">Status</strong><br />
                        <span class="fw-semibold">@Model.Status</span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <strong class="text-muted">Positions</strong><br />
                        <span class="fw-semibold">@Model.PositionCount</span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <strong class="text-muted">Employment Type</strong><br />
                        <span class="fw-semibold">@Model.EmploymentType</span>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="p-3 border rounded bg-light">
                        <strong class="text-muted">Salary Range</strong><br />
                        @if (Model.SalaryRangeMin.HasValue && Model.SalaryRangeMax.HasValue)
                        {
                            <span class="fw-semibold text-success">
                                @($"{Model.SalaryRangeMin:C} - {Model.SalaryRangeMax:C}")
                            </span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 border rounded bg-light">
                        <strong class="text-muted">Deadline</strong><br />
                        <span class="fw-semibold">
                            @(Model.Deadline?.ToString("yyyy-MM-dd") ?? "-")
                        </span>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <!-- DETAILS SECTIONS -->
            <div class="mb-4">
                <h5 class="fw-bold text-primary">Job Description</h5>
                <p class="text-secondary">@Model.JobDescription</p>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold text-primary">Requirements</h5>
                <p class="text-secondary">@Model.Requirements</p>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold text-primary">Responsibilities</h5>
                <p class="text-secondary">@Model.Responsibilities</p>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold text-primary">Benefits</h5>
                <p class="text-secondary">@Model.Benefits</p>
            </div>

            <!-- PROJECTS -->
            <div class="mb-4">
                <h5 class="fw-bold text-primary">Projects</h5>

                @if (Model.ProjectNames != null && Model.ProjectNames.Any())
                {
                    <div class="d-flex flex-wrap">
                        @foreach (var project in Model.ProjectNames)
                        {
                            <span class="badge bg-info text-dark me-2 mb-2 p-2 rounded-pill">
                                <i class="bi bi-folder2-open"></i> @project
                            </span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">-</p>
                }
            </div>

            <hr />

            <!-- AUDIT -->
            <div class="mt-4">
                <h5 class="fw-bold text-primary">Audit Information</h5>

                <div class="row g-3">
                    <div class="col-md-6">
                        <strong class="text-muted">Created By</strong><br />
                        @Model.CreatedBy
                    </div>

                    <div class="col-md-6">
                        <strong class="text-muted">Created On</strong><br />
                        @Model.CreatedOn.ToString("yyyy-MM-dd HH:mm")
                    </div>

                    <div class="col-md-6">
                        <strong class="text-muted">Modified By</strong><br />
                        @Model.ModifiedBy
                    </div>

                    <div class="col-md-6">
                        <strong class="text-muted">Modified On</strong><br />
                        @(Model.ModifiedOn?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
<!-- Assign Applicant Modal -->
<div class="modal fade" id="assignApplicantModal" tabindex="-1" aria-labelledby="assignApplicantModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="assignApplicantForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="assignApplicantModalLabel">Assign Applicant</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="VacancyId" name="VacancyId" value="@Model.Id" />

                    <div class="mb-3">
                        <label for="SelectedApplicantId" class="form-field-label">Select Applicant</label><span class="text-danger"> *</span>
                        <select id="SelectedApplicantId" name="SelectedApplicantId" class="form-field-select">
                            <option value="">-- Select Applicant --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="Note" class="form-field-label">Note</label>
                        <textarea id="Note" name="Note" class="form-field-input" rows="3"></textarea>
                    </div>

                    <div id="assignApplicantError" class="text-danger"></div>
                    <div id="assignApplicantSuccess" class="text-success"></div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="button-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="button-primary">Assign</button>
                </div>
            </form>
        </div>
    </div>
    </div>
</div>
@section Scripts {
    <script>
        var assignModal = document.getElementById('assignApplicantModal');
               assignModal.addEventListener('show.bs.modal', function (event) {
            var select = document.getElementById('SelectedApplicantId');
            select.innerHTML = '<option value="">Loading...</option>';

            fetch('/Vacancy/GetAllApplicants')
                .then(response => response.json())
                .then(data => {
                    select.innerHTML = '<option value="">-- Select Applicant --</option>';
                    data.forEach(a => {
                        var opt = document.createElement('option');
                        opt.value = a.id;
                        opt.text = a.name + ' (' + (a.currentJob || '-') + ')';
                        select.appendChild(opt);
                    });

                    // Init Select2 with search
                    $(select).select2({
                        dropdownParent: $('#assignApplicantModal'),
                        width: '100%',
                        placeholder: '-- Select Applicant --'
                    });
                })
                .catch(err => {
                    select.innerHTML = '<option value="">Error loading applicants</option>';
                });
        });

    </script>

    <script>
                document.getElementById('assignApplicantForm').addEventListener('submit', function (e) {
            e.preventDefault();

            var vacancyId = document.getElementById('VacancyId').value;
            var selectedApplicantId = document.getElementById('SelectedApplicantId').value;
            var note = document.getElementById('Note').value;

            if (!selectedApplicantId) {
                document.getElementById('assignApplicantError').innerText = 'Please select an applicant';
                return;
            }

            fetch('/Vacancy/AssignApplicant', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    VacancyId: parseInt(vacancyId),
                    SelectedApplicantId: parseInt(selectedApplicantId),
                    Note: note // <-- explicitly send Note
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('assignApplicantSuccess').innerText = data.message;
                    document.getElementById('assignApplicantError').innerText = '';
                    setTimeout(() => location.reload(), 1000);
                } else {
                    document.getElementById('assignApplicantError').innerText = data.message;
                    document.getElementById('assignApplicantSuccess').innerText = '';
                }
            })
            .catch(err => {
                document.getElementById('assignApplicantError').innerText = 'An error occurred';
            });
        });

    </script>
}
