@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyDetailsVM

@{
    ViewData["Title"] = "Vacancy Details";
}

<div class="card-component">
    <div class="card-header flex-between">
        <h2 class="card-title"><i class="bi bi-briefcase-fill me-2"></i>Vacancy Details</h2>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn-component btn-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>

            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-component btn-primary">
                <i class="bi bi-pencil me-1"></i> Edit
            </a>

            <a asp-action="GetSubmissions" asp-route-vacancyId="@Model.Id" class="btn-component btn-outline">
                <i class="bi bi-file-earmark-text me-1"></i> View Submissions
            </a>

            @if (Model.Status == "Open")
            {
                <button type="button"
                        class="btn-component btn-outline"
                        data-bs-toggle="modal"
                        data-bs-target="#assignApplicantModal">
                    <i class="bi bi-person-plus me-1"></i> Assign Applicant
                </button>
            }

            <button type="button"
                    class="btn-component btn-destructive"
                    data-bs-toggle="modal"
                    data-bs-target="#deleteVacancyModal">
                <i class="bi bi-trash me-1"></i> Delete
            </button>
        </div>
    </div>

    <!-- MAIN CARD -->
    <div class="card-component mt-4">
        <div class="card-content">

            <!-- TITLE -->
            <h3 class="fw-bold mb-4" style="color: hsl(222, 47%, 45%); font-size: 1.5rem;">
                @Model.TitleName
            </h3>

            <!-- QUICK INFO -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card-stat-box">
                        <strong class="card-stat-label">Status</strong>
                        <span class="badge-component @(Model.Status == "Open" ? "badge-success" : "badge-secondary")" style="font-size: 0.875rem;">
                            @Model.Status
                        </span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-stat-box">
                        <strong class="card-stat-label">Positions</strong>
                        <span class="card-stat-value">@Model.PositionCount</span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-stat-box">
                        <strong class="card-stat-label">Employment Type</strong>
                        <span style="font-size: 1rem; font-weight: 600;">@Model.EmploymentType</span>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="card-stat-box">
                        <strong class="card-stat-label">Salary Range</strong>
                        @if (Model.SalaryRangeMin.HasValue && Model.SalaryRangeMax.HasValue)
                        {
                            <span style="color: hsl(142, 76%, 36%); font-size: 1rem; font-weight: 600;">
                                @($"{Model.SalaryRangeMin:C} - {Model.SalaryRangeMax:C}")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">Not specified</span>
                        }
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card-stat-box">
                        <strong class="card-stat-label">Deadline</strong>
                        <span style="font-size: 1rem; font-weight: 600;">
                            @(Model.Deadline?.ToString("MMMM dd, yyyy") ?? "No deadline")
                        </span>
                    </div>
                </div>
            </div>

            <div class="field-separator"></div>

            <!-- DETAILS SECTIONS -->
            <div class="mb-4">
                <h5 class="fw-bold mb-2" style="color: hsl(222, 47%, 45%); font-size: 1.125rem;">
                    <i class="bi bi-file-text me-2"></i>Job Description
                </h5>
                <p class="text-secondary" style="line-height: 1.6;">@Html.Raw(@Model.JobDescription)</p>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold mb-2" style="color: hsl(222, 47%, 45%); font-size: 1.125rem;">
                    <i class="bi bi-list-check me-2"></i>Requirements
                </h5>
                <p class="text-secondary" style="line-height: 1.6;">@Html.Raw(@Model.Requirements)</p>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold mb-2" style="color: hsl(222, 47%, 45%); font-size: 1.125rem;">
                    <i class="bi bi-clipboard-check me-2"></i>Responsibilities
                </h5>
                <p class="text-secondary" style="line-height: 1.6;">@Html.Raw(@Model.Responsibilities)</p>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold mb-2" style="color: hsl(222, 47%, 45%); font-size: 1.125rem;">
                    <i class="bi bi-gift me-2"></i>Benefits
                </h5>
                <p class="text-secondary" style="line-height: 1.6;">@Html.Raw(@Model.Benefits)</p>
            </div>

            <!-- PROJECTS -->
            <div class="mb-4">
                <h5 class="fw-bold mb-2" style="color: hsl(222, 47%, 45%); font-size: 1.125rem;">
                    <i class="bi bi-folder2-open me-2"></i>Projects
                </h5>

                @if (Model.ProjectNames != null && Model.ProjectNames.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var project in Model.ProjectNames)
                        {
                            <span class="badge-component badge-secondary" style="font-size: 0.875rem; padding: 0.5rem 1rem;">
                                <i class="bi bi-folder2-open me-1"></i> @project
                            </span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">No projects assigned</p>
                }
            </div>

            <div class="field-separator"></div>

            <!-- AUDIT -->
            <div class="mt-4">
                <h5 class="fw-bold mb-3" style="color: hsl(222, 47%, 45%); font-size: 1.125rem;">
                    <i class="bi bi-clock-history me-2"></i>Audit Information
                </h5>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="field">
                            <span class="field-label">Created By</span>
                            <span class="text-muted">@Model.CreatedBy</span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="field">
                            <span class="field-label">Created On</span>
                            <span class="text-muted">@Model.CreatedOn.ToString("MMMM dd, yyyy 'at' HH:mm")</span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="field">
                            <span class="field-label">Modified By</span>
                            <span class="text-muted">@Model.ModifiedBy</span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="field">
                            <span class="field-label">Modified On</span>
                            <span class="text-muted">@(Model.ModifiedOn?.ToString("MMMM dd, yyyy 'at' HH:mm") ?? "Not modified")</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Delete Vacancy Dialog -->
<div class="modal fade" id="deleteVacancyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background-color: hsl(0, 84%, 97%); border-bottom-color: hsl(0, 84%, 85%);">
                <h5 class="modal-title" style="color: hsl(0, 84%, 40%);">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Are you absolutely sure you want to delete this vacancy? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn-component btn-destructive">
                        <i class="bi bi-trash me-1"></i>Delete Vacancy
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
<!-- Assign Applicant Modal -->
<div class="modal fade" id="assignApplicantModal" tabindex="-1" aria-labelledby="assignApplicantModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="assignApplicantForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="assignApplicantModalLabel">
                        <i class="bi bi-person-plus me-2"></i>Assign Applicant
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="VacancyId" name="VacancyId" value="@Model.Id" />

                    <div class="field-group">
                        <div class="field">
                            <label class="field-label" for="SelectedApplicantId">
                                Select Applicant
                                <span class="text-danger">*</span>
                            </label>
                            <select id="SelectedApplicantId" name="SelectedApplicantId" class="form-field-select">
                                <option value="">-- Select Applicant --</option>
                            </select>
                            <span class="field-description">Choose an applicant to assign to this vacancy</span>
                        </div>

                        <div class="field">
                            <label class="field-label" for="Note">Note</label>
                            <textarea id="Note" name="Note" class="form-field-textarea" rows="3" placeholder="Add any notes or comments..."></textarea>
                            <span class="field-description">Optional notes about this assignment</span>
                        </div>
                    </div>

                    <div id="assignApplicantError" class="field-error mt-3" style="display:none;"></div>
                    <div id="assignApplicantSuccess" class="alert-component alert-success mt-3" style="display:none;"></div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn-component btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Assign
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        var assignModal = document.getElementById('assignApplicantModal');
               assignModal.addEventListener('show.bs.modal', function (event) {
            var select = document.getElementById('SelectedApplicantId');
            select.innerHTML = '<option value="">Loading...</option>';

            fetch('/Vacancy/GetAllApplicants')
                .then(response => response.json())
                .then(data => {
                    select.innerHTML = '<option value="">-- Select Applicant --</option>';
                    data.forEach(a => {
                        var opt = document.createElement('option');
                        opt.value = a.id;
                        opt.text = a.name + ' (' + (a.currentJob || '-') + ')';
                        select.appendChild(opt);
                    });

                    // Init Select2 with search
                    $(select).select2({
                        dropdownParent: $('#assignApplicantModal'),
                        width: '100%',
                        placeholder: '-- Select Applicant --'
                    });
                })
                .catch(err => {
                    select.innerHTML = '<option value="">Error loading applicants</option>';
                });
        });

    </script>

    <script>
                document.getElementById('assignApplicantForm').addEventListener('submit', function (e) {
            e.preventDefault();

            var vacancyId = document.getElementById('VacancyId').value;
            var selectedApplicantId = document.getElementById('SelectedApplicantId').value;
            var note = document.getElementById('Note').value;

            if (!selectedApplicantId) {
                document.getElementById('assignApplicantError').innerText = 'Please select an applicant';
                return;
            }

            fetch('/Vacancy/AssignApplicant', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    VacancyId: parseInt(vacancyId),
                    SelectedApplicantId: parseInt(selectedApplicantId),
                    Note: note // <-- explicitly send Note
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('assignApplicantSuccess').innerText = data.message;
                    document.getElementById('assignApplicantError').innerText = '';
                    setTimeout(() => location.reload(), 1000);
                } else {
                    document.getElementById('assignApplicantError').innerText = data.message;
                    document.getElementById('assignApplicantSuccess').innerText = '';
                }
            })
            .catch(err => {
                document.getElementById('assignApplicantError').innerText = 'An error occurred';
            });
        });

    </script>
}
