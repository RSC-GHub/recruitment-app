@using Recruitment.Domain.Enums
@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyFormViewModel

@{
    ViewData["Title"] = "Edit Vacancy";
}

<h2>Edit Vacancy</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="TitleId" class="form-label">Title</label>
        <select asp-for="TitleId" asp-items="Model.Titles" class="form-select"></select>
    </div>

    <div class="mb-3">
        <label asp-for="JobDescription">Job Description</label>
        <textarea asp-for="JobDescription" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="Requirements"></label>
        <textarea asp-for="Requirements" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="Responsibilities"></label>
        <textarea asp-for="Responsibilities" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="Benefits"></label>
        <textarea asp-for="Benefits" class="form-control"></textarea>
    </div>

    <div class="row mb-3">
        <div class="col">
            <label asp-for="PositionCount">Position Count</label>
            <input asp-for="PositionCount" class="form-control" />
        </div>

        <div class="col">
            <label asp-for="EmploymentType">Employment Type</label>
            <select asp-for="EmploymentType" class="form-select">
                @foreach (var type in Enum.GetValues(typeof(EmploymentType)))
                {
                    <option value="@type" selected="@(type.Equals(Model.EmploymentType))">@type</option>
                }
            </select>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col">
            <label asp-for="SalaryRangeMin">Salary Range Minimum</label>
            <input asp-for="SalaryRangeMin" class="form-control" />
        </div>

        <div class="col">
            <label asp-for="SalaryRangeMax">Salary Range Maximum</label>
            <input asp-for="SalaryRangeMax" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Deadline"></label>
        <input asp-for="Deadline" type="date" class="form-control" />
    </div>

    <hr />

    <h4>Projects</h4>

    <table class="table table-bordered" id="projectsTable">
        <thead>
            <tr>
                <th>Project</th>
                <th>Priority</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Projects.Count; i++)
            {
                <tr>
                    <td>
                        <select asp-for="Projects[@i].ProjectId"
                                asp-items="Model.ProjectList"
                                class="form-select">
                        </select>
                    </td>

                    <td>
                        <select asp-for="Projects[@i].Priority" class="form-select">
                            <option value="0">Low</option>
                            <option value="1">Medium</option>
                            <option value="2">High</option>
                        </select>
                    </td>

                    <td>
                        <button type="button" class="btn btn-danger btn-sm removeRow">X</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button type="button" class="btn btn-secondary mb-3" id="addProjectRow">+ Add Project</button>

    <button type="submit" class="btn btn-primary">Update</button>

</form>

@section Scripts {
    <script>
        let index = @Model.Projects.Count;

        document.getElementById("addProjectRow").addEventListener("click", function () {
            let table = document.querySelector("#projectsTable tbody");

            let row = `
            <tr>
                <td>
                    <select name="Projects[${index}].ProjectId" class="form-select">
                        ${document.querySelector("#projectOptions").innerHTML}
                    </select>
                </td>
                <td>
                    <select name="Projects[${index}].Priority" class="form-select">
                        <option value="0">Low</option>
                        <option value="1">Medium</option>
                        <option value="2">High</option>
                    </select>
                </td>
                <td>
                    <button type="button" class="btn btn-danger btn-sm removeRow">X</button>
                </td>
            </tr>`;

            table.insertAdjacentHTML("beforeend", row);
            index++;
        });

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("removeRow")) {
                e.target.closest("tr").remove();
            }
        });
    </script>

    <select id="projectOptions" class="d-none">
        @foreach (var p in Model.ProjectList)
        {
            <option value="@p.Value">@p.Text</option>
        }
    </select>
}
