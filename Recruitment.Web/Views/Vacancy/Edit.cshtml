@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyEditSectionVM
@using Recruitment.Domain.Enums

<h2>Edit Vacancy</h2>

<form asp-action="UpdateBasic" method="post">
    <input type="hidden" name="VacancyId" value="@Model.VacancyId" />

    <div class="mb-3">
        <label>Title</label>
        <select name="TitleId" class="form-control">
            @foreach (var t in Model.Titles)
            {
                var isSelected = t.Name == Model.TitleName;
                <option value="@t.Id" selected="@isSelected">@t.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Job Description</label>
        <textarea name="JobDescription" class="form-control">@Model.JobDescription</textarea>
    </div>

    <div class="mb-3">
        <label>Requirements</label>
        <textarea name="Requirements" class="form-control">@Model.Requirements</textarea>
    </div>

    <div class="mb-3">
        <label>Responsibilities</label>
        <textarea name="Responsibilities" class="form-control">@Model.Responsibilities</textarea>
    </div>

    <div class="mb-3">
        <label>Benefits</label>
        <textarea name="Benefits" class="form-control">@Model.Benefits</textarea>
    </div>

    <div class="mb-3">
        <label>Position Count</label>
        <input type="number" name="PositionCount" class="form-control" value="@Model.PositionCount" />
    </div>

    <div class="mb-3">
        <label>Employment Type</label>
        <select name="EmploymentType" class="form-control">
            @foreach (var type in Enum.GetValues(typeof(EmploymentType)))
            {
                var isSelected = type.ToString() == Model.EmploymentType;
                <option value="@type" selected="@isSelected">@type</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Salary Min</label>
        <input type="number" name="SalaryRangeMin" class="form-control" value="@Model.SalaryRangeMin" />
    </div>

    <div class="mb-3">
        <label>Salary Max</label>
        <input type="number" name="SalaryRangeMax" class="form-control" value="@Model.SalaryRangeMax" />
    </div>

    <div class="mb-3">
        <label>Status</label>
        <select name="Status" class="form-control">
            @foreach (var status in Enum.GetValues(typeof(VacancyStatus)))
            {
                var isSelected = status.ToString() == Model.Status;
                <option value="@status" selected="@isSelected">@status</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Deadline</label>
        <input type="date" name="Deadline" class="form-control" value="@(Model.Deadline?.ToString("yyyy-MM-dd"))" />
    </div>

    <hr />
    <h4>Projects</h4>
    <button type="button" class="btn btn-secondary mb-3" data-bs-toggle="modal" data-bs-target="#projectSelectorModal">Add Projects</button>
    <ul>
        @foreach(var p in Model.AllProjects.Where(p => Model.SelectedProjectIds.Contains(p.Id)))
        {
            <li>@p.Name</li>
        }
    </ul>

    <button type="submit" class="btn btn-success">Save Vacancy</button>
</form>

<div class="modal fade" id="projectSelectorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5>Select Projects</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="projectSelectForm">
                    @foreach(var p in Model.AllProjects)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="@p.Id" @(Model.SelectedProjectIds.Contains(p.Id) ? "checked" : "") />
                            <label class="form-check-label">@p.Name</label>
                        </div>
                    }
                    <button type="button" class="btn btn-primary mt-2" id="saveProjectsBtn">Save Projects</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var allProjects = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllProjects));

    document.getElementById("saveProjectsBtn").addEventListener("click", function () {
        var selectedIds = Array.from(document.querySelectorAll("#projectSelectForm input[type=checkbox]:checked"))
                               .map(cb => cb.value);

        console.log(selectedIds);

        var modal = bootstrap.Modal.getInstance(document.getElementById('projectSelectorModal'));
        modal.hide();

        // تحديث الـ project list فورياً
        var ul = document.querySelector("form ul");
        ul.innerHTML = "";
        selectedIds.forEach(id => {
            var project = allProjects.find(p => p.id == id);
            if(project){
                var li = document.createElement("li");
                li.textContent = project.name;
                ul.appendChild(li);
            }
        });
    });
</script>
