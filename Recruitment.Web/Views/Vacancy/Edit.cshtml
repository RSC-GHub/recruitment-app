@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyEditVM

@{
    ViewData["Title"] = "Edit Vacancy";
}

<div class="card-component">
    <div class="card-header flex-between">
        <h2 class="card-title"><i class="bi bi-pencil-square me-2"></i>Edit Vacancy</h2>
        <a asp-action="Index" class="btn-component btn-secondary"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
    </div>
    <div class="card-content">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="field-group">
                <!-- Title -->
                <div class="field">
                    <label class="field-label" for="TitleId">
                        Title <span class="text-danger">*</span>
                        <span class="tooltip-trigger">
                            <i>i</i>
                            <span class="tooltip-content multiline">Select the job title for this vacancy. This helps categorize the position and makes it easier for candidates to find.</span>
                        </span>
                    </label>
                    <select asp-for="TitleId" id="TitleId" class="form-field-select select2-dropdown" asp-items="Model.TitlesDropdown">
                        <option value="">-- Select Title --</option>
                    </select>
                    <span class="field-description">Choose from available job titles</span>
                    <span asp-validation-for="TitleId" class="field-error" style="display:none;"></span>
                </div>

                <!-- Job Description -->
                <div class="field">
                    <label class="field-label" for="JobDescription">
                        Job Description <span class="text-danger">*</span>
                        <span class="tooltip-trigger">
                            <i>i</i>
                            <span class="tooltip-content multiline">Provide a comprehensive overview of the role, including what the position entails and what the candidate will be doing day-to-day.</span>
                        </span>
                    </label>
                    <textarea asp-for="JobDescription" id="JobDescription" class="form-field-textarea" rows="4"></textarea>
                    <span class="field-description">Describe the primary purpose and goals of this position</span>
                    <span asp-validation-for="JobDescription" class="field-error" style="display:none;"></span>
                </div>

                <!-- Requirements -->
                <div class="field">
                    <label class="field-label" for="Requirements">
                        Requirements <span class="text-danger">*</span>
                        <span class="tooltip-trigger">
                            <i>i</i>
                            <span class="tooltip-content multiline">List the qualifications, skills, education, and experience required for this position. Include both must-have and nice-to-have requirements.</span>
                        </span>
                    </label>
                    <textarea asp-for="Requirements" id="Requirements" class="form-field-textarea" rows="4"></textarea>
                    <span class="field-description">List essential qualifications and skills</span>
                    <span asp-validation-for="Requirements" class="field-error" style="display:none;"></span>
                </div>

                <!-- Responsibilities -->
                <div class="field">
                    <label class="field-label" for="Responsibilities">
                        Responsibilities <span class="text-danger">*</span>
                        <span class="tooltip-trigger">
                            <i>i</i>
                            <span class="tooltip-content multiline">Outline the key duties and responsibilities the candidate will be expected to perform in this role.</span>
                        </span>
                    </label>
                    <textarea asp-for="Responsibilities" id="Responsibilities" class="form-field-textarea" rows="4"></textarea>
                    <span class="field-description">Define the main duties and tasks</span>
                    <span asp-validation-for="Responsibilities" class="field-error" style="display:none;"></span>
                </div>

                <!-- Benefits -->
                <div class="field">
                    <label class="field-label" for="Benefits">
                        Benefits
                        <span class="tooltip-trigger">
                            <i>i</i>
                            <span class="tooltip-content multiline">Describe the benefits package offered with this position, such as health insurance, retirement plans, paid time off, etc.</span>
                        </span>
                    </label>
                    <textarea asp-for="Benefits" id="Benefits" class="form-field-textarea" rows="3"></textarea>
                    <span class="field-description">Optional: Highlight perks and benefits offered</span>
                    <span asp-validation-for="Benefits" class="field-error" style="display:none;"></span>
                </div>

                <div class="field-separator"></div>

                <div class="row g-4">
                    <!-- Position Count -->
                    <div class="col-md-6">
                        <div class="field">
                            <label class="field-label" for="PositionCount">
                                Position Count <span class="text-danger">*</span>
                                <span class="tooltip-trigger">
                                    <i>i</i>
                                    <span class="tooltip-content multiline">Enter the number of open positions available for this vacancy. If hiring multiple candidates for the same role, specify the count here.</span>
                                </span>
                            </label>
                            <input asp-for="PositionCount" id="PositionCount" class="form-field-input" type="number" min="1" />
                            <span class="field-description">Number of openings for this role</span>
                            <span asp-validation-for="PositionCount" class="field-error" style="display:none;"></span>
                        </div>
                    </div>

                    <!-- Employment Type -->
                    <div class="col-md-6">
                        <div class="field">
                            <label class="field-label" for="EmploymentType">
                                Employment Type <span class="text-danger">*</span>
                                <span class="tooltip-trigger">
                                    <i>i</i>
                                    <span class="tooltip-content multiline">Select the type of employment: Full-time, Part-time, Contract, Temporary, or Internship.</span>
                                </span>
                            </label>
                            <select asp-for="EmploymentType" id="EmploymentType" class="form-field-select select2-dropdown">
                                @foreach (var type in Enum.GetValues(typeof(Recruitment.Domain.Enums.EmploymentType)))
                                {
                                    <option value="@type" selected="@(type.ToString() == Model.EmploymentType.ToString())">@type</option>
                                }
                            </select>
                            <span class="field-description">Type of employment arrangement</span>
                            <span asp-validation-for="EmploymentType" class="field-error" style="display:none;"></span>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="col-md-6">
                        <div class="field">
                            <label class="field-label" for="Status">
                                Status <span class="text-danger">*</span>
                                <span class="tooltip-trigger">
                                    <i>i</i>
                                    <span class="tooltip-content multiline">Set the current status of this vacancy.</span>
                                </span>
                            </label>
                            <select asp-for="Status" id="Status" class="form-field-select select2-dropdown">
                                @foreach (var status in Enum.GetValues(typeof(Recruitment.Domain.Enums.VacancyStatus)))
                                {
                                    <option value="@status" selected="@(status.ToString() == Model.Status.ToString())">@status</option>
                                }
                            </select>
                            <span class="field-description">Current vacancy status</span>
                            <span asp-validation-for="Status" class="field-error" style="display:none;"></span>
                        </div>
                    </div>

                    <!-- Salary Range Min -->
                    <div class="col-md-6">
                        <div class="field">
                            <label class="field-label" for="SalaryRangeMin">Salary Range Minimum</label>
                            <input asp-for="SalaryRangeMin" id="SalaryRangeMin" class="form-field-input" type="number" step="0.01" />
                            <span class="field-description">Optional: Minimum salary amount</span>
                            <span asp-validation-for="SalaryRangeMin" class="field-error" style="display:none;"></span>
                        </div>
                    </div>

                    <!-- Salary Range Max -->
                    <div class="col-md-6">
                        <div class="field">
                            <label class="field-label" for="SalaryRangeMax">Salary Range Maximum</label>
                            <input asp-for="SalaryRangeMax" id="SalaryRangeMax" class="form-field-input" type="number" step="0.01" />
                            <span class="field-description">Optional: Maximum salary amount</span>
                            <span asp-validation-for="SalaryRangeMax" class="field-error" style="display:none;"></span>
                        </div>
                    </div>

                    <!-- Deadline -->
                    <div class="col-md-6">
                        <div class="field">
                            <label class="field-label" for="Deadline">Deadline</label>
                            <input asp-for="Deadline" id="Deadline" class="form-field-input" type="date" />
                            <span class="field-description">Optional: Last date to accept applications</span>
                            <span asp-validation-for="Deadline" class="field-error" style="display:none;"></span>
                        </div>
                    </div>

                    <!-- Projects Multi-Select -->
                    <div class="col-md-6">
                        <div class="field">
                            <label class="field-label" for="ProjectIds">Projects</label>
                            <select asp-for="ProjectIds" id="ProjectIds" class="form-field-select select2-dropdown" asp-items="Model.ProjectsDropdown" multiple="multiple"></select>
                            <span class="field-description">Optional: Select related projects</span>
                            <span asp-validation-for="ProjectIds" class="field-error" style="display:none;"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="field-separator"></div>

            <button type="submit" class="btn-component btn-primary">
                <i class="bi bi-check-circle me-1"></i>Save Changes
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <!-- jQuery + Select2 -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(function () {

            /* --- Select2 Initialization --- */
            $('.select2-dropdown').select2({
                width: '100%',
                placeholder: "-- Select --",
                allowClear: true
            });

            /* --- Hide all validation on load --- */
            $('.field-error').hide();

            /* --- Validation function --- */
            function validateField($field) {
                var fieldName = $field.attr('name');

                // Skip validation for ProjectIds (multi-select)
                if (fieldName === 'ProjectIds') return true;

                var $fieldContainer = $field.closest('.field');
                var $fieldError = $fieldContainer.find('.field-error').first();
                var isRequired = $fieldContainer.find('label .text-danger').length > 0;

                var value = $field.val();

                if (isRequired && (!value || value === '' || (Array.isArray(value) && value.length === 0))) {
                    if ($fieldError.length) {
                        $fieldError.show();
                    }
                    $field.addClass('is-invalid');
                    $fieldContainer.attr('data-invalid', 'true');
                    return false;
                } else {
                    if ($fieldError.length) {
                        $fieldError.hide();
                    }
                    $field.removeClass('is-invalid');
                    $fieldContainer.removeAttr('data-invalid');
                    return true;
                }
            }

            var touchedFields = new Set();

            /* --- Field change/blur validation --- */
            $('input, textarea, select').on('blur change input', function () {
                var $field = $(this);
                touchedFields.add($field.attr('name'));
                validateField($field);
            });

            /* --- Form submit --- */
            $('form').on('submit', function (e) {

                // IMPORTANT FIX:
                // Ensure ProjectIds always sends empty array instead of null
                var projectSelect = $('select[name="ProjectIds"]');
                if (projectSelect.val() === null) {
                    projectSelect.val([]);   // This ensures backend receives an empty list
                }

                var isValid = true;

                $('input, textarea, select').each(function () {
                    var $field = $(this);
                    touchedFields.add($field.attr('name'));
                    
                    if (!validateField($field)) {
                        isValid = false;
                    }
                });

                if (!isValid) {
                    e.preventDefault();
                    // Scroll to first error
                    var $firstError = $('[data-invalid="true"]').first();
                    if ($firstError.length) {
                        $('html, body').animate({
                            scrollTop: $firstError.offset().top - 100
                        }, 300);
                    }
                }
            });

        });
    </script>
}
