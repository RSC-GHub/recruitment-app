@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyDetailsViewModel

@{
    ViewData["Title"] = "Delete Vacancy";
}

<h2>Delete Vacancy</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this vacancy?
</div>

<div class="mb-3">
    <strong>Title:</strong> @Model.TitleName
</div>
<div class="mb-3">
    <strong>Positions:</strong> @Model.PositionCount
</div>
<div class="mb-3">
    <strong>Employment Type:</strong> @Model.EmploymentType
</div>
<div class="mb-3">
    <strong>Status:</strong> @Model.Status
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
