@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyViewModel

<h2>Delete Vacancy</h2>

<div>
    <h4>Are you sure you want to delete this vacancy?</h4>
    <p><strong>Title:</strong> @Model.TitleName</p>
    <p><strong>Job Description:</strong> @Model.JobDescription</p>
    <p><strong>Projects:</strong> @string.Join(", ", Model.ProjectNames ?? new List<string>())</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
