@model List<Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyListVM>
@using Recruitment.Domain.Enums

@{
    ViewData["Title"] = "Vacancies";
}

<h2>Vacancies</h2>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">Add New Vacancy</a>
</div>

<form method="get" class="row g-4 mb-4">
    <div class="col-md-4">
        <select name="titleId" class="form-select">
            <option value="">-- All Titles --</option>
            @foreach (var t in (SelectList)ViewBag.Titles)
            {
                <option value="@t.Value" selected=@(t.Selected)>@t.Text</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <select name="projectId" class="form-select">
            <option value="">-- All Projects --</option>
            @foreach (var p in (SelectList)ViewBag.Projects)
            {
                <option value="@p.Value" selected=@(p.Selected)>@p.Text</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="">-- All Status --</option>
            @foreach (var s in (SelectList)ViewBag.Statuses)
            {
                <option value="@s.Value" selected=@(s.Selected)>@s.Text</option>
            }
        </select>
    </div>
    <div class="col-md-1">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
</form>


<table class="table table-bordered table-striped table-hover">
    <thead class="table-light">
        <tr>
            <th>Title</th>
            <th>Positions</th>
            <th>Employment Type</th>
            <th>Status</th>
            <th>Deadline</th>
            <th>Projects</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var vacancy in Model)
        {
            <tr style="cursor:pointer;" onclick="location.href='@Url.Action("Details", "Vacancy", new { id = vacancy.Id })'">
                <td>@vacancy.TitleName</td>
                <td>@vacancy.PositionCount</td>
                <td>@vacancy.EmploymentType</td>
                <td>@vacancy.Status</td>
                <td>@(vacancy.Deadline?.ToString("yyyy-MM-dd") ?? "-")</td>
                <td>
                    @if (vacancy.ProjectNames != null && vacancy.ProjectNames.Any())
                    {
                        <div class="d-flex flex-column gap-1">
                            @foreach (var project in vacancy.ProjectNames)
                            {
                                <span class="badge bg-secondary">@project</span>
                            }
                        </div>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
                
            </tr>
        }
    </tbody>
</table>

@if (ViewBag.TotalPages > 1)
{
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    int maxPagesToShow = 5;
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, startPage + maxPagesToShow - 1);

    <nav aria-label="Page navigation">
        <ul class="pagination">

            <!-- Previous -->
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new
                                     {
                                         page = currentPage - 1,
                                         search = Context.Request.Query["search"],
                                         titleId = Context.Request.Query["titleId"],
                                         projectId = Context.Request.Query["projectId"],
                                         status = Context.Request.Query["status"]
                                     })">Prev</a>
        </li>

            <!-- Page numbers -->
        @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new
                                         {
                                             page = i,
                                             search = Context.Request.Query["search"],
                                             titleId = Context.Request.Query["titleId"],
                                             projectId = Context.Request.Query["projectId"],
                                             status = Context.Request.Query["status"]
                                         })">@i</a>
        </li>
                }

            @if (endPage < totalPages)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new
                                         {
                                             page = totalPages,
                                             search = Context.Request.Query["search"],
                                             titleId = Context.Request.Query["titleId"],
                                             projectId = Context.Request.Query["projectId"],
                                             status = Context.Request.Query["status"]
                                         })">@totalPages</a>
        </li>
                }

            <!-- Next -->
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new
                                     {
                                         page = currentPage + 1,
                                         search = Context.Request.Query["search"],
                                         titleId = Context.Request.Query["titleId"],
                                         projectId = Context.Request.Query["projectId"],
                                         status = Context.Request.Query["status"]
                                     })">Next</a>
        </li>

        </ul>
    </nav>
}

