@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyIndexVM

@{
    ViewData["Title"] = "Vacancies";
}

<div class="container mt-4">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-briefcase-fill me-2"></i>Vacancies
        </h2>

        <a href="/Vacancy/Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Add Vacancy
        </a>
    </div>

    <!-- FILTERS CARD -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 mb-4">
                <div class="col-md-3">
                    <input type="text" name="search" class="form-control" placeholder="Search..."
                           value="@Model.Search" />
                </div>

                <div class="col-md-3">
                    <select name="titleId" class="form-select">
                        <option value="">-- All Titles --</option>
                        @foreach (var t in Model.Titles)
                        {
                            <option value="@t.Value" selected="@(Model.TitleId?.ToString() == t.Value)">
                                @t.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <select name="projectId" class="form-select">
                        <option value="">-- All Projects --</option>
                        @foreach (var p in Model.Projects)
                        {
                            <option value="@p.Value" selected="@(Model.ProjectId?.ToString() == p.Value)">
                                @p.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <select name="status" class="form-select">
                        <option value="">-- All Status --</option>
                        @foreach (var s in Model.Statuses)
                        {
                            <option value="@s.Value" selected="@(Model.Status?.ToString() == s.Value)">
                                @s.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-12 mt-2">
                    <button type="submit" class="btn btn-primary">Filter</button>
                </div>
            </form>
        </div>
    </div>

    <!-- VACANCIES TABLE -->
    <div class="table-responsive shadow-sm">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Positions</th>
                    <th>Employment</th>
                    <th>Projects</th>
                    <th>Status</th>
                    <th>Deadline</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Vacancies.Any())
                {
                    foreach (var v in Model.Vacancies)
                    {
                        <tr>
                            <td>@v.TitleName</td>
                            <td>@v.PositionCount</td>
                            <td>@v.EmploymentType</td>
                            <td>
                                @foreach (var p in v.ProjectNames)
                                {
                                    <span class="badge bg-secondary me-1">@p</span>
                                }
                            </td>
                            <td>@v.Status</td>
                            <td>@v.Deadline?.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a href="/Vacancy/Details/@v.Id" class="btn btn-sm btn-primary">View</a>
                                <a href="/Vacancy/Edit/@v.Id" class="btn btn-sm btn-warning">Edit</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">No vacancies found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- PAGINATION -->
    @if (Model.TotalCount > Model.PageSize)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">

                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link"
                       href="?page=@(Model.Page - 1)&search=@Model.Search&titleId=@Model.TitleId&projectId=@Model.ProjectId&status=@Model.Status">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.Page == i ? "active" : "")">
                        <a class="page-link"
                           href="?page=@i&search=@Model.Search&titleId=@Model.TitleId&projectId=@Model.ProjectId&status=@Model.Status">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       href="?page=@(Model.Page + 1)&search=@Model.Search&titleId=@Model.TitleId&projectId=@Model.ProjectId&status=@Model.Status">
                        Next
                    </a>
                </li>

            </ul>
        </nav>
    }

</div>
