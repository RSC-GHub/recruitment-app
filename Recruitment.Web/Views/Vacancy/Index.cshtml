@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyIndexVM

@{
    ViewData["Title"] = "Vacancies";
}

<!-- Page Header -->
<div class="flex-between mb-4">
    <div>
        <h2 class="card-title d-flex align-items-center gap-2">
            <i class="bi bi-briefcase-fill"></i>
            Vacancies
        </h2>
        <p class="card-description">Manage job vacancies and positions</p>
    </div>
    <a href="/Vacancy/Create" class="btn-component btn-primary">
        <i class="bi bi-plus-lg me-2"></i>
        Add Vacancy
    </a>
</div>

<!-- Filters Card -->
<div class="card-component mb-4">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-funnel me-2"></i>
            Search & Filter
        </h3>
    </div>
    <div class="card-content">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <div class="form-field">
                    <label class="form-label" for="search">Search</label>
                    <input type="text" 
                           id="search"
                           name="search" 
                           class="form-input" 
                           placeholder="Search vacancies..."
                           value="@Model.Search" />
                </div>
            </div>

            <div class="col-md-3">
                <div class="form-field">
                    <label class="form-label" for="titleId">Job Title</label>
                    <select id="titleId" name="titleId" class="form-select">
                        <option value="">All Titles</option>
                        @foreach (var t in Model.Titles)
                        {
                            <option value="@t.Value" selected="@(Model.TitleId?.ToString() == t.Value)">
                                @t.Text
                            </option>
                        }
                    </select>
                </div>
            </div>

            <div class="col-md-3">
                <div class="form-field">
                    <label class="form-label" for="projectId">Project</label>
                    <select id="projectId" name="projectId" class="form-select">
                        <option value="">All Projects</option>
                        @foreach (var p in Model.Projects)
                        {
                            <option value="@p.Value" selected="@(Model.ProjectId?.ToString() == p.Value)">
                                @p.Text
                            </option>
                        }
                    </select>
                </div>
            </div>

            <div class="col-md-3">
                <div class="form-field">
                    <label class="form-label" for="status">Status</label>
                    <select id="status" name="status" class="form-select">
                        <option value="">All Status</option>
                        @foreach (var s in Model.Statuses)
                        {
                            <option value="@s.Value" selected="@(Model.Status?.ToString() == s.Value)">
                                @s.Text
                            </option>
                        }
                    </select>
                </div>
            </div>

            <div class="col-12">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-component btn-primary">
                        <i class="bi bi-search me-2"></i>
                        Apply Filters
                    </button>

                    <a href="/Vacancy/Index" class="btn-component btn-outline">
                        <i class="bi bi-x-circle me-2"></i>
                        Clear Filters
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Vacancies Table -->
<div class="card-component">
    <div class="card-content p-0">
        <div class="table-scroll-wrapper">
            <div class="table-component">
                <table>
                    <thead>
                        <tr>
                            <th style="min-width: 150px;">Title</th>
                            <th style="min-width: 100px;">Positions</th>
                            <th style="min-width: 150px;">Employment Type</th>
                            <th style="min-width: 200px;">Projects</th>
                            <th style="min-width: 100px;">Status</th>
                            <th style="min-width: 120px;">Deadline</th>
                            <th class="text-end" style="min-width: 150px; width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Vacancies.Any())
                    {
                        foreach (var v in Model.Vacancies)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@v.TitleName</div>
                                </td>
                                <td>
                                    <span class="badge-component badge-secondary">
                                        @v.PositionCount
                                    </span>
                                </td>
                                <td>@v.EmploymentType</td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        @foreach (var p in v.ProjectNames)
                                        {
                                            <span class="badge-component badge-secondary">@p</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var statusClass = v.Status == "Open" ? "badge-success" : 
                                                         v.Status == "Closed" ? "badge-secondary" : 
                                                         "badge-warning";
                                    }
                                    <span class="badge-component @statusClass">
                                        @v.Status
                                    </span>
                                </td>
                                <td>
                                    @if (v.Deadline.HasValue)
                                    {
                                        <span>@v.Deadline.Value.ToString("MMM dd, yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a href="/Vacancy/Details/@v.Id" 
                                           class="btn-component btn-sm btn-outline"
                                           title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/Vacancy/Edit/@v.Id" 
                                           class="btn-component btn-sm btn-primary"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button"
                                                class="btn-component btn-sm btn-destructive"
                                                onclick="confirmDelete('@v.Id', '@v.TitleName')"
                                                title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
                                <div class="text-muted">No vacancies found</div>
                                @if (!string.IsNullOrEmpty(Model.Search) || Model.TitleId.HasValue || Model.ProjectId.HasValue || Model.Status.HasValue)
                                {
                                    <a href="/Vacancy/Index" class="btn-component btn-outline mt-3">Clear Filters</a>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (Model.TotalCount > Model.PageSize)
    {
        <div class="card-footer">
            <nav class="pagination-component" aria-label="Pagination">
                <!-- Previous Button -->
                <a class="pagination-button @(Model.Page == 1 ? "disabled" : "")"
                   href="?page=@(Model.Page - 1)&search=@Model.Search&titleId=@Model.TitleId&projectId=@Model.ProjectId&status=@Model.Status"
                   @(Model.Page == 1 ? "aria-disabled=true" : "")>
                    <i class="bi bi-chevron-left"></i>
                </a>

                <!-- Page Numbers -->
                @{
                    int startPage = Math.Max(1, Model.Page - 2);
                    int endPage = Math.Min(Model.TotalPages, Model.Page + 2);
                }

                @if (startPage > 1)
                {
                    <a class="pagination-button"
                       href="?page=1&search=@Model.Search&titleId=@Model.TitleId&projectId=@Model.ProjectId&status=@Model.Status">
                        1
                    </a>
                    @if (startPage > 2)
                    {
                        <span class="pagination-button disabled">...</span>
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a class="pagination-button @(Model.Page == i ? "active" : "")"
                       href="?page=@i&search=@Model.Search&titleId=@Model.TitleId&projectId=@Model.ProjectId&status=@Model.Status">
                        @i
                    </a>
                }

                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1)
                    {
                        <span class="pagination-button disabled">...</span>
                    }
                    <a class="pagination-button"
                       href="?page=@Model.TotalPages&search=@Model.Search&titleId=@Model.TitleId&projectId=@Model.ProjectId&status=@Model.Status">
                        @Model.TotalPages
                    </a>
                }

                <!-- Next Button -->
                <a class="pagination-button @(Model.Page == Model.TotalPages ? "disabled" : "")"
                   href="?page=@(Model.Page + 1)&search=@Model.Search&titleId=@Model.TitleId&projectId=@Model.ProjectId&status=@Model.Status"
                   @(Model.Page == Model.TotalPages ? "aria-disabled=true" : "")>
                    <i class="bi bi-chevron-right"></i>
                </a>
            </nav>

            <div class="text-center mt-3 text-muted small">
                Showing @((Model.Page - 1) * Model.PageSize + 1) to @Math.Min(Model.Page * Model.PageSize, Model.TotalCount) of @Model.TotalCount results
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function confirmDelete(vacancyId, title) {
            if (confirm(`Are you sure you want to delete vacancy "${title}"? This action cannot be undone.`)) {
                fetch(`/Vacancy/Delete/${vacancyId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                .then(response => {
                    if (response.ok) {
                        showToast(`Vacancy "${title}" has been deleted successfully`, 'success');
                        setTimeout(() => window.location.reload(), 1000);
                    } else {
                        showToast('Failed to delete vacancy', 'error');
                    }
                })
                .catch(error => {
                    showToast('An error occurred', 'error');
                });
            }
        }
    </script>
}
