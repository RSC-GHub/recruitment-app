@model IEnumerable<Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyTableViewModel>

@{
    ViewData["Title"] = "Vacancies";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Vacancies</h2>
    <a asp-action="Create" class="btn btn-primary">Create Vacancy</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Positions</th>
            <th>Type</th>
            <th>Status</th>
            <th>Projects</th>
            <th style="width:180px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TitleName</td>
                <td>@item.PositionCount</td>
                <td>@item.EmploymentType</td>
                <td>@item.Status</td>
                <td>
                    @if (item.Projects != null && item.Projects.Any())
                    {
                        @foreach (var p in item.Projects)
                        {
                            <span class="badge bg-secondary me-1">
                                @p.ProjectName - @p.Priority
                            </span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">No Projects</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">View</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
