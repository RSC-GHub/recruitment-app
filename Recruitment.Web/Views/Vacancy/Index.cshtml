@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyIndexVM

<h2>Vacancies</h2>

<a asp-action="Create" class="btn btn-success mb-3">Add Vacancy</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Title</th>
            <th>Positions</th>
            <th>Employment Type</th>
            <th>Status</th>
            <th>Projects</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var v in Model.Vacancies)
        {
            <tr>
                <td>@v.TitleName</td>
                <td>@v.PositionCount</td>
                <td>@v.EmploymentType</td>
                <td>@v.Status</td>
                <td>
                    @foreach (var p in v.ProjectNames)
                    {
                        <span class="badge bg-info">@p</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@v.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination">
            <!-- Previous Page -->
            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber - 1)">Previous</a>
            </li>

            <!-- Page Numbers -->
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }

            <!-- Next Page -->
            <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageNumber + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
