@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyApplicationsVM

@{
    ViewData["Title"] = "Applications for Vacancy";
}

<div class="card-component">
    <div class="card-header flex-between">
        <h2 class="card-title"><i class="bi bi-file-earmark-text me-2"></i>Applications</h2>
        <a asp-action="Details" asp-route-id="@Model.VacancyId" class="button-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Vacancy Details
        </a>
    </div>
    <div class="card-content">

        <!-- Search Form -->
        <form method="get" class="mb-3">
            <div class="d-flex gap-2">
                <input type="text" name="search" value="@Model.Search" placeholder="Search by applicant, email or note..." class="form-field-input flex-grow-1" />
                <input type="hidden" name="vacancyId" value="@Model.VacancyId" />
                <button type="submit" class="button-primary"><i class="bi bi-search me-1"></i>Search</button>
            </div>
        </form>

        <div class="table-component">
            <table>
    <thead>
        <tr>
            <th>Applicant Name</th>
            <th>Phone Number</th>
            <th>Email</th>
            <th>Status</th>
            <th>Applied On</th>
            <th>Note</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var app in Model.Applications)
        {
            <tr style="cursor:pointer;"
                onclick="location.href='@Url.Action("Details", "Application", new { id = app.Id })'">
                <td>@app.ApplicantName</td>
                <td>@app.PhoneNumber</td>
                <td>@app.ApplicantEmail</td>
                <td>@app.ApplicationStatus</td>
                <td>@app.ApplicationDate.ToString("yyyy-MM-dd")</td>
                <td>@app.Note</td>
            </tr>
        }
    </tbody>
</table>
</div>


<!-- Paging -->
<nav>
    <ul class="pagination">

        @if (Model.Page > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="GetSubmissions"
                   asp-route-vacancyId="@Model.VacancyId"
                   asp-route-page="@(Model.Page - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-search="@Model.Search">Previous</a> 
            </li>
        }

        <li class="page-item disabled">
            <span class="page-link">
                Page @Model.Page of @(Math.Ceiling((double)Model.TotalCount / Model.PageSize))
            </span>
        </li>

        @if (Model.Page * Model.PageSize < Model.TotalCount)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="GetSubmissions"
                   asp-route-vacancyId="@Model.VacancyId"
                   asp-route-page="@(Model.Page + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-search="@Model.Search">Next</a> 
            </li>
        }

    </ul>
</nav>

    </div>
</div>
