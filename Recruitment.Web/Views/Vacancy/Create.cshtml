@model Recruitment.Web.ViewModels.CoreBusiness.Vacancy.VacancyCreateVM
@using Recruitment.Domain.Enums

<h2>Add Vacancy</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label>Title</label>
        <select name="Vacancy.TitleId" class="form-control">
            @foreach (var t in Model.Titles)
            {
                <option value="@t.Id">@t.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Job Description</label>
        <textarea name="Vacancy.JobDescription" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label>Requirements</label>
        <textarea name="Vacancy.Requirements" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label>Responsibilities</label>
        <textarea name="Vacancy.Responsibilities" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label>Benefits</label>
        <textarea name="Vacancy.Benefits" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label>Position Count</label>
        <input type="number" name="Vacancy.PositionCount" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Employment Type</label>
        <select name="Vacancy.EmploymentType" class="form-control">
            @foreach (var type in Enum.GetValues(typeof(EmploymentType)))
            {
                <option value="@type">@type</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Salary Min</label>
        <input type="number" name="Vacancy.SalaryRangeMin" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Salary Max</label>
        <input type="number" name="Vacancy.SalaryRangeMax" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Status</label>
        <select name="Vacancy.Status" class="form-control">
            @foreach (var status in Enum.GetValues(typeof(VacancyStatus)))
            {
                <option value="@status">@status</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Deadline</label>
        <input type="date" name="Vacancy.Deadline" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Save Vacancy</button>
</form>
