@model Recruitment.Web.ViewModels.UserManagement.Applicant.ApplicantIndexVM

@{
    ViewData["Title"] = "Applicants";
}

<!-- Page Header -->
<div class="flex-between mb-4">
    <div>
        <h2 class="card-title d-flex align-items-center gap-2">
            <i class="bi bi-person-badge-fill"></i>
            Applicants
        </h2>
        <p class="card-description">Manage applicant profiles and information</p>
    </div>
    <a asp-action="Create" class="btn-component btn-primary" style="background-color: hsl(202 80.3% 23.9%); border-color: hsl(202 80.3% 23.9%); color: #fff;">
        <i class="bi bi-plus-lg me-2"></i>
        Add Applicant
    </a>
</div>

<!-- Search Card -->
<div class="card-component mb-4">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-search me-2"></i>
            Search Applicants
        </h3>
    </div>
    <div class="card-content">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-8">
                <div class="form-field">
                    <label class="form-label" for="search">Search</label>
                    <input type="text" 
                           id="search"
                           name="search" 
                           value="@Model.Search" 
                           class="form-input" 
                           placeholder="Search by name, email, city, nationality, phone, Current Job, Target Position..." />
                </div>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <div class="form-field w-100">
                    <label class="form-label">&nbsp;</label>
                    <div class="d-flex gap-2">
                        <button class="btn-component btn-primary flex-grow-1">
                            <i class="bi bi-search me-2"></i>
                            Search
                        </button>
                        @if (!string.IsNullOrEmpty(Model.Search))
                        {
                            <a href="@Url.Action("Index")" class="btn-component btn-outline">
                                <i class="bi bi-x-circle"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Applicants Table -->
<div class="card-component">
    <div class="card-content p-0">
        <div class="table-scroll-wrapper">
            <div class="table-component">
                <table>
                    <thead>
                        <tr>
                            <th style="min-width: 180px;">Name</th>
                            <th style="min-width: 200px;">Email</th>
                            <th style="min-width: 140px;">Phone</th>
                            <th style="min-width: 120px;">Country</th>
                            <th style="min-width: 150px;">Degree</th>
                            <th style="min-width: 140px;">Graduation Year</th>
                            <th style="width: 100px; min-width: 100px;" class="text-end">Actions</th>
                        </tr>
                    </thead>
                <tbody>
                    @if (Model.Applicants != null && Model.Applicants.Any())
                    {
                        foreach (var a in Model.Applicants)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-person-circle fs-5 text-primary"></i>
                                        <span class="fw-semibold">@a.FullName</span>
                                    </div>
                                </td>
                                <td>@a.Email</td>
                                <td>@a.PhoneNumber</td>
                                <td>
                                    <span class="badge-component badge-secondary">@a.CountryName</span>
                                </td>
                                <td>@a.EducationDegree</td>
                                <td>
                                    <span class="badge-component badge-outline">@a.GraduationYear</span>
                                </td>
                                <td class="text-end">
                                    <a href="@Url.Action("Profile", "Applicant", new { id = a.Id })" 
                                       class="btn-component btn-sm btn-outline"
                                       title="View Profile">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
                                <div class="text-muted">No applicants found</div>
                                @if (!string.IsNullOrEmpty(Model.Search))
                                {
                                    <a href="@Url.Action("Index")" class="btn-component btn-outline mt-3">Clear Search</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        </div>
    </div>

    <!-- Pagination -->
    @{
        int totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);
    }

    @if (totalPages > 1)
    {
        <div class="card-footer">
            <nav class="pagination-component" aria-label="Pagination">
                <a class="pagination-button @(Model.Page == 1 ? "disabled" : "")"
                   asp-action="Index"
                   asp-route-page="@(Model.Page - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-search="@Model.Search">
                    <i class="bi bi-chevron-left"></i>
                </a>

                @{
                    int startPage = Math.Max(1, Model.Page - 2);
                    int endPage = Math.Min(totalPages, Model.Page + 2);
                }

                @if (startPage > 1)
                {
                    <a class="pagination-button"
                       asp-action="Index"
                       asp-route-page="1"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-search="@Model.Search">
                        1
                    </a>
                    @if (startPage > 2)
                    {
                        <span class="pagination-button disabled">...</span>
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a class="pagination-button @(i == Model.Page ? "active" : "")"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-search="@Model.Search">
                        @i
                    </a>
                }

                @if (endPage < totalPages)
                {
                    @if (endPage < totalPages - 1)
                    {
                        <span class="pagination-button disabled">...</span>
                    }
                    <a class="pagination-button"
                       asp-action="Index"
                       asp-route-page="@totalPages"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-search="@Model.Search">
                        @totalPages
                    </a>
                }

                <a class="pagination-button @(Model.Page == totalPages ? "disabled" : "")"
                   asp-action="Index"
                   asp-route-page="@(Model.Page + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-search="@Model.Search">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </nav>

            <div class="text-center mt-3 text-muted small">
                Showing @((Model.Page - 1) * Model.PageSize + 1) to @Math.Min(Model.Page * Model.PageSize, Model.TotalCount) of @Model.TotalCount results
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Show toast notifications
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            showToast('@TempData["SuccessMessage"]', 'success');
            </text>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <text>
            showToast('@TempData["ErrorMessage"]', 'error');
            </text>
        }
    </script>
}
