@model Recruitment.Web.ViewModels.UserManagement.Applicant.ApplicantEditVM

@{
    ViewData["Title"] = "Edit Applicant";
}

<div class="card-component">
    <div class="card-header">
        <h2 class="card-title"><i class="bi bi-pencil-square me-2"></i>Edit Applicant</h2>
    </div>
    <div class="card-content">
        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="row g-3" id="applicantForm">
            <input type="hidden" asp-for="Id" />

            <!-- Full Name -->
            <div class="col-md-6">
                <label class="form-field-label">Full Name</label><span class="form-field-error"> *</span>
                <input asp-for="FullName" class="form-field-input" id="fullName" />
                <span asp-validation-for="FullName" class="form-field-error"></span>
            </div>

            <!-- Email -->
            <div class="col-md-6">
                <label class="form-field-label">Email</label><span class="form-field-error"> *</span>
                <input asp-for="Email" class="form-field-input" type="email" id="email" />
                <span asp-validation-for="Email" class="form-field-error"></span>
            </div>

            <!-- Phone Number -->
            <div class="col-md-6">
                <label class="form-field-label">Phone Number</label><span class="form-field-error"> *</span>
                <input asp-for="PhoneNumber" class="form-field-input" id="phoneNumber" />
                <span asp-validation-for="PhoneNumber" class="form-field-error"></span>
            </div>

            <!-- Country -->
            <div class="col-md-6">
                <label class="form-field-label">Country</label><span class="form-field-error"> *</span>
                <select asp-for="CountryId" asp-items="Model.Countries" class="form-field-select" id="countryId">
                    <option value="">-- Select Country --</option>
                </select>
                <span asp-validation-for="CountryId" class="form-field-error"></span>
            </div>

            <!-- City -->
            <div class="col-md-6">
                <label class="form-field-label">City</label><span class="form-field-error"> *</span>
                <input asp-for="City" class="form-field-input" id="city" />
                <span asp-validation-for="City" class="form-field-error"></span>
            </div>

            <!-- Nationality -->
            <div class="col-md-6">
                <label class="form-field-label">Nationality</label><span class="form-field-error"> *</span>
                <input asp-for="Nationality" class="form-field-input" id="nationality" />
                <span asp-validation-for="Nationality" class="form-field-error"></span>
            </div>

            <!-- Gender -->
            <div class="col-md-6">
                <label class="form-field-label">Gender</label><span class="form-field-error"> *</span>
                <select asp-for="Gender" asp-items="Model.GenderType" class="form-field-select" id="gender">
                    <option value="">-- Select Gender --</option>
                </select>
                <span asp-validation-for="Gender" class="form-field-error"></span>
            </div>

            <!-- Military Status -->
            <div class="col-md-6">
                <label class="form-field-label">Military Status</label><span class="form-field-error"> *</span>
                <select asp-for="MilitaryStatus" asp-items="Model.MilitaryStatuses" class="form-field-select" id="militaryStatus">
                    <option value="">-- Select Military Status --</option>
                </select>
                <span asp-validation-for="MilitaryStatus" class="form-field-error"></span>
            </div>

            <!-- Marital Status -->
            <div class="col-md-6">
                <label class="form-field-label">Marital Status</label><span class="form-field-error"> *</span>
                <select asp-for="MaritalStatus" asp-items="Model.MaritalStatuses" class="form-field-select" id="maritalStatus">
                    <option value="">-- Select Marital Status --</option>
                </select>
                <span asp-validation-for="MaritalStatuses" class="form-field-error"></span>
            </div>

            <!-- Target Position -->
            <div class="col-md-6">
                <label class="form-field-label">Target Position</label>
                <input asp-for="TargetPosition" class="form-field-input" id="targetPosition" />
                <span asp-validation-for="TargetPosition" class="form-field-error"></span>
            </div>

            <!-- Current Job -->
            <div class="col-md-6">
                <label class="form-field-label">Current Job</label><span class="form-field-error"> *</span>
                <input asp-for="CurrentJob" class="form-field-input" id="currentJob" />
                <span asp-validation-for="CurrentJob" class="form-field-error"></span>
            </div>

            <!-- Current Employer -->
            <div class="col-md-6">
                <label class="form-field-label">Current Employer</label><span class="form-field-error"> *</span>
                <input asp-for="CurrentEmployer" class="form-field-input" id="currentEmployer" />
                <span asp-validation-for="CurrentEmployer" class="form-field-error"></span>
            </div>

            <!-- Current Salary -->
            <div class="col-md-6">
                <label class="form-field-label">Current Salary</label><span class="form-field-error"> *</span>
                <input asp-for="CurrentSalary" class="form-field-input" type="number" step="0.01" id="currentSalary" />
                <span asp-validation-for="CurrentSalary" class="form-field-error"></span>
            </div>

            <!-- Expected Salary -->
            <div class="col-md-6">
                <label class="form-field-label">Expected Salary</label><span class="form-field-error"> *</span>
                <input asp-for="ExpectedSalary" class="form-field-input" type="number" step="0.01" id="expectedSalary" />
                <span asp-validation-for="ExpectedSalary" class="form-field-error"></span>
            </div>

            <!-- Currency -->
            <div class="col-md-6">
                <label class="form-field-label">Currency</label><span class="form-field-error"> *</span>
                <select asp-for="CurrencyId" asp-items="Model.Currencies" class="form-field-select" id="currencyId">
                    <option value="">-- Select Currency --</option>
                </select>
                <span asp-validation-for="CurrencyId" class="form-field-error"></span>
            </div>

            <!-- Address -->
            <div class="col-md-6">
                <label class="form-field-label">Address</label>
                <input asp-for="Address" class="form-field-input" />
                <span asp-validation-for="Address" class="form-field-error"></span>
            </div>

            <!-- Education Degree -->
            <div class="col-md-6">
                <label class="form-field-label">Education Degree</label><span class="form-field-error"> *</span>
                <select asp-for="EducationDegree" asp-items="Model.EducationDegrees" class="form-field-select" id="educationDegree">
                    <option value="">-- Select Degree --</option>
                </select>
                <span asp-validation-for="EducationDegree" class="form-field-error"></span>
            </div>

            <!-- Graduation Year -->
            <div class="col-md-6">
                <label class="form-field-label">Graduation Year</label>
                <input asp-for="GraduationYear" class="form-field-input" type="number" />
                <span asp-validation-for="GraduationYear" class="form-field-error"></span>
            </div>

            <!-- Major -->
            <div class="col-md-6">
                <label class="form-field-label">Major</label>
                <input asp-for="Major" class="form-field-input" />
                <span asp-validation-for="Major" class="form-field-error"></span>
            </div>

            <!-- Notice Period -->
            <div class="col-md-6">
                <label class="form-field-label">Notice Period (days)</label><span class="form-field-error"> *</span>
                <input asp-for="NoticePeriod" class="form-field-input" type="number" id="noticePeriod" />
                <span asp-validation-for="NoticePeriod" class="form-field-error"></span>
            </div>

            <!-- Extra Certificate -->
            <div class="col-md-12">
                <label class="form-field-label">Extra Certificate</label>
                <textarea asp-for="ExtraCertificate" class="form-field-input"></textarea>
                <span asp-validation-for="ExtraCertificate" class="form-field-error"></span>
            </div>

            <!-- CV Upload -->
            <div class="col-md-12">
                <label class="form-field-label">Upload New CV (PDF)</label>

                @if (!string.IsNullOrWhiteSpace(Model.ExistingCVPath))
                {
                    <p class="text-muted">
                        A CV is already uploaded. Leave this empty if you do not want to replace it.
                    </p>
                }

                <input asp-for="CV" type="file" class="form-field-input" accept=".pdf,.doc,.docx" />
                <span asp-validation-for="CV" class="form-field-error"></span>

                @if (!string.IsNullOrWhiteSpace(Model.ExistingCVPath))
                {
                    <div class="mt-2">
                        <strong>Existing CV:</strong>
                        <a href="@Model.ExistingCVPath" class="btn btn-sm btn-outline-primary" target="_blank">View / Download</a>
                    </div>
                }
            </div>

            <div class="col-md-12">
                <label class="form-field-label">Offer Status</label>
                <input asp-for="OfferStatus" type="text" class="form-field-input" id="offerStatus" />
                <span asp-validation-for="OfferStatus" class="form-field-error"></span>
            </div>

            <div class="col-md-12">
                <label class="form-field-label">Comment</label>
                <input asp-for="Comment" type="text" class="form-field-input" id="comment" />
                <span asp-validation-for="Comment" class="form-field-error"></span>
            </div>


            <div class="col-12 text-end mt-4">
                <button type="submit" class="btn-component btn-primary">
                    <i class="bi bi-check-circle me-1"></i>Save Changes
                </button>
                <a asp-action="Index" class="class=" btn-component btn-secondary"">
                    <i class="bi bi-x-circle me-1"></i>Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Gender / Military Status logic
            $('#gender').on('change', function() {
                var genderValue = $(this).val();
                var militaryStatusSelect = $('#militaryStatus');

                if (genderValue == '2') { // Female
                    militaryStatusSelect.prop('disabled', true).val('');
                    militaryStatusSelect.removeClass('is-invalid');
                    militaryStatusSelect.siblings('.text-danger').text('');
                } else {
                    militaryStatusSelect.prop('disabled', false);
                }
            });
            $('#gender').trigger('change');
        });
    </script>
}
