@model Recruitment.Web.ViewModels.CoreBusiness.DepartmentTitle.DepartmentTitleEditViewModel

@{
    ViewData["Title"] = "Edit Department Title";
}

<h2>Edit Department Title</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="DepartmentId"></label>
        <input asp-for="DepartmentId" class="form-control" />
        <span asp-validation-for="DepartmentId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TitleId"></label>
        <input asp-for="TitleId" class="form-control" />
        <span asp-validation-for="TitleId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
