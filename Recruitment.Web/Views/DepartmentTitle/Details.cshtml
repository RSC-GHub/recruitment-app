@model Recruitment.Web.ViewModels.CoreBusiness.DepartmentTitle.DepartmentTitleDetailsViewModel

@{
    ViewData["Title"] = "Department Title Details";
}

<h2>Department Title Details</h2>

<div>
    <dl class="row">
        <dt class="col-sm-2">Department ID</dt>
        <dd class="col-sm-10">@Model.DepartmentId</dd>

        <dt class="col-sm-2">Title ID</dt>
        <dd class="col-sm-10">@Model.TitleId</dd>
    </dl>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
