@model IEnumerable<Recruitment.Web.ViewModels.CoreBusiness.DepartmentTitle.DepartmentTitleListViewModel>

@{
    ViewData["Title"] = "Department Titles";
}

<div class="card-component">
    <div class="card-header">
        <div class="flex-between">
            <div>
                <h2 class="card-title">Department Titles</h2>
                <p class="card-description">Map job titles to departments</p>
            </div>
            <a asp-action="Create" class="btn-component btn-primary">
                <i class="bi bi-plus-circle me-2"></i>
                Create Mapping
            </a>
        </div>
    </div>

    <div class="card-content">
        <div class="table-component">
            <table>
                <thead>
                    <tr>
                        <th>Department ID</th>
                        <th>Title ID</th>
                        <th style="width: 150px;" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge-component badge-secondary">@item.DepartmentId</span>
                                </td>
                                <td>
                                    <span class="badge-component badge-default">@item.TitleId</span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@item.Id" 
                                           class="btn-component btn-sm btn-primary"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" 
                                           class="btn-component btn-sm btn-destructive"
                                           title="Delete"
                                           onclick="return confirm('Are you sure you want to delete this mapping?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
                                <span class="text-muted">No department-title mappings found</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Show toast notifications
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            showToast('@TempData["SuccessMessage"]', 'success');
            </text>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <text>
            showToast('@TempData["ErrorMessage"]', 'error');
            </text>
        }
    </script>
}
