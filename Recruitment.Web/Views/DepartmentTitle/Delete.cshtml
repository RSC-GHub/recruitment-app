@model Recruitment.Web.ViewModels.CoreBusiness.DepartmentTitle.DepartmentTitleDeleteViewModel

@{
    ViewData["Title"] = "Delete Department Title";
}

<div class="card-component" style="max-width: 600px; margin: 2rem auto;">
    <div class="card-header" style="background-color: hsl(0, 84%, 60%); color: white;">
        <h2 class="card-title mb-0">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Delete Department Title Mapping
        </h2>
    </div>

    <div class="card-content">
        <div class="alert-component alert-destructive mb-4">
            <i class="bi bi-exclamation-triangle-fill alert-icon"></i>
            <div>
                <div class="alert-title">Are you sure you want to delete this record?</div>
                <div class="alert-description">
                    This action cannot be undone. This will remove the mapping between the department and title.
                </div>
            </div>
        </div>

        <div class="mb-4 p-4" style="background-color: hsl(0, 0%, 97%); border-radius: 8px;">
            <dl class="row mb-0">
                <dt class="col-sm-4">Department ID:</dt>
                <dd class="col-sm-8">
                    <span class="badge-component badge-secondary">@Model.DepartmentId</span>
                </dd>

                <dt class="col-sm-4">Title ID:</dt>
                <dd class="col-sm-8">
                    <span class="badge-component badge-default">@Model.TitleId</span>
                </dd>
            </dl>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn-component btn-destructive">
                    <i class="bi bi-trash me-2"></i>
                    Yes, Delete Mapping
                </button>
                <a asp-action="Index" class="btn-component btn-secondary">
                    <i class="bi bi-x-circle me-2"></i>
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
