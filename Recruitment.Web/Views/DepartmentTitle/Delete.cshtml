@model Recruitment.Web.ViewModels.CoreBusiness.DepartmentTitle.DepartmentTitleDeleteViewModel

@{
    ViewData["Title"] = "Delete Department Title";
}

<h2>Delete Department Title</h2>

<h4>Are you sure you want to delete this record?</h4>
<div>
    <dl class="row">
        <dt class="col-sm-2">Department ID</dt>
        <dd class="col-sm-10">@Model.DepartmentId</dd>

        <dt class="col-sm-2">Title ID</dt>
        <dd class="col-sm-10">@Model.TitleId</dd>
    </dl>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
