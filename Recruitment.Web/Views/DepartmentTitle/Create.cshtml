@model Recruitment.Web.ViewModels.CoreBusiness.DepartmentTitle.DepartmentTitleCreateViewModel

@{
    ViewData["Title"] = "Create Department Title";
}

<h2>Create Department Title</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="DepartmentId"></label>
        <input asp-for="DepartmentId" class="form-control" />
        <span asp-validation-for="DepartmentId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TitleId"></label>
        <input asp-for="TitleId" class="form-control" />
        <span asp-validation-for="TitleId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
