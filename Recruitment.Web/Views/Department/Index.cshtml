@using Recruitment.Application.Interfaces.Services.UserManagement
@model Recruitment.Web.ViewModels.CoreBusiness.Department.DepartmentsPagedVM
@inject IPermissionService PermissionService

@{
    ViewData["Title"] = "Departments";
}

<!-- Header -->
<div class="flex-between mb-4">
    <div>
        <h2 class="card-title d-flex align-items-center gap-2">
            <i class="bi bi-building"></i>
            Departments
        </h2>
        <p class="card-description">Manage organizational departments</p>
    </div>
    @if (PermissionService.HasPermission("Department", "Create"))
    {
        <button type="button"
                class="btn-component btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#createModal">
            <i class="bi bi-plus-lg me-2"></i>
            Add Department
        </button>
    }

</div>

<!-- Search & Filter -->
<div class="card-component mb-4">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-funnel me-2"></i>
            Search
        </h3>
    </div>

    <div class="card-content">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-10">
                <div class="form-field">
                    <label class="form-label">Search</label>
                    <input type="text"
                           name="search"
                           value="@Model.Search"
                           class="form-input"
                           placeholder="Search by department name..." />
                </div>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <div class="form-field w-100">
                    <button type="submit" class="btn-component btn-primary w-100">
                        <i class="bi bi-search me-2"></i>
                        Filter
                    </button>

                    @if (!string.IsNullOrEmpty(Model.Search))
                    {
                        <a asp-action="Index" class="btn-component btn-outline w-100 mt-2">
                            <i class="bi bi-x-circle me-2"></i>
                            Clear
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card-content">
    <div class="table-component">
        <table>
            <thead>
                <tr>
                    <th style="width:80px">#</th>
                    <th>Name</th>
                    <th style="width:150px" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold text-muted">
                                @item.Id
                            </td>

                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-building icon-color text-primary"></i>
                                    <span class="fw-semibold">@item.Name</span>
                                </div>
                            </td>

                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    @if (PermissionService.HasPermission("Department", "Edit"))
                                    {
                                        <button class="btn-component btn-sm btn-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editModal"
                                                data-id="@item.Id"
                                                data-name="@item.Name">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }

                                    @if (PermissionService.HasPermission("Department", "Delete"))
                                    {
                                        <button class="btn-component btn-sm btn-destructive"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@item.Id"
                                                data-name="@item.Name">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center py-5 text-muted">
                            No departments found
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <div class="card-footer">
        <nav class="pagination-component">

            <a class="pagination-button @(Model.Page == 1 ? "disabled" : "")"
               asp-action="Index"
               asp-route-page="@(Model.Page - 1)"
               asp-route-pageSize="@Model.PageSize"
               asp-route-search="@Model.Search">
                <i class="bi bi-chevron-left"></i>
            </a>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a class="pagination-button @(i == Model.Page ? "active" : "")"
                   asp-action="Index"
                   asp-route-page="@i"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-search="@Model.Search">
                    @i
                </a>
            }

            <a class="pagination-button @(Model.Page == Model.TotalPages ? "disabled" : "")"
               asp-action="Index"
               asp-route-page="@(Model.Page + 1)"
               asp-route-pageSize="@Model.PageSize"
               asp-route-search="@Model.Search">
                <i class="bi bi-chevron-right"></i>
            </a>

        </nav>

        <div class="text-center mt-3 text-muted small">
            Showing @((Model.Page - 1) * Model.PageSize + 1)
            to @Math.Min(Model.Page * Model.PageSize, Model.TotalCount)
            of @Model.TotalCount results
        </div>
    </div>
}

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Create" method="post" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Department</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div class="form-field">
                    <label class="form-label">
                        Department Name <span class="text-danger">*</span>
                    </label>
                    <input name="Name"
                           class="form-input"
                           placeholder="Department name"
                           required />
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="submit" class="btn-component btn-primary">
                    Save
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Edit" method="post" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Department</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" name="Id" id="editId" />
                <div class="form-field">
                    <label class="form-label">
                        Department Name <span class="text-danger">*</span>
                    </label>
                    <input name="Name"
                           id="editName"
                           class="form-input"
                           required />
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="submit" class="btn-component btn-primary">
                    Update
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Delete" method="post" class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirm Delete</h5>
                <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>
                    Are you sure you want to delete
                    <strong id="deleteDepartmentName"></strong>?
                </p>
                <input type="hidden" name="Id" id="deleteDepartmentId" />
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-component btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="submit" class="btn-component btn-destructive">
                    Delete
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Fill Edit Modal
        document.getElementById('editModal')
            .addEventListener('show.bs.modal', function (e) {
                var btn = e.relatedTarget;
                document.getElementById('editId').value = btn.getAttribute('data-id');
                document.getElementById('editName').value = btn.getAttribute('data-name');
            });

        // Fill Delete Modal
        document.getElementById('deleteModal')
            .addEventListener('show.bs.modal', function (e) {
                var btn = e.relatedTarget;
                document.getElementById('deleteDepartmentId').value = btn.getAttribute('data-id');
                document.getElementById('deleteDepartmentName').textContent =
                    btn.getAttribute('data-name');
            });

        @if (TempData["SuccessMessage"] != null)
        {
                            <text>showToast('@TempData["SuccessMessage"]', 'success');</text>
        }

        @if (TempData["ErrorMessage"] != null)
        {
                            <text>showToast('@TempData["ErrorMessage"]', 'error');</text>
        }
    </script>
}
